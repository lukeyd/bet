// simd-float — first-class float SIMD vectors (`vec4`/`vec2` = `f32xN`): construction, element-wise
// add, `scale` (scalar broadcast), the `dot` reduction, `length` (via sqrt), and `min`. Floats are
// never printed bare (corpus rule), so every result is reduced to an `int`. The interpreter holds
// lanes in true `f32`, and all values here are exactly representable, so interp == compiled.
pull "spill"

finna main() {
    lowkey a: vec4 = vec4(1.0, 2.0, 3.0, 4.0)
    lowkey b: vec4 = vec4(2.0, 2.0, 2.0, 2.0)

    lowkey c: vec4 = a + b
    spill.it(c.x as int)                     // [3,4,5,6] -> 3
    spill.it(a.dot(b) as int)                // 2+4+6+8 = 20

    lowkey d: vec4 = a.scale(3.0)
    spill.it(d.w as int)                     // [3,6,9,12] -> 12

    spill.it(vec4(3.0, 4.0, 0.0, 0.0).length() as int)  // sqrt(25) = 5
    spill.it(vec2(6.0, 8.0).length() as int)            // sqrt(100) = 10

    spill.it(vec2(1.0, 9.0).min(vec2(4.0, 4.0)).y as int) // [1,4] -> 4
}
