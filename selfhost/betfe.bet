// betfe — the self-hosted `bet` frontend's entry point (Milestone 7.1, Phase C).
//
// The eventual shape is: read a `.bet` source, lex -> parse -> lower, and PRINT the `.mir` text to
// stdout, where the existing Rust backend takes over (`bet build foo.mir`). The only contract is
// the `.mir` textual format (crates/midir/src/text.rs); no FFI into Rust is needed.
//
// SINGLE FILE, on purpose: `pull` is a no-op (the stdlib is compiler intrinsics) and `bet build`
// compiles ONE source file — there are no source imports. So the whole frontend lives here, the
// way the Rust `frontend` crate holds lexer.rs / parser.rs / lower.rs together and `--emit <kind>`
// stops after the relevant phase. Each phase is a section below.
//
// C1+C2+C3 done, C4 in progress — the LEXER and PARSER are real. `betfe --emit tokens <file>`
// prints the post-ASI token stream and `--emit ast <file>` prints the parsed AST, both in the exact
// format of crates/frontend/src/dump.rs and both verified byte-identical against `bet build --emit
// <kind>` over the WHOLE corpus by `cargo xtask selfhost`. `--emit mir <file>` lowers the AST to
// .mir text (C4): byte-identical for the growing supported subset (print-only main so far), the
// `%%UNSUPPORTED%%` sentinel otherwise. With NO args betfe still emits the fixed `hello` .mir (the
// C0 tracer) so the `.mir` -> backend -> binary pipeline stays proven; it retires once C4 covers it.
//
// A Token here is a `drip { kind, text, hasText }` where `kind` is the canonical DUMP TAG (not a
// 70-variant `moods` sum). This is deliberate: dump.rs maps every keyword to its own spelling, so
// the scanner sets `kind = word` for keywords and emit just prints `kind` — byte-identical output
// (the actual deliverable) with a fraction of the code. The parser (C3) matches on these kind
// strings and, since the lexer already normalized payloads to their dump forms, builds AST-dump
// labels by plain concatenation. See the C3 section header for the AST representation (a label-tree
// index arena) and the bet-semantics gotchas that shaped it.
pull "spill"
pull "str"
pull "vec"
pull "fs"
pull "sys"

// --- the growable string builder the emitters are built on (A2). ---
drip StrBuilder {
    buf: vec[u8]
}

finna sbNew() -> StrBuilder {
    bet StrBuilder{ buf: vec.new[u8]() }
}

finna (sb: StrBuilder) add(s: str) {
    sb.buf.append(s)
}

finna (sb: StrBuilder) finish() -> str {
    bet sb.buf.str()
}

// ===========================================================================
// C1 — the lexer (mirror of crates/frontend/src/lexer.rs).
// ===========================================================================

// A lexical token. `kind` is the canonical dump tag; `text` is the payload for the five tokens
// that carry one (ident / int / float / str / byte); `hasText` selects the `<tag> <payload>` form.
drip Token {
    kind: str,
    text: str,
    hasText: bool
}

finna tok0(k: str) -> Token {
    bet Token{ kind: k, text: "", hasText: cap }
}

finna tok1(k: str, t: str) -> Token {
    bet Token{ kind: k, text: t, hasText: nocap }
}

// --- byte classifiers (bytes compared as ints, as str.at returns them). ---

finna isDigit(c: int) -> bool {
    bet c >= 48 && c <= 57
}

finna isAlpha(c: int) -> bool {
    bet (c >= 97 && c <= 122) || (c >= 65 && c <= 90)
}

finna isIdentStart(c: int) -> bool {
    bet isAlpha(c) || c == 95
}

finna isIdentCont(c: int) -> bool {
    bet isAlpha(c) || isDigit(c) || c == 95
}

finna isHexDigit(c: int) -> bool {
    bet isDigit(c) || (c >= 97 && c <= 102) || (c >= 65 && c <= 70)
}

finna isDecCont(c: int) -> bool {
    bet isDigit(c) || c == 95
}

// Value of a hex/dec digit byte (0 for anything else — callers guard the class first).
finna hexVal(c: int) -> int {
    fr c >= 48 && c <= 57 {
        bet c - 48
    }
    fr c >= 97 && c <= 102 {
        bet c - 97 + 10
    }
    fr c >= 65 && c <= 70 {
        bet c - 65 + 10
    }
    bet 0
}

// The 32 L2 keywords (dump tag == surface spelling, per dump.rs::token_tag).
finna isKeyword(w: str) -> bool {
    bet str.slaps(w, "finna") ||
        str.slaps(w, "bet") ||
        str.slaps(w, "lowkey") ||
        str.slaps(w, "facts") ||
        str.slaps(w, "drip") ||
        str.slaps(w, "moods") ||
        str.slaps(w, "pull") ||
        str.slaps(w, "extern") ||
        str.slaps(w, "fr") ||
        str.slaps(w, "naw") ||
        str.slaps(w, "vibin") ||
        str.slaps(w, "squad") ||
        str.slaps(w, "dip") ||
        str.slaps(w, "skip") ||
        str.slaps(w, "vibe") ||
        str.slaps(w, "slide") ||
        str.slaps(w, "yeet") ||
        str.slaps(w, "sheesh") ||
        str.slaps(w, "bounce") ||
        str.slaps(w, "nocap") ||
        str.slaps(w, "cap") ||
        str.slaps(w, "ghosted") ||
        str.slaps(w, "flex") ||
        str.slaps(w, "hush") ||
        str.slaps(w, "crib") ||
        str.slaps(w, "cop") ||
        str.slaps(w, "evict") ||
        str.slaps(w, "tag") ||
        str.slaps(w, "holla") ||
        str.slaps(w, "trust") ||
        str.slaps(w, "in") ||
        str.slaps(w, "as")
}

// Whether a newline right after a token of `kind` TERMINATES the statement (grammar §L6).
finna endsStatement(k: str) -> bool {
    bet str.slaps(k, "ident") ||
        str.slaps(k, "int") ||
        str.slaps(k, "float") ||
        str.slaps(k, "str") ||
        str.slaps(k, "byte") ||
        str.slaps(k, "nocap") ||
        str.slaps(k, "cap") ||
        str.slaps(k, "ghosted") ||
        str.slaps(k, "rparen") ||
        str.slaps(k, "rbracket") ||
        str.slaps(k, "rbrace") ||
        str.slaps(k, "bet") ||
        str.slaps(k, "dip") ||
        str.slaps(k, "skip") ||
        str.slaps(k, "bounce")
}

// --- literal helpers ---

// Digit-string -> int in the given radix, skipping `_` separators.
finna parseNumVal(s: str, radix: int) -> int {
    lowkey acc = 0
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n {
        lowkey c = str.at(s, i)
        fr c != 95 {
            acc = acc * radix + hexVal(c)
        }
        i = i + 1
    }
    bet acc
}

// Non-negative int -> its decimal string (the dump prints the parsed VALUE, not the source).
finna itoa(n: int) -> str {
    fr n == 0 {
        bet "0"
    }
    lowkey digits = vec.new[u8]()
    lowkey x = n
    vibin x > 0 {
        digits.stack(((x % 10) + 48) as u8)
        x = x / 10
    }
    // Reverse (digits were produced least-significant-first). NOTE: vec.gang() is UNSIGNED —
    // cast to int or `i >= 0` never fails and `i - 1` wraps at 0 (an infinite loop).
    lowkey out = vec.new[u8]()
    lowkey i = (digits.gang() as int) - 1
    vibin i >= 0 {
        out.stack(digits[i])
        i = i - 1
    }
    bet out.str()
}

// Strip `_` separators from a numeric source slice (used for the float payload).
finna cleanNum(s: str) -> str {
    lowkey out = vec.new[u8]()
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n {
        lowkey c = str.at(s, i)
        fr c != 95 {
            out.stack(c as u8)
        }
        i = i + 1
    }
    bet out.str()
}

// Re-quote a string VALUE with the dump's minimal escape set (mirror dump.rs::quote).
finna quote(s: str) -> str {
    lowkey out = vec.new[u8]()
    out.stack(34 as u8)
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n {
        lowkey c = str.at(s, i)
        fr c == 92 {
            out.stack(92 as u8)
            out.stack(92 as u8)
        } naw fr c == 34 {
            out.stack(92 as u8)
            out.stack(34 as u8)
        } naw fr c == 10 {
            out.stack(92 as u8)
            out.stack(110 as u8)
        } naw fr c == 9 {
            out.stack(92 as u8)
            out.stack(116 as u8)
        } naw fr c == 13 {
            out.stack(92 as u8)
            out.stack(114 as u8)
        } naw {
            out.stack(c as u8)
        }
        i = i + 1
    }
    out.stack(34 as u8)
    bet out.str()
}

// Decode a string literal's escapes to its byte VALUE (mirror lexer.rs::unescape_str). `\xHH` is
// encoded as the UTF-8 of U+00HH, matching Rust's char->String path.
finna unescapeStr(s: str) -> str {
    lowkey out = vec.new[u8]()
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n {
        lowkey c = str.at(s, i)
        fr c == 92 {
            i = i + 1
            lowkey e = str.at(s, i)
            fr e == 110 {
                out.stack(10 as u8)
            } naw fr e == 116 {
                out.stack(9 as u8)
            } naw fr e == 114 {
                out.stack(13 as u8)
            } naw fr e == 92 {
                out.stack(92 as u8)
            } naw fr e == 34 {
                out.stack(34 as u8)
            } naw fr e == 39 {
                out.stack(39 as u8)
            } naw fr e == 48 {
                out.stack(0 as u8)
            } naw fr e == 120 {
                lowkey v = hexVal(str.at(s, i + 1)) * 16 + hexVal(str.at(s, i + 2))
                fr v < 128 {
                    out.stack(v as u8)
                } naw {
                    out.stack((192 + (v / 64)) as u8)
                    out.stack((128 + (v % 64)) as u8)
                }
                i = i + 2
            } naw {
                out.stack(e as u8)
            }
            i = i + 1
        } naw {
            out.stack(c as u8)
            i = i + 1
        }
    }
    bet out.str()
}

// The L6 ASI pass: collapse `newline` tokens into statement-terminating `semi`s (mirror
// lexer.rs::apply_asi).
finna applyAsi(raw: vec[Token]) -> vec[Token] {
    lowkey out = vec.new[Token]()
    lowkey prevEnds = cap
    lowkey n = raw.gang() as int
    lowkey i = 0
    vibin i < n {
        lowkey t = raw[i]
        fr str.slaps(t.kind, "newline") {
            fr prevEnds {
                out.stack(tok0("semi"))
                prevEnds = cap
            }
        } naw fr str.slaps(t.kind, "semi") {
            prevEnds = cap
            out.stack(t)
        } naw {
            prevEnds = endsStatement(t.kind)
            out.stack(t)
        }
        i = i + 1
    }
    bet out
}

// Tokenize a whole source string into the post-ASI token stream (mirror lexer.rs::tokenize).
finna lex(src: str) -> vec[Token] {
    lowkey raw = vec.new[Token]()
    lowkey n = str.len(src)
    lowkey i = 0
    vibin i < n {
        lowkey c = str.at(src, i)

        // whitespace (spaces / tabs)
        fr c == 32 || c == 9 {
            i = i + 1
            skip
        }
        // newline
        fr c == 10 {
            raw.stack(tok0("newline"))
            i = i + 1
            skip
        }
        // carriage return (\r or \r\n) -> one newline
        fr c == 13 {
            i = i + 1
            fr i < n && str.at(src, i) == 10 {
                i = i + 1
            }
            raw.stack(tok0("newline"))
            skip
        }
        // comments: `//` to end of line, `/* ... */` non-nesting
        fr c == 47 && i + 1 < n && (str.at(src, i + 1) == 47 || str.at(src, i + 1) == 42) {
            fr str.at(src, i + 1) == 47 {
                i = i + 2
                vibin i < n && str.at(src, i) != 10 {
                    i = i + 1
                }
            } naw {
                i = i + 2
                vibin i < n {
                    fr str.at(src, i) == 42 && i + 1 < n && str.at(src, i + 1) == 47 {
                        i = i + 2
                        dip
                    }
                    i = i + 1
                }
            }
            skip
        }
        // identifiers / keywords
        fr isIdentStart(c) {
            lowkey s0 = i
            vibin i < n && isIdentCont(str.at(src, i)) {
                i = i + 1
            }
            lowkey word = str.sub(src, s0, i)
            fr isKeyword(word) {
                raw.stack(tok0(word))
            } naw {
                raw.stack(tok1("ident", word))
            }
            skip
        }
        // numeric tower: hex / bin / decimal / float
        fr isDigit(c) {
            lowkey s0 = i
            fr c == 48 && i + 1 < n && str.at(src, i + 1) == 120 {
                i = i + 2
                lowkey ds = i
                vibin i < n && (isHexDigit(str.at(src, i)) || str.at(src, i) == 95) {
                    i = i + 1
                }
                raw.stack(tok1("int", itoa(parseNumVal(str.sub(src, ds, i), 16))))
            } naw fr c == 48 && i + 1 < n && str.at(src, i + 1) == 98 {
                i = i + 2
                lowkey ds = i
                vibin i < n && (str.at(src, i) == 48 || str.at(src, i) == 49 || str.at(src, i) == 95) {
                    i = i + 1
                }
                raw.stack(tok1("int", itoa(parseNumVal(str.sub(src, ds, i), 2))))
            } naw {
                vibin i < n && isDecCont(str.at(src, i)) {
                    i = i + 1
                }
                lowkey isFloat = cap
                // fractional part: `.` must be followed by a digit (else it's a Dot token)
                fr i < n && str.at(src, i) == 46 && i + 1 < n && isDigit(str.at(src, i + 1)) {
                    isFloat = nocap
                    i = i + 1
                    vibin i < n && isDecCont(str.at(src, i)) {
                        i = i + 1
                    }
                }
                // exponent: `e`/`E` then optional sign then a digit
                fr i < n && (str.at(src, i) == 101 || str.at(src, i) == 69) {
                    lowkey j = i + 1
                    fr j < n && (str.at(src, j) == 43 || str.at(src, j) == 45) {
                        j = j + 1
                    }
                    fr j < n && isDigit(str.at(src, j)) {
                        isFloat = nocap
                        i = j
                        vibin i < n && isDecCont(str.at(src, i)) {
                            i = i + 1
                        }
                    }
                }
                fr isFloat {
                    raw.stack(tok1("float", cleanNum(str.sub(src, s0, i))))
                } naw {
                    raw.stack(tok1("int", itoa(parseNumVal(str.sub(src, s0, i), 10))))
                }
            }
            skip
        }
        // string literal
        fr c == 34 {
            i = i + 1
            lowkey cs = i
            vibin i < n && str.at(src, i) != 34 {
                fr str.at(src, i) == 92 {
                    i = i + 1
                }
                i = i + 1
            }
            lowkey inner = str.sub(src, cs, i)
            i = i + 1
            raw.stack(tok1("str", quote(unescapeStr(inner))))
            skip
        }
        // byte literal
        fr c == 39 {
            i = i + 1
            lowkey bv = 0
            fr str.at(src, i) == 92 {
                i = i + 1
                lowkey e = str.at(src, i)
                fr e == 110 {
                    bv = 10
                } naw fr e == 116 {
                    bv = 9
                } naw fr e == 114 {
                    bv = 13
                } naw fr e == 92 {
                    bv = 92
                } naw fr e == 34 {
                    bv = 34
                } naw fr e == 39 {
                    bv = 39
                } naw fr e == 48 {
                    bv = 0
                } naw fr e == 120 {
                    bv = hexVal(str.at(src, i + 1)) * 16 + hexVal(str.at(src, i + 2))
                    i = i + 2
                } naw {
                    bv = e
                }
                i = i + 1
            } naw {
                bv = str.at(src, i)
                i = i + 1
            }
            i = i + 1
            raw.stack(tok1("byte", itoa(bv)))
            skip
        }

        // operators & punctuation (longest match wins)
        lowkey c1 = 0
        fr i + 1 < n {
            c1 = str.at(src, i + 1)
        }
        lowkey c2 = 0
        fr i + 2 < n {
            c2 = str.at(src, i + 2)
        }
        fr c == 60 && c1 == 60 && c2 == 61 {
            raw.stack(tok0("shleq"))
            i = i + 3
        } naw fr c == 62 && c1 == 62 && c2 == 61 {
            raw.stack(tok0("shreq"))
            i = i + 3
        } naw fr c == 45 && c1 == 62 {
            raw.stack(tok0("arrow"))
            i = i + 2
        } naw fr c == 61 && c1 == 61 {
            raw.stack(tok0("eqeq"))
            i = i + 2
        } naw fr c == 33 && c1 == 61 {
            raw.stack(tok0("ne"))
            i = i + 2
        } naw fr c == 60 && c1 == 61 {
            raw.stack(tok0("le"))
            i = i + 2
        } naw fr c == 62 && c1 == 61 {
            raw.stack(tok0("ge"))
            i = i + 2
        } naw fr c == 60 && c1 == 60 {
            raw.stack(tok0("shl"))
            i = i + 2
        } naw fr c == 62 && c1 == 62 {
            raw.stack(tok0("shr"))
            i = i + 2
        } naw fr c == 38 && c1 == 38 {
            raw.stack(tok0("andand"))
            i = i + 2
        } naw fr c == 124 && c1 == 124 {
            raw.stack(tok0("oror"))
            i = i + 2
        } naw fr c == 43 && c1 == 61 {
            raw.stack(tok0("pluseq"))
            i = i + 2
        } naw fr c == 45 && c1 == 61 {
            raw.stack(tok0("minuseq"))
            i = i + 2
        } naw fr c == 42 && c1 == 61 {
            raw.stack(tok0("stareq"))
            i = i + 2
        } naw fr c == 47 && c1 == 61 {
            raw.stack(tok0("slasheq"))
            i = i + 2
        } naw fr c == 37 && c1 == 61 {
            raw.stack(tok0("percenteq"))
            i = i + 2
        } naw fr c == 38 && c1 == 61 {
            raw.stack(tok0("ampeq"))
            i = i + 2
        } naw fr c == 124 && c1 == 61 {
            raw.stack(tok0("pipeeq"))
            i = i + 2
        } naw fr c == 94 && c1 == 61 {
            raw.stack(tok0("careteq"))
            i = i + 2
        } naw fr c == 60 {
            raw.stack(tok0("lt"))
            i = i + 1
        } naw fr c == 62 {
            raw.stack(tok0("gt"))
            i = i + 1
        } naw fr c == 61 {
            raw.stack(tok0("eq"))
            i = i + 1
        } naw fr c == 43 {
            raw.stack(tok0("plus"))
            i = i + 1
        } naw fr c == 45 {
            raw.stack(tok0("minus"))
            i = i + 1
        } naw fr c == 42 {
            raw.stack(tok0("star"))
            i = i + 1
        } naw fr c == 47 {
            raw.stack(tok0("slash"))
            i = i + 1
        } naw fr c == 37 {
            raw.stack(tok0("percent"))
            i = i + 1
        } naw fr c == 38 {
            raw.stack(tok0("amp"))
            i = i + 1
        } naw fr c == 124 {
            raw.stack(tok0("pipe"))
            i = i + 1
        } naw fr c == 94 {
            raw.stack(tok0("caret"))
            i = i + 1
        } naw fr c == 126 {
            raw.stack(tok0("tilde"))
            i = i + 1
        } naw fr c == 33 {
            raw.stack(tok0("bang"))
            i = i + 1
        } naw fr c == 46 {
            raw.stack(tok0("dot"))
            i = i + 1
        } naw fr c == 44 {
            raw.stack(tok0("comma"))
            i = i + 1
        } naw fr c == 58 {
            raw.stack(tok0("colon"))
            i = i + 1
        } naw fr c == 59 {
            raw.stack(tok0("semi"))
            i = i + 1
        } naw fr c == 91 {
            raw.stack(tok0("lbracket"))
            i = i + 1
        } naw fr c == 93 {
            raw.stack(tok0("rbracket"))
            i = i + 1
        } naw fr c == 40 {
            raw.stack(tok0("lparen"))
            i = i + 1
        } naw fr c == 41 {
            raw.stack(tok0("rparen"))
            i = i + 1
        } naw fr c == 123 {
            raw.stack(tok0("lbrace"))
            i = i + 1
        } naw fr c == 125 {
            raw.stack(tok0("rbrace"))
            i = i + 1
        } naw {
            // unknown byte — the Rust lexer errors here; we skip so the diff localizes it.
            i = i + 1
        }
    }
    bet applyAsi(raw)
}

// Print the post-ASI token stream, one token per line, EXACTLY as dump.rs::tokens does.
finna emitTokens(toks: vec[Token]) -> str {
    lowkey sb = sbNew()
    lowkey n = toks.gang() as int
    lowkey i = 0
    vibin i < n {
        lowkey t = toks[i]
        sb.add(t.kind)
        fr t.hasText {
            sb.add(" ")
            sb.add(t.text)
        }
        sb.add("\n")
        i = i + 1
    }
    bet sb.finish()
}

// ===========================================================================
// C3 — the parser (mirror of crates/frontend/src/parser.rs).
//
// Builds a LABEL-TREE arena: every line of the AST dump (dump.rs::ast) is one Node{label,kids}.
// A parse function advances a shared cursor and returns the index of the node it built; emitAst
// walks the tree printing label at depth and recursing kids at depth+1 — so the output is
// byte-identical to dump.rs::ast BY CONSTRUCTION. The lexer already normalized payloads to their
// dump forms (quoted strings, itoa'd ints), so labels are built by plain concatenation.
//
// bet gotchas honored here: (1) structs pass BY VALUE, so all mutable parser state lives in
// shared-handle vecs — `pos`/`ns` are 1-element cells mutated via pop+stack (v[i]=x does NOT
// lower on the compiled path). (2) vec.gang() is UNSIGNED, cast `as int` for signed loops.
// (3) multi-line bool exprs would ASI-split, so conditions stay on one line.
// ===========================================================================

// A parse tree node: `label` is the exact AST-dump line; `kids` are child node indices.
drip Node {
    label: str,
    kids: vec[int]
}

// The parser state. Every mutable field is a shared-handle vec (see the by-value note above):
// `toks` the post-ASI stream, `pos` a 1-elem cursor cell, `nodes` the arena, `ns` a 1-elem
// no-struct flag cell (§L6 rule 3: a header `{` reads as a block, not a struct literal).
drip P {
    toks: vec[Token],
    pos: vec[int],
    nodes: vec[Node],
    ns: vec[int]
}

// --- tiny string helpers (labels are built by concatenation) ---
finna isEmpty(s: str) -> bool {
    bet str.len(s) == 0
}

finna sp2(a: str, b: str) -> str {
    lowkey sb = sbNew()
    sb.add(a)
    sb.add(" ")
    sb.add(b)
    bet sb.finish()
}

finna sp3(a: str, b: str, c: str) -> str {
    bet sp2(sp2(a, b), c)
}

// --- arena ---
finna mkNode(p: P, label: str) -> int {
    lowkey i = p.nodes.gang() as int
    p.nodes.stack(Node{ label: label, kids: vec.new[int]() })
    bet i
}

finna addKid(p: P, parent: int, child: int) {
    p.nodes[parent].kids.stack(child)
}

// --- cursor cell (a 1-elem vec mutated via pop+stack) ---
finna curGet(p: P) -> int {
    bet p.pos[0]
}

finna curSet(p: P, v: int) {
    p.pos.pop()
    p.pos.stack(v)
}

finna adv(p: P) {
    curSet(p, curGet(p) + 1)
}

finna toksLen(p: P) -> int {
    bet p.toks.gang() as int
}

finna atEof(p: P) -> bool {
    bet curGet(p) >= toksLen(p)
}

finna curKind(p: P) -> str {
    fr atEof(p) { bet "" }
    bet p.toks[curGet(p)].kind
}

finna curText(p: P) -> str {
    fr atEof(p) { bet "" }
    bet p.toks[curGet(p)].text
}

finna peek2Kind(p: P) -> str {
    lowkey j = curGet(p) + 1
    fr j >= toksLen(p) { bet "" }
    bet p.toks[j].kind
}

finna check(p: P, k: str) -> bool {
    bet str.slaps(curKind(p), k)
}

finna eat(p: P, k: str) -> bool {
    fr check(p, k) {
        adv(p)
        bet nocap
    }
    bet cap
}

// Best-effort: on valid corpus input the expected token is always present. On invalid input we
// leave the cursor put so the AST diff localizes the divergence (no silent recovery).
finna expect(p: P, k: str) {
    fr check(p, k) { adv(p) }
}

finna ident(p: P) -> str {
    lowkey t = curText(p)
    adv(p)
    bet t
}

finna skipSemis(p: P) {
    vibin check(p, "semi") { adv(p) }
}

// --- no_struct flag cell ---
finna nsGet(p: P) -> bool {
    bet p.ns[0] == 1
}

finna nsSet(p: P, v: bool) {
    p.ns.pop()
    fr v { p.ns.stack(1) } naw { p.ns.stack(0) }
}

// --- types (§S3) ---
finna parseType(p: P) -> int {
    // `[]T` — slice.
    fr check(p, "lbracket") {
        adv(p)
        expect(p, "rbracket")
        lowkey inner = parseType(p)
        lowkey n = mkNode(p, "slice")
        addKid(p, n, inner)
        bet n
    }
    fr eat(p, "tag") {
        lowkey inner = parseType(p)
        lowkey n = mkNode(p, "tag")
        addKid(p, n, inner)
        bet n
    }
    fr eat(p, "crib") {
        lowkey inner = parseType(p)
        lowkey n = mkNode(p, "crib-ty")
        addKid(p, n, inner)
        bet n
    }
    fr eat(p, "finna") {
        expect(p, "lparen")
        lowkey fnNode = mkNode(p, "fn-ty")
        lowkey paramsNode = mkNode(p, "params")
        fr !check(p, "rparen") {
            addKid(p, paramsNode, parseType(p))
            vibin eat(p, "comma") {
                addKid(p, paramsNode, parseType(p))
            }
        }
        expect(p, "rparen")
        expect(p, "arrow")
        lowkey retNode = mkNode(p, "ret")
        addKid(p, retNode, parseType(p))
        addKid(p, fnNode, paramsNode)
        addKid(p, fnNode, retNode)
        bet fnNode
    }
    // A named type (`int`, `stash[str, i64]`, `Enemy`) or `rawptr`.
    lowkey name = ident(p)
    fr str.slaps(name, "rawptr") {
        bet mkNode(p, "rawptr")
    }
    lowkey node = mkNode(p, sp2("named", name))
    // Generic args: `[` NOT immediately followed by an int literal.
    fr check(p, "lbracket") && !str.slaps(peek2Kind(p), "int") {
        adv(p)
        addKid(p, node, parseType(p))
        vibin eat(p, "comma") {
            addKid(p, node, parseType(p))
        }
        expect(p, "rbracket")
    }
    // Trailing fixed-array dims: `Enemy[1000]`.
    vibin check(p, "lbracket") && str.slaps(peek2Kind(p), "int") {
        adv(p)
        lowkey sizeText = curText(p)
        adv(p)
        expect(p, "rbracket")
        lowkey arr = mkNode(p, sp2("array", sizeText))
        addKid(p, arr, node)
        node = arr
    }
    bet node
}

// --- expressions (§E1 precedence ladder) ---
// A header expression: unparenthesized struct literals disabled so a trailing `{` is a block.
finna exprHeader(p: P) -> int {
    lowkey saved = nsGet(p)
    nsSet(p, nocap)
    lowkey e = parseExpr(p)
    nsSet(p, saved)
    bet e
}

// A sub-expression with struct literals RE-enabled (inside brackets).
finna fullExpr(p: P) -> int {
    lowkey saved = nsGet(p)
    nsSet(p, cap)
    lowkey e = parseExpr(p)
    nsSet(p, saved)
    bet e
}

finna parseExpr(p: P) -> int {
    bet orExpr(p)
}

finna mkBinary(p: P, opTag: str, l: int, r: int) -> int {
    lowkey n = mkNode(p, sp2("binary", opTag))
    addKid(p, n, l)
    addKid(p, n, r)
    bet n
}

finna orExpr(p: P) -> int {
    lowkey lhs = andExpr(p)
    vibin eat(p, "oror") {
        lowkey rhs = andExpr(p)
        lhs = mkBinary(p, "or", lhs, rhs)
    }
    bet lhs
}

finna andExpr(p: P) -> int {
    lowkey lhs = cmpExpr(p)
    vibin eat(p, "andand") {
        lowkey rhs = cmpExpr(p)
        lhs = mkBinary(p, "and", lhs, rhs)
    }
    bet lhs
}

finna cmpTag(p: P) -> str {
    fr check(p, "eqeq") { bet "eq" }
    fr check(p, "ne") { bet "ne" }
    fr check(p, "lt") { bet "lt" }
    fr check(p, "le") { bet "le" }
    fr check(p, "gt") { bet "gt" }
    fr check(p, "ge") { bet "ge" }
    bet ""
}

finna cmpExpr(p: P) -> int {
    lowkey lhs = bitorExpr(p)
    lowkey opTag = cmpTag(p)
    vibin !isEmpty(opTag) {
        adv(p)
        lowkey rhs = bitorExpr(p)
        lhs = mkBinary(p, opTag, lhs, rhs)
        opTag = cmpTag(p)
    }
    bet lhs
}

finna bitorExpr(p: P) -> int {
    lowkey lhs = bitxorExpr(p)
    vibin eat(p, "pipe") {
        lowkey rhs = bitxorExpr(p)
        lhs = mkBinary(p, "bitor", lhs, rhs)
    }
    bet lhs
}

finna bitxorExpr(p: P) -> int {
    lowkey lhs = bitandExpr(p)
    vibin eat(p, "caret") {
        lowkey rhs = bitandExpr(p)
        lhs = mkBinary(p, "bitxor", lhs, rhs)
    }
    bet lhs
}

finna bitandExpr(p: P) -> int {
    lowkey lhs = shiftExpr(p)
    vibin eat(p, "amp") {
        lowkey rhs = shiftExpr(p)
        lhs = mkBinary(p, "bitand", lhs, rhs)
    }
    bet lhs
}

finna shiftTag(p: P) -> str {
    fr check(p, "shl") { bet "shl" }
    fr check(p, "shr") { bet "shr" }
    bet ""
}

finna shiftExpr(p: P) -> int {
    lowkey lhs = addExpr(p)
    lowkey opTag = shiftTag(p)
    vibin !isEmpty(opTag) {
        adv(p)
        lowkey rhs = addExpr(p)
        lhs = mkBinary(p, opTag, lhs, rhs)
        opTag = shiftTag(p)
    }
    bet lhs
}

finna addTag(p: P) -> str {
    fr check(p, "plus") { bet "add" }
    fr check(p, "minus") { bet "sub" }
    bet ""
}

finna addExpr(p: P) -> int {
    lowkey lhs = mulExpr(p)
    lowkey opTag = addTag(p)
    vibin !isEmpty(opTag) {
        adv(p)
        lowkey rhs = mulExpr(p)
        lhs = mkBinary(p, opTag, lhs, rhs)
        opTag = addTag(p)
    }
    bet lhs
}

finna mulTag(p: P) -> str {
    fr check(p, "star") { bet "mul" }
    fr check(p, "slash") { bet "div" }
    fr check(p, "percent") { bet "rem" }
    bet ""
}

finna mulExpr(p: P) -> int {
    lowkey lhs = castExpr(p)
    lowkey opTag = mulTag(p)
    vibin !isEmpty(opTag) {
        adv(p)
        lowkey rhs = castExpr(p)
        lhs = mkBinary(p, opTag, lhs, rhs)
        opTag = mulTag(p)
    }
    bet lhs
}

finna castExpr(p: P) -> int {
    lowkey e = unaryExpr(p)
    vibin eat(p, "as") {
        lowkey ty = parseType(p)
        lowkey n = mkNode(p, "cast")
        addKid(p, n, e)
        addKid(p, n, ty)
        e = n
    }
    bet e
}

finna unaryExpr(p: P) -> int {
    lowkey opTag = ""
    fr check(p, "bang") {
        opTag = "not"
    } naw fr check(p, "tilde") {
        opTag = "bitnot"
    } naw fr check(p, "minus") {
        opTag = "neg"
    }
    fr isEmpty(opTag) {
        bet postfixExpr(p)
    }
    adv(p)
    lowkey operand = unaryExpr(p)
    lowkey n = mkNode(p, sp2("unary", opTag))
    addKid(p, n, operand)
    bet n
}

finna postfixExpr(p: P) -> int {
    lowkey e = primary(p)
    vibin nocap {
        fr check(p, "dot") {
            adv(p)
            fr eat(p, "trust") {
                expect(p, "lparen")
                expect(p, "rparen")
                expect(p, "in")
                lowkey cribE = primary(p)
                lowkey n = mkNode(p, "trust")
                addKid(p, n, e)
                addKid(p, n, cribE)
                e = n
            } naw {
                lowkey name = ident(p)
                lowkey gens = maybeGenericArgs(p)
                fr check(p, "lparen") {
                    lowkey argsNode = callArgs(p)
                    lowkey n = mkNode(p, sp2("method", name))
                    lowkey recv = mkNode(p, "receiver")
                    addKid(p, recv, e)
                    addKid(p, n, recv)
                    addTypeargs(p, n, gens)
                    addKid(p, n, argsNode)
                    e = n
                } naw {
                    lowkey n = mkNode(p, sp2("field", name))
                    addKid(p, n, e)
                    addTypeargs(p, n, gens)
                    e = n
                }
            }
        } naw fr check(p, "lparen") {
            lowkey argsNode = callArgs(p)
            lowkey n = mkNode(p, "call")
            lowkey callee = mkNode(p, "callee")
            addKid(p, callee, e)
            addKid(p, n, callee)
            addKid(p, n, argsNode)
            e = n
        } naw fr check(p, "lbracket") {
            adv(p)
            lowkey index = fullExpr(p)
            expect(p, "rbracket")
            lowkey n = mkNode(p, "index")
            addKid(p, n, e)
            addKid(p, n, index)
            e = n
        } naw {
            dip
        }
    }
    bet e
}

finna primary(p: P) -> int {
    fr check(p, "int") {
        lowkey t = curText(p)
        adv(p)
        bet mkNode(p, sp2("int", t))
    }
    fr check(p, "float") {
        lowkey t = curText(p)
        adv(p)
        bet mkNode(p, sp2("float", t))
    }
    fr check(p, "str") {
        lowkey t = curText(p)
        adv(p)
        bet mkNode(p, sp2("str", t))
    }
    fr check(p, "byte") {
        lowkey t = curText(p)
        adv(p)
        bet mkNode(p, sp2("byte", t))
    }
    fr check(p, "nocap") {
        adv(p)
        bet mkNode(p, "bool true")
    }
    fr check(p, "cap") {
        adv(p)
        bet mkNode(p, "bool false")
    }
    fr check(p, "ghosted") {
        adv(p)
        bet mkNode(p, "ghosted")
    }
    fr check(p, "cop") {
        bet copExpr(p)
    }
    fr check(p, "lparen") {
        adv(p)
        lowkey inner = fullExpr(p)
        expect(p, "rparen")
        bet inner
    }
    fr check(p, "lbracket") {
        bet arrayLit(p)
    }
    // ident: a name reference or a struct literal.
    lowkey name = ident(p)
    lowkey gens = maybeGenericArgs(p)
    fr !nsGet(p) && check(p, "lbrace") {
        bet structLitBody(p, name, gens)
    }
    lowkey n = mkNode(p, sp2("name", name))
    addTypeargs(p, n, gens)
    bet n
}

// `[ "[" typeList "]" ]` after a name — generic instantiation, returned as a list of type-node
// indices (empty if not a generic list). Only consumed when the bracket group is followed by `(`
// (a call) or, where struct literals are allowed, `{`.
finna maybeGenericArgs(p: P) -> vec[int] {
    lowkey out = vec.new[int]()
    fr !check(p, "lbracket") {
        bet out
    }
    lowkey after = peekAfterMatchingBracket(p)
    lowkey looksGeneric = cap
    fr str.slaps(after, "lparen") {
        looksGeneric = nocap
    } naw fr str.slaps(after, "lbrace") {
        looksGeneric = !nsGet(p)
    }
    fr !looksGeneric {
        bet out
    }
    adv(p)
    out.stack(parseType(p))
    vibin eat(p, "comma") {
        out.stack(parseType(p))
    }
    expect(p, "rbracket")
    bet out
}

// A `typeargs` wrapper over a generic-arg list — attached only when the list is non-empty.
finna addTypeargs(p: P, parent: int, tys: vec[int]) {
    lowkey n = tys.gang() as int
    fr n > 0 {
        lowkey w = mkNode(p, "typeargs")
        lowkey i = 0
        vibin i < n {
            addKid(p, w, tys[i])
            i = i + 1
        }
        addKid(p, parent, w)
    }
}

// The token kind immediately following the bracket group that starts at the current `[`
// (balanced across all bracket kinds). Disambiguates generics from indexing.
finna peekAfterMatchingBracket(p: P) -> str {
    lowkey depth = 0
    lowkey i = curGet(p)
    lowkey n = toksLen(p)
    vibin i < n {
        lowkey k = p.toks[i].kind
        fr str.slaps(k, "lbracket") || str.slaps(k, "lparen") || str.slaps(k, "lbrace") {
            depth = depth + 1
        } naw fr str.slaps(k, "rbracket") || str.slaps(k, "rparen") || str.slaps(k, "rbrace") {
            depth = depth - 1
            fr depth == 0 {
                lowkey j = i + 1
                fr j < n { bet p.toks[j].kind }
                bet ""
            }
        }
        i = i + 1
    }
    bet ""
}

finna structLitBody(p: P, name: str, gens: vec[int]) -> int {
    lowkey saved = nsGet(p)
    nsSet(p, cap)
    expect(p, "lbrace")
    lowkey node = mkNode(p, sp2("struct", name))
    addTypeargs(p, node, gens)
    lowkey fieldsNode = mkNode(p, "fields")
    vibin nocap {
        skipSemis(p)
        fr check(p, "rbrace") || atEof(p) { dip }
        lowkey fname = ident(p)
        expect(p, "colon")
        lowkey value = parseExpr(p)
        lowkey fnode = mkNode(p, sp2("field", fname))
        addKid(p, fnode, value)
        addKid(p, fieldsNode, fnode)
        skipSemis(p)
        fr !eat(p, "comma") {
            skipSemis(p)
        }
    }
    expect(p, "rbrace")
    nsSet(p, saved)
    addKid(p, node, fieldsNode)
    bet node
}

finna arrayLit(p: P) -> int {
    lowkey saved = nsGet(p)
    nsSet(p, cap)
    expect(p, "lbracket")
    lowkey node = mkNode(p, "array-lit")
    fr !check(p, "rbracket") {
        addKid(p, node, parseExpr(p))
        vibin eat(p, "comma") {
            fr check(p, "rbracket") { dip }
            addKid(p, node, parseExpr(p))
        }
    }
    expect(p, "rbracket")
    nsSet(p, saved)
    bet node
}

finna copExpr(p: P) -> int {
    expect(p, "cop")
    lowkey node = mkNode(p, "cop")
    addKid(p, node, copInit(p))
    expect(p, "in")
    lowkey cribE = postfixExpr(p)
    lowkey cribW = mkNode(p, "crib")
    addKid(p, cribW, cribE)
    addKid(p, node, cribW)
    bet node
}

finna copInit(p: P) -> int {
    lowkey name = ident(p)
    lowkey gens = maybeGenericArgs(p)
    fr check(p, "lbrace") {
        bet structLitBody(p, name, gens)
    }
    fr check(p, "lparen") {
        lowkey argsNode = callArgs(p)
        lowkey n = mkNode(p, sp2("variant", name))
        addKid(p, n, argsNode)
        bet n
    }
    // Nullary variant — dump.rs still emits an (empty) `args` wrapper.
    lowkey n = mkNode(p, sp2("variant", name))
    addKid(p, n, mkNode(p, "args"))
    bet n
}

finna callArgs(p: P) -> int {
    lowkey saved = nsGet(p)
    nsSet(p, cap)
    expect(p, "lparen")
    lowkey node = mkNode(p, "args")
    fr !check(p, "rparen") {
        addKid(p, node, parseArg(p))
        vibin eat(p, "comma") {
            fr check(p, "rparen") { dip }
            addKid(p, node, parseArg(p))
        }
    }
    expect(p, "rparen")
    nsSet(p, saved)
    bet node
}

finna parseArg(p: P) -> int {
    // Optional `label:` — an ident (or the `in` keyword) immediately followed by `:`.
    lowkey label = ""
    lowkey hasLabel = cap
    fr str.slaps(curKind(p), "ident") && str.slaps(peek2Kind(p), "colon") {
        label = ident(p)
        expect(p, "colon")
        hasLabel = nocap
    } naw fr str.slaps(curKind(p), "in") && str.slaps(peek2Kind(p), "colon") {
        expect(p, "in")
        expect(p, "colon")
        label = "in"
        hasLabel = nocap
    }
    lowkey value = parseExpr(p)
    lowkey node = 0
    fr hasLabel {
        node = mkNode(p, sp2("arg", label))
    } naw {
        node = mkNode(p, "arg")
    }
    addKid(p, node, value)
    bet node
}

// --- statements (§S4) ---
finna parseBlock(p: P) -> int {
    expect(p, "lbrace")
    lowkey node = mkNode(p, "block")
    vibin nocap {
        skipSemis(p)
        fr check(p, "rbrace") || atEof(p) { dip }
        addKid(p, node, parseStmt(p))
    }
    expect(p, "rbrace")
    bet node
}

finna stmtEnds(p: P) -> bool {
    bet atEof(p) || check(p, "semi") || check(p, "rbrace")
}

finna parseStmt(p: P) -> int {
    fr check(p, "lowkey") { bet varDecl(p, "hush") }
    fr check(p, "facts") { bet constDecl(p, "hush") }
    fr check(p, "crib") { bet cribDecl(p, "hush") }
    fr check(p, "fr") { bet frStmt(p) }
    fr check(p, "vibin") { bet vibinStmt(p) }
    fr check(p, "squad") { bet squadStmt(p) }
    fr check(p, "vibe") { bet vibeStmt(p) }
    fr check(p, "holla") { bet hollaStmt(p) }
    fr check(p, "sheesh") { bet sheeshStmt(p) }
    fr check(p, "evict") {
        adv(p)
        lowkey n = mkNode(p, "evict")
        addKid(p, n, parseExpr(p))
        bet n
    }
    fr check(p, "slide") {
        adv(p)
        lowkey n = mkNode(p, "slide")
        addKid(p, n, parseExpr(p))
        bet n
    }
    fr check(p, "bet") {
        adv(p)
        lowkey n = mkNode(p, "bet")
        fr !stmtEnds(p) {
            addKid(p, n, parseExpr(p))
            vibin eat(p, "comma") {
                addKid(p, n, parseExpr(p))
            }
        }
        bet n
    }
    fr check(p, "bounce") {
        adv(p)
        lowkey n = mkNode(p, "bounce")
        addKid(p, n, parseExpr(p))
        bet n
    }
    fr check(p, "yeet") {
        adv(p)
        expect(p, "lparen")
        lowkey e = parseExpr(p)
        expect(p, "rparen")
        lowkey n = mkNode(p, "yeet")
        addKid(p, n, e)
        bet n
    }
    fr check(p, "dip") {
        adv(p)
        bet mkNode(p, "dip")
    }
    fr check(p, "skip") {
        adv(p)
        bet mkNode(p, "skip")
    }
    bet exprOrAssign(p)
}

finna exprOrAssign(p: P) -> int {
    lowkey first = parseExpr(p)
    lowkey op = assignTag(p)
    fr check(p, "comma") || !isEmpty(op) {
        lowkey targets = mkNode(p, "targets")
        addKid(p, targets, first)
        vibin eat(p, "comma") {
            addKid(p, targets, parseExpr(p))
        }
        op = assignTag(p)
        adv(p)
        lowkey values = mkNode(p, "values")
        addKid(p, values, parseExpr(p))
        vibin eat(p, "comma") {
            addKid(p, values, parseExpr(p))
        }
        lowkey n = mkNode(p, sp2("assign", op))
        addKid(p, n, targets)
        addKid(p, n, values)
        bet n
    }
    lowkey n = mkNode(p, "expr-stmt")
    addKid(p, n, first)
    bet n
}

finna assignTag(p: P) -> str {
    fr check(p, "eq") { bet "eq" }
    fr check(p, "pluseq") { bet "addeq" }
    fr check(p, "minuseq") { bet "subeq" }
    fr check(p, "stareq") { bet "muleq" }
    fr check(p, "slasheq") { bet "diveq" }
    fr check(p, "percenteq") { bet "remeq" }
    fr check(p, "ampeq") { bet "andeq" }
    fr check(p, "pipeeq") { bet "oreq" }
    fr check(p, "careteq") { bet "xoreq" }
    fr check(p, "shleq") { bet "shleq" }
    fr check(p, "shreq") { bet "shreq" }
    bet ""
}

finna frStmt(p: P) -> int {
    expect(p, "fr")
    lowkey node = mkNode(p, "fr")
    addKid(p, node, exprHeader(p))
    addKid(p, node, parseBlock(p))
    vibin eat(p, "naw") {
        fr eat(p, "fr") {
            lowkey elif = mkNode(p, "elif")
            addKid(p, elif, exprHeader(p))
            addKid(p, elif, parseBlock(p))
            addKid(p, node, elif)
        } naw {
            lowkey els = mkNode(p, "else")
            addKid(p, els, parseBlock(p))
            addKid(p, node, els)
            dip
        }
    }
    bet node
}

finna vibinStmt(p: P) -> int {
    expect(p, "vibin")
    lowkey node = mkNode(p, "vibin")
    addKid(p, node, exprHeader(p))
    addKid(p, node, parseBlock(p))
    bet node
}

finna squadStmt(p: P) -> int {
    expect(p, "squad")
    lowkey var = ident(p)
    expect(p, "in")
    lowkey node = mkNode(p, sp2("squad", var))
    addKid(p, node, exprHeader(p))
    addKid(p, node, parseBlock(p))
    bet node
}

finna vibeStmt(p: P) -> int {
    expect(p, "vibe")
    lowkey node = mkNode(p, "vibe")
    addKid(p, node, exprHeader(p))
    expect(p, "lbrace")
    vibin nocap {
        skipSemis(p)
        fr check(p, "rbrace") || atEof(p) { dip }
        fr eat(p, "naw") {
            lowkey def = mkNode(p, "default")
            addKid(p, def, parseBlock(p))
            addKid(p, node, def)
            skipSemis(p)
            dip
        }
        addKid(p, node, matchArm(p))
    }
    expect(p, "rbrace")
    bet node
}

finna matchArm(p: P) -> int {
    lowkey variant = ident(p)
    lowkey binds = ""
    fr eat(p, "lparen") {
        binds = ident(p)
        vibin eat(p, "comma") {
            binds = sp2(binds, ident(p))
        }
        expect(p, "rparen")
    }
    lowkey label = ""
    fr isEmpty(binds) {
        label = sp2("arm", variant)
    } naw {
        label = sp3("arm", variant, binds)
    }
    lowkey node = mkNode(p, label)
    addKid(p, node, parseBlock(p))
    bet node
}

finna hollaStmt(p: P) -> int {
    expect(p, "holla")
    lowkey binding = ident(p)
    expect(p, "eq")
    lowkey tagE = parseExpr(p)
    expect(p, "in")
    lowkey cribE = exprHeader(p)
    lowkey live = parseBlock(p)
    expect(p, "ghosted")
    lowkey ghost = parseBlock(p)
    lowkey node = mkNode(p, sp2("holla", binding))
    lowkey tagW = mkNode(p, "tag")
    addKid(p, tagW, tagE)
    addKid(p, node, tagW)
    lowkey cribW = mkNode(p, "crib")
    addKid(p, cribW, cribE)
    addKid(p, node, cribW)
    lowkey liveW = mkNode(p, "live")
    addKid(p, liveW, live)
    addKid(p, node, liveW)
    lowkey ghostW = mkNode(p, "ghosted")
    addKid(p, ghostW, ghost)
    addKid(p, node, ghostW)
    bet node
}

finna sheeshStmt(p: P) -> int {
    expect(p, "sheesh")
    lowkey node = mkNode(p, "sheesh")
    addKid(p, node, parseBlock(p))
    fr eat(p, "naw") {
        lowkey name = ident(p)
        lowkey b = parseBlock(p)
        lowkey rec = mkNode(p, sp2("recover", name))
        addKid(p, rec, b)
        addKid(p, node, rec)
    }
    bet node
}

finna varDecl(p: P, vis: str) -> int {
    expect(p, "lowkey")
    lowkey targets = ident(p)
    vibin eat(p, "comma") {
        targets = sp2(targets, ident(p))
    }
    lowkey hasTy = cap
    lowkey tyNode = 0
    fr eat(p, "colon") {
        hasTy = nocap
        tyNode = parseType(p)
    }
    expect(p, "eq")
    lowkey node = mkNode(p, sp3("var", vis, targets))
    fr hasTy {
        lowkey tw = mkNode(p, "type")
        addKid(p, tw, tyNode)
        addKid(p, node, tw)
    }
    lowkey values = mkNode(p, "values")
    addKid(p, values, parseExpr(p))
    vibin eat(p, "comma") {
        addKid(p, values, parseExpr(p))
    }
    addKid(p, node, values)
    bet node
}

finna constDecl(p: P, vis: str) -> int {
    expect(p, "facts")
    lowkey name = ident(p)
    lowkey hasTy = cap
    lowkey tyNode = 0
    fr eat(p, "colon") {
        hasTy = nocap
        tyNode = parseType(p)
    }
    expect(p, "eq")
    lowkey value = parseExpr(p)
    lowkey node = mkNode(p, sp3("const", vis, name))
    fr hasTy {
        lowkey tw = mkNode(p, "type")
        addKid(p, tw, tyNode)
        addKid(p, node, tw)
    }
    lowkey vw = mkNode(p, "value")
    addKid(p, vw, value)
    addKid(p, node, vw)
    bet node
}

finna cribDecl(p: P, vis: str) -> int {
    expect(p, "crib")
    lowkey name = ident(p)
    lowkey node = mkNode(p, sp3("crib", vis, name))
    fr eat(p, "colon") {
        addKid(p, node, parseType(p))
    }
    bet node
}

// --- top-level items (§S1) ---
finna parseProgram(p: P) -> int {
    lowkey root = mkNode(p, "program")
    vibin nocap {
        skipSemis(p)
        fr atEof(p) { dip }
        addKid(p, root, topItem(p))
    }
    bet root
}

finna topItem(p: P) -> int {
    fr check(p, "pull") { bet pullItem(p) }
    fr check(p, "extern") { bet externDecl(p) }
    lowkey vis = "hush"
    fr eat(p, "flex") { vis = "flex" }
    fr check(p, "finna") { bet fnDecl(p, vis) }
    fr check(p, "drip") { bet dripDecl(p, vis) }
    fr check(p, "moods") { bet moodsDecl(p, vis) }
    fr check(p, "crib") { bet cribDecl(p, vis) }
    fr check(p, "facts") { bet constDecl(p, vis) }
    fr check(p, "lowkey") { bet varDecl(p, vis) }
    // Unexpected (never on valid input) — a placeholder so the diff localizes it.
    adv(p)
    bet mkNode(p, "unexpected")
}

finna pullItem(p: P) -> int {
    expect(p, "pull")
    lowkey mod = curText(p)
    adv(p)
    bet mkNode(p, sp2("pull", mod))
}

finna externDecl(p: P) -> int {
    expect(p, "extern")
    lowkey abi = curText(p)
    adv(p)
    expect(p, "finna")
    lowkey name = ident(p)
    lowkey node = mkNode(p, sp3("extern", abi, name))
    addKid(p, node, paramList(p))
    addKid(p, node, optRetSingle(p))
    bet node
}

finna fnDecl(p: P, vis: str) -> int {
    expect(p, "finna")
    lowkey hasRecv = check(p, "lparen")
    lowkey recvNode = 0
    fr hasRecv {
        recvNode = receiver(p)
    }
    lowkey name = ident(p)
    lowkey gens = genericParams(p)
    lowkey node = mkNode(p, sp3("func", vis, name))
    fr hasRecv {
        addKid(p, node, recvNode)
    }
    addGenerics(p, node, gens)
    addKid(p, node, paramList(p))
    addKid(p, node, optRet(p))
    addKid(p, node, parseBlock(p))
    bet node
}

finna receiver(p: P) -> int {
    expect(p, "lparen")
    lowkey name = ident(p)
    expect(p, "colon")
    lowkey ty = parseType(p)
    expect(p, "rparen")
    lowkey node = mkNode(p, sp2("receiver", name))
    addKid(p, node, ty)
    bet node
}

// `[ "[" ident { "," ident } "]" ]` — a generic parameter list, joined into a single string.
finna genericParams(p: P) -> str {
    lowkey out = ""
    fr eat(p, "lbracket") {
        out = ident(p)
        vibin eat(p, "comma") {
            out = sp2(out, ident(p))
        }
        expect(p, "rbracket")
    }
    bet out
}

// The `generics` line (bare when empty, else `generics T U`).
finna addGenerics(p: P, parent: int, gens: str) {
    fr isEmpty(gens) {
        addKid(p, parent, mkNode(p, "generics"))
    } naw {
        addKid(p, parent, mkNode(p, sp2("generics", gens)))
    }
}

finna paramList(p: P) -> int {
    expect(p, "lparen")
    lowkey node = mkNode(p, "params")
    fr !check(p, "rparen") {
        addKid(p, node, param(p))
        vibin eat(p, "comma") {
            addKid(p, node, param(p))
        }
    }
    expect(p, "rparen")
    bet node
}

finna param(p: P) -> int {
    lowkey name = ident(p)
    expect(p, "colon")
    lowkey ty = parseType(p)
    lowkey node = mkNode(p, sp2("param", name))
    addKid(p, node, ty)
    bet node
}

finna optRet(p: P) -> int {
    fr !eat(p, "arrow") {
        bet mkNode(p, "ret none")
    }
    fr eat(p, "lparen") {
        lowkey node = mkNode(p, "ret multi")
        addKid(p, node, parseType(p))
        vibin eat(p, "comma") {
            addKid(p, node, parseType(p))
        }
        expect(p, "rparen")
        bet node
    }
    lowkey node = mkNode(p, "ret single")
    addKid(p, node, parseType(p))
    bet node
}

finna optRetSingle(p: P) -> int {
    fr eat(p, "arrow") {
        lowkey node = mkNode(p, "ret single")
        addKid(p, node, parseType(p))
        bet node
    }
    bet mkNode(p, "ret none")
}

finna dripDecl(p: P, vis: str) -> int {
    expect(p, "drip")
    lowkey name = ident(p)
    lowkey gens = genericParams(p)
    lowkey node = mkNode(p, sp3("drip", vis, name))
    addGenerics(p, node, gens)
    expect(p, "lbrace")
    vibin nocap {
        skipSemis(p)
        fr check(p, "rbrace") || atEof(p) { dip }
        addKid(p, node, fieldDecl(p))
        skipSemis(p)
        eat(p, "comma")
    }
    expect(p, "rbrace")
    bet node
}

finna fieldDecl(p: P) -> int {
    lowkey fvis = "default"
    fr eat(p, "flex") {
        fvis = "flex"
    } naw fr eat(p, "hush") {
        fvis = "hush"
    }
    lowkey name = ident(p)
    expect(p, "colon")
    lowkey ty = parseType(p)
    lowkey node = mkNode(p, sp3("field", fvis, name))
    addKid(p, node, ty)
    bet node
}

finna moodsDecl(p: P, vis: str) -> int {
    expect(p, "moods")
    lowkey name = ident(p)
    lowkey gens = genericParams(p)
    lowkey node = mkNode(p, sp3("moods", vis, name))
    addGenerics(p, node, gens)
    expect(p, "lbrace")
    vibin nocap {
        skipSemis(p)
        fr check(p, "rbrace") || atEof(p) { dip }
        addKid(p, node, variant(p))
        skipSemis(p)
        eat(p, "comma")
    }
    expect(p, "rbrace")
    bet node
}

finna variant(p: P) -> int {
    lowkey name = ident(p)
    lowkey node = mkNode(p, sp2("variant", name))
    fr eat(p, "lparen") {
        addKid(p, node, parseType(p))
        vibin eat(p, "comma") {
            addKid(p, node, parseType(p))
        }
        expect(p, "rparen")
    }
    bet node
}

// Walk the label-tree, printing each node's label at `depth` and recursing kids at depth+1.
finna emitNode(p: P, idx: int, depth: int, sb: StrBuilder) {
    lowkey d = 0
    vibin d < depth {
        sb.add("  ")
        d = d + 1
    }
    sb.add(p.nodes[idx].label)
    sb.add("\n")
    lowkey kids = p.nodes[idx].kids
    lowkey n = kids.gang() as int
    lowkey i = 0
    vibin i < n {
        emitNode(p, kids[i], depth + 1, sb)
        i = i + 1
    }
}

// Parse a token stream and print its AST dump, EXACTLY as dump.rs::ast does.
finna emitAst(toks: vec[Token]) -> str {
    lowkey pos = vec.new[int]()
    pos.stack(0)
    lowkey ns = vec.new[int]()
    ns.stack(0)
    lowkey p = P{ toks: toks, pos: pos, nodes: vec.new[Node](), ns: ns }
    lowkey root = parseProgram(p)
    lowkey sb = sbNew()
    emitNode(p, root, 0, sb)
    bet sb.finish()
}

// Lex + parse a source string and emit its .mir text (or the unsupported sentinel).
finna emitMirFromSrc(src: str) -> str {
    lowkey pos = vec.new[int]()
    pos.stack(0)
    lowkey ns = vec.new[int]()
    ns.stack(0)
    lowkey p = P{ toks: lex(src), pos: pos, nodes: vec.new[Node](), ns: ns }
    lowkey root = parseProgram(p)
    bet emitMir(p, root)
}

// ===========================================================================
// C4 — lowering (mirror of crates/frontend/src/lower.rs), emitting .mir text directly.
//
// betfe emits `.mir` TEXT (not an in-memory midir Module), so C4 (lower) and C5 (the .mir
// printer) merge here: walk the AST label-tree and append text matching midir/src/text.rs and
// lower.rs EXACTLY — same externs (bet_print is eager, ExternId 0), same SSA temp numbering, same
// op sequence. This is grown incrementally; the SUPPORTED SUBSET so far is a print-only `main`
// (spill.it / spill.f of str and int literals: hello, comments, spill-format). Any construct not
// yet handled sets the ctx `unsupported` flag and emitMir returns the `%%UNSUPPORTED%%` sentinel,
// which the `cargo xtask selfhost` C4 gate logs as not-yet-lowered (no silent gaps) rather than
// diffing. As coverage grows, programs move from that list to byte-identical automatically.
// ===========================================================================

facts UNSUPPORTED = "%%UNSUPPORTED%%\n"

// A `spill.f` format segment: literal text, or a `{}` hole consuming the next argument.
drip Seg {
    isHole: bool,
    text: str
}

// The lowering context. All mutable state is shared-handle vecs (structs pass by value): the
// ordered extern decl lines (bet_print pre-added), the current fn's local types (index = local
// id — the SSA temp counter is `localTypes.gang()`), its bb0 statement lines, and a 1-elem
// `ok` cell (0 once an unsupported construct is hit).
// A basic block: statement lines + a 1-element terminator cell ("" until set).
drip Block {
    stmts: vec[str],
    term: vec[str]
}

finna blkNew() -> Block {
    lowkey t = vec.new[str]()
    t.stack("")
    bet Block{ stmts: vec.new[str](), term: t }
}

drip LowerCtx {
    externs: vec[str],
    fns: vec[str],
    fnNames: vec[str],
    fnParamCsv: vec[str],
    fnRet: vec[str],
    localTypes: vec[str],
    paramCount: vec[int],
    curRet: vec[str],
    blocks: vec[Block],
    curBlock: vec[int],
    ok: vec[int],
    bindNames: vec[str],
    bindIds: vec[int],
    constNames: vec[str],
    constVals: vec[str],
    constTys: vec[str],
    gConstNames: vec[str],
    gConstVals: vec[str],
    gConstTys: vec[str],
    structNames: vec[str],
    structDecls: vec[str],
    fieldStruct: vec[str],
    fieldNames: vec[str],
    fieldTypes: vec[str],
    fieldIdx: vec[int],
    sumNames: vec[str],
    sumDecls: vec[str],
    variantSum: vec[str],
    variantNames: vec[str],
    variantIdx: vec[int],
    variantPayload: vec[str],
    externFnNames: vec[str],
    externFnParamCsv: vec[str],
    externFnRet: vec[str],
    externFnDecl: vec[str],
    cribGlobalNames: vec[str],
    cribGlobalElems: vec[str],
    cribGlobalCaps: vec[str],
    loopIncr: vec[int],
    loopExit: vec[int],
    // --- generics / monomorphization ---
    // Active type-parameter substitution (T -> concrete .mir type) while lowering an instance.
    substNames: vec[str],
    substTypes: vec[str],
    // Generic fn/struct definitions kept by name (-> their AST node index) for on-demand instances.
    genFnNames: vec[str],
    genFnIdx: vec[int],
    genStructNames: vec[str],
    genStructIdx: vec[int],
    // Reserved-but-not-yet-lowered fn instances (drained after the concrete funcs): the base
    // generic name, the mangled instance name, and a "," CSV of concrete arg .mir types.
    moQName: vec[str],
    moQMangled: vec[str],
    moQArgs: vec[str]
}

finna lcNew() -> LowerCtx {
    lowkey ex = vec.new[str]()
    ex.stack("extern \"C\" fn bet_print(rawptr, u64) -> void")
    lowkey okc = vec.new[int]()
    okc.stack(1)
    lowkey pc = vec.new[int]()
    pc.stack(0)
    lowkey cr = vec.new[str]()
    cr.stack("void")
    lowkey blks = vec.new[Block]()
    blks.stack(blkNew())
    lowkey cur = vec.new[int]()
    cur.stack(0)
    bet LowerCtx{ externs: ex, fns: vec.new[str](), fnNames: vec.new[str](), fnParamCsv: vec.new[str](), fnRet: vec.new[str](), localTypes: vec.new[str](), paramCount: pc, curRet: cr, blocks: blks, curBlock: cur, ok: okc, bindNames: vec.new[str](), bindIds: vec.new[int](), constNames: vec.new[str](), constVals: vec.new[str](), constTys: vec.new[str](), gConstNames: vec.new[str](), gConstVals: vec.new[str](), gConstTys: vec.new[str](), structNames: vec.new[str](), structDecls: vec.new[str](), fieldStruct: vec.new[str](), fieldNames: vec.new[str](), fieldTypes: vec.new[str](), fieldIdx: vec.new[int](), sumNames: vec.new[str](), sumDecls: vec.new[str](), variantSum: vec.new[str](), variantNames: vec.new[str](), variantIdx: vec.new[int](), variantPayload: vec.new[str](), externFnNames: vec.new[str](), externFnParamCsv: vec.new[str](), externFnRet: vec.new[str](), externFnDecl: vec.new[str](), cribGlobalNames: vec.new[str](), cribGlobalElems: vec.new[str](), cribGlobalCaps: vec.new[str](), loopIncr: vec.new[int](), loopExit: vec.new[int](), substNames: vec.new[str](), substTypes: vec.new[str](), genFnNames: vec.new[str](), genFnIdx: vec.new[int](), genStructNames: vec.new[str](), genStructIdx: vec.new[int](), moQName: vec.new[str](), moQMangled: vec.new[str](), moQArgs: vec.new[str]() }
}

// --- per-function reset (structs pass by value, so drain the shared-handle vecs in place) ---
finna drainStr(v: vec[str]) {
    vibin (v.gang() as int) > 0 { v.pop() }
}

finna drainInt(v: vec[int]) {
    vibin (v.gang() as int) > 0 { v.pop() }
}

finna drainBlk(v: vec[Block]) {
    vibin (v.gang() as int) > 0 { v.pop() }
}

finna set1(cell: vec[int], v: int) {
    cell.pop()
    cell.stack(v)
}

finna set1s(cell: vec[str], v: str) {
    cell.pop()
    cell.stack(v)
}

// Reset current-function state for a fresh function; bb0 re-created, cursor at 0.
finna resetFn(c: LowerCtx, paramCount: int, ret: str) {
    drainStr(c.localTypes)
    drainBlk(c.blocks)
    c.blocks.stack(blkNew())
    set1(c.curBlock, 0)
    set1(c.paramCount, paramCount)
    set1s(c.curRet, ret)
    drainStr(c.bindNames)
    drainInt(c.bindIds)
    drainStr(c.constNames)
    drainStr(c.constVals)
    drainStr(c.constTys)
    drainInt(c.loopIncr)
    drainInt(c.loopExit)
}

// --- loop stack (dip=break -> exit, skip=continue -> incr/header) ---
finna pushLoop(c: LowerCtx, incr: int, exit: int) {
    c.loopIncr.stack(incr)
    c.loopExit.stack(exit)
}

finna popLoop(c: LowerCtx) {
    c.loopIncr.pop()
    c.loopExit.pop()
}

finna inLoop(c: LowerCtx) -> bool {
    bet (c.loopExit.gang() as int) > 0
}

finna loopIncrTop(c: LowerCtx) -> int {
    bet c.loopIncr[(c.loopIncr.gang() as int) - 1]
}

finna loopExitTop(c: LowerCtx) -> int {
    bet c.loopExit[(c.loopExit.gang() as int) - 1]
}

// The index of a registered function named `name`, or -1.
finna lookupFn(c: LowerCtx, name: str) -> int {
    lowkey n = c.fnNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.fnNames[i], name) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

// The i-th comma-separated field of `csv` ("" if out of range).
finna csvAt(csv: str, idx: int) -> str {
    lowkey n = str.len(csv)
    lowkey field = 0
    lowkey start = 0
    lowkey i = 0
    vibin i < n {
        fr str.at(csv, i) == 44 {
            fr field == idx { bet str.sub(csv, start, i) }
            field = field + 1
            start = i + 1
        }
        i = i + 1
    }
    fr field == idx { bet str.sub(csv, start, n) }
    bet ""
}

// Join a vec of strings with ", ".
finna joinComma(v: vec[str]) -> str {
    lowkey sb = sbNew()
    lowkey n = v.gang() as int
    lowkey i = 0
    vibin i < n {
        fr i > 0 { sb.add(", ") }
        sb.add(v[i])
        i = i + 1
    }
    bet sb.finish()
}

// --- basic-block / terminator management (mirror lower.rs new_block/reserve_block/select/term_*) ---
finna curId(c: LowerCtx) -> int {
    bet c.curBlock[0]
}

finna setCur(c: LowerCtx, id: int) {
    c.curBlock.pop()
    c.curBlock.stack(id)
}

// Create a block and select it (emission continues there).
finna newBlock(c: LowerCtx) -> int {
    lowkey id = c.blocks.gang() as int
    c.blocks.stack(blkNew())
    setCur(c, id)
    bet id
}

// Create a block WITHOUT selecting it (its id is allocated now; it is filled later).
finna reserveBlock(c: LowerCtx) -> int {
    lowkey id = c.blocks.gang() as int
    c.blocks.stack(blkNew())
    bet id
}

finna selectBlock(c: LowerCtx, id: int) {
    setCur(c, id)
}

finna blkTerm(c: LowerCtx, id: int) -> str {
    bet c.blocks[id].term[0]
}

finna setTerm(c: LowerCtx, id: int, t: str) {
    lowkey tv = c.blocks[id].term
    tv.pop()
    tv.stack(t)
}

// `done` = the current block already has a terminator (mirror ctx.done).
finna lcDone(c: LowerCtx) -> bool {
    bet !isEmpty(blkTerm(c, curId(c)))
}

// Terminate the current block with `goto to`, unless already terminated (mirror term_goto).
finna termGoto(c: LowerCtx, to: int) {
    fr !lcDone(c) {
        setTerm(c, curId(c), cat2("goto bb", itoa(to)))
    }
}

finna termRet(c: LowerCtx) {
    fr !lcDone(c) {
        setTerm(c, curId(c), "return")
    }
}

finna termRetVal(c: LowerCtx, op: str) {
    fr !lcDone(c) {
        setTerm(c, curId(c), cat2("return ", op))
    }
}

// `return op0, op1, ..` — a multi-value return (tuple).
finna termRetMulti(c: LowerCtx, ops: vec[str]) {
    fr !lcDone(c) {
        setTerm(c, curId(c), cat2("return ", joinComma(ops)))
    }
}

finna termUnreachable(c: LowerCtx) {
    fr !lcDone(c) {
        setTerm(c, curId(c), "unreachable")
    }
}

// Unconditionally set a block's terminator (mirror set_goto / set_branch — the block is known
// to need this edge and has no terminator yet).
finna setGoto(c: LowerCtx, from: int, to: int) {
    setTerm(c, from, cat2("goto bb", itoa(to)))
}

finna setBranch(c: LowerCtx, from: int, cond: str, thenBb: int, elseBb: int) {
    lowkey sb = sbNew()
    sb.add("branch ")
    sb.add(cond)
    sb.add(" -> bb")
    sb.add(itoa(thenBb))
    sb.add(" else bb")
    sb.add(itoa(elseBb))
    setTerm(c, from, sb.finish())
}

// `switch disc [v0 -> bbA, v1 -> bbB, ..] else bbDefault` — a sum-match dispatch.
finna setSwitch(c: LowerCtx, from: int, disc: str, caseVals: vec[int], caseBbs: vec[int], defaultBb: int) {
    lowkey sb = sbNew()
    sb.add("switch ")
    sb.add(disc)
    sb.add(" [")
    lowkey n = caseVals.gang() as int
    lowkey i = 0
    vibin i < n {
        fr i > 0 { sb.add(", ") }
        sb.add(itoa(caseVals[i]))
        sb.add(" -> bb")
        sb.add(itoa(caseBbs[i]))
        i = i + 1
    }
    sb.add("] else bb")
    sb.add(itoa(defaultBb))
    setTerm(c, from, sb.finish())
}

// --- current-function name/const bindings ---
finna bindLocal(c: LowerCtx, name: str, id: int) {
    c.bindNames.stack(name)
    c.bindIds.stack(id)
}

// The local id bound to `name` (latest binding wins), or -1.
finna lookupLocal(c: LowerCtx, name: str) -> int {
    lowkey i = (c.bindNames.gang() as int) - 1
    vibin i >= 0 {
        fr str.slaps(c.bindNames[i], name) {
            bet c.bindIds[i]
        }
        i = i - 1
    }
    bet 0 - 1
}

finna addConst(c: LowerCtx, name: str, val: str, ty: str) {
    c.constNames.stack(name)
    c.constVals.stack(val)
    c.constTys.stack(ty)
}

// Index of the (function-local) const named `name`, or -1.
finna lookupConst(c: LowerCtx, name: str) -> int {
    lowkey i = (c.constNames.gang() as int) - 1
    vibin i >= 0 {
        fr str.slaps(c.constNames[i], name) {
            bet i
        }
        i = i - 1
    }
    bet 0 - 1
}

// Top-level consts live in a separate scope that survives per-function resets.
finna addGlobalConst(c: LowerCtx, name: str, val: str, ty: str) {
    c.gConstNames.stack(name)
    c.gConstVals.stack(val)
    c.gConstTys.stack(ty)
}

finna lookupGlobalConst(c: LowerCtx, name: str) -> int {
    lowkey i = (c.gConstNames.gang() as int) - 1
    vibin i >= 0 {
        fr str.slaps(c.gConstNames[i], name) {
            bet i
        }
        i = i - 1
    }
    bet 0 - 1
}

// --- struct registry (global; struct types are values spelled by their name) ---
finna isStruct(c: LowerCtx, name: str) -> bool {
    lowkey n = c.structNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.structNames[i], name) { bet nocap }
        i = i + 1
    }
    bet cap
}

finna addField(c: LowerCtx, sname: str, fname: str, fty: str, pos: int) {
    c.fieldStruct.stack(sname)
    c.fieldNames.stack(fname)
    c.fieldTypes.stack(fty)
    c.fieldIdx.stack(pos)
}

// The declaration position of field `fname` in struct `sname`, or -1.
finna structFieldIndex(c: LowerCtx, sname: str, fname: str) -> int {
    lowkey n = c.fieldNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.fieldStruct[i], sname) && str.slaps(c.fieldNames[i], fname) {
            bet c.fieldIdx[i]
        }
        i = i + 1
    }
    bet 0 - 1
}

finna structFieldType(c: LowerCtx, sname: str, fname: str) -> str {
    lowkey n = c.fieldNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.fieldStruct[i], sname) && str.slaps(c.fieldNames[i], fname) {
            bet c.fieldTypes[i]
        }
        i = i + 1
    }
    bet ""
}

// --- sum (moods) registry: sum types are values spelled by their name; variants resolve globally ---
finna isSum(c: LowerCtx, name: str) -> bool {
    lowkey n = c.sumNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.sumNames[i], name) { bet nocap }
        i = i + 1
    }
    bet cap
}

finna addVariant(c: LowerCtx, sum: str, vname: str, idx: int, payload: str) {
    c.variantSum.stack(sum)
    c.variantNames.stack(vname)
    c.variantIdx.stack(idx)
    c.variantPayload.stack(payload)
}

// Flat index of the variant named `vname` (unique across the corpus), or -1.
finna lookupVariant(c: LowerCtx, vname: str) -> int {
    lowkey n = c.variantNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.variantNames[i], vname) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

// Count of components in a "," CSV ("" -> 0).
finna csvLen(csv: str) -> int {
    fr isEmpty(csv) { bet 0 }
    lowkey n = str.len(csv)
    lowkey count = 1
    lowkey i = 0
    vibin i < n {
        fr str.at(csv, i) == 44 { count = count + 1 }
        i = i + 1
    }
    bet count
}

// Emit `%t = make SUM::Variant(ops)` and return (reg, sum type).
finna emitMakeVariant(c: LowerCtx, sumName: str, variantName: str, ops: vec[str]) -> (str, str) {
    lowkey tmp = newLocal(c, sumName)
    lowkey sb = sbNew()
    sb.add("make ")
    sb.add(sumName)
    sb.add("::")
    sb.add(variantName)
    sb.add("(")
    sb.add(joinComma(ops))
    sb.add(")")
    emitAssign(c, tmp, sb.finish())
    bet reg(tmp), sumName
}

// --- yikes: the built-in error type, a synthesized struct `__yikes { present: bool, msg: str }` ---
finna isYikesTy(ty: str) -> bool {
    bet str.slaps(ty, "__yikes")
}

// Lazily register the `__yikes` struct on first use (mirror the frontend's lazy yikes_struct).
finna ensureYikes(c: LowerCtx) {
    fr !isStruct(c, "__yikes") {
        c.structNames.stack("__yikes")
        c.structDecls.stack("struct __yikes { hush present: bool, hush msg: str }")
        addField(c, "__yikes", "present", "bool", 0)
        addField(c, "__yikes", "msg", "str", 1)
    }
}

// Emit `%t = make __yikes(present, msg)` and return (reg, "__yikes").
finna emitMakeYikes(c: LowerCtx, present: str, msg: str) -> (str, str) {
    ensureYikes(c)
    lowkey tmp = newLocal(c, "__yikes")
    lowkey sb = sbNew()
    sb.add("make __yikes(")
    sb.add(present)
    sb.add(", ")
    sb.add(msg)
    sb.add(")")
    emitAssign(c, tmp, sb.finish())
    bet reg(tmp), "__yikes"
}

// --- scalar type helpers ---
finna isSignedIntTy(t: str) -> bool {
    bet str.slaps(t, "i8") || str.slaps(t, "i16") || str.slaps(t, "i32") || str.slaps(t, "i64")
}

finna isUnsignedIntTy(t: str) -> bool {
    bet str.slaps(t, "u8") || str.slaps(t, "u16") || str.slaps(t, "u32") || str.slaps(t, "u64")
}

finna isIntTy(t: str) -> bool {
    bet isSignedIntTy(t) || isUnsignedIntTy(t)
}

finna isFloatTy(t: str) -> bool {
    bet str.slaps(t, "f32") || str.slaps(t, "f64")
}

finna intBits(t: str) -> int {
    fr str.slaps(t, "i8") || str.slaps(t, "u8") { bet 8 }
    fr str.slaps(t, "i16") || str.slaps(t, "u16") { bet 16 }
    fr str.slaps(t, "i32") || str.slaps(t, "u32") { bet 32 }
    bet 64
}

finna intHintOrDefault(hint: str) -> str {
    fr isIntTy(hint) { bet hint }
    bet "i64"
}

finna floatHintOrDefault(hint: str) -> str {
    fr isFloatTy(hint) { bet hint }
    bet "f64"
}

finna isComparisonTag(op: str) -> bool {
    bet str.slaps(op, "eq") || str.slaps(op, "ne") || str.slaps(op, "lt") || str.slaps(op, "le") || str.slaps(op, "gt") || str.slaps(op, "ge")
}

finna isArithTag(op: str) -> bool {
    bet str.slaps(op, "add") || str.slaps(op, "sub") || str.slaps(op, "mul") || str.slaps(op, "div") || str.slaps(op, "rem")
}

// The arithmetic mode suffix for `op` on operands of type `ty` (mirror lower.rs arith_mode).
finna arithMode(ty: str, op: str) -> str {
    fr !isArithTag(op) { bet "na" }
    fr isSignedIntTy(ty) { bet "trap" }
    fr isUnsignedIntTy(ty) { bet "wrap" }
    bet "na"
}

// The cast kind for src -> dst (mirror lower.rs cast_kind).
finna castKind(src: str, dst: str) -> str {
    fr isIntTy(src) && isIntTy(dst) {
        lowkey sw = intBits(src)
        lowkey dw = intBits(dst)
        fr dw > sw {
            fr isSignedIntTy(src) { bet "sext" }
            bet "zext"
        }
        fr dw < sw { bet "trunc" }
        bet "bitcast"
    }
    fr isIntTy(src) && isFloatTy(dst) { bet "itof" }
    fr isFloatTy(src) && isIntTy(dst) { bet "ftoi" }
    fr isFloatTy(src) && isFloatTy(dst) { bet "fresize" }
    bet "bitcast"
}

// The compound-assign IR op (addeq -> add, ...).
finna compoundBinop(op: str) -> str {
    fr str.slaps(op, "addeq") { bet "add" }
    fr str.slaps(op, "subeq") { bet "sub" }
    fr str.slaps(op, "muleq") { bet "mul" }
    fr str.slaps(op, "diveq") { bet "div" }
    fr str.slaps(op, "remeq") { bet "rem" }
    fr str.slaps(op, "andeq") { bet "bitand" }
    fr str.slaps(op, "oreq") { bet "bitor" }
    fr str.slaps(op, "xoreq") { bet "bitxor" }
    fr str.slaps(op, "shleq") { bet "shl" }
    bet "shr"
}

finna hasSpace(s: str) -> bool {
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n {
        fr str.at(s, i) == 32 { bet nocap }
        i = i + 1
    }
    bet cap
}

// Map a named-scalar type to its .mir spelling ("" if not a scalar C4.2 handles).
finna mapScalar(nm: str) -> str {
    fr str.slaps(nm, "int") { bet "i64" }
    fr str.slaps(nm, "uint") { bet "u64" }
    fr str.slaps(nm, "float") { bet "f64" }
    fr isIntTy(nm) || isFloatTy(nm) { bet nm }
    fr str.slaps(nm, "bool") || str.slaps(nm, "str") || str.slaps(nm, "rawptr") { bet nm }
    fr str.slaps(nm, "void") || str.slaps(nm, "nada") { bet "void" }
    bet ""
}

// --- fixed-array value model: types spelled `[ELEM; N]` (slices are `[]ELEM`) ---
finna arrayTyStr(elem: str, n: int) -> str {
    lowkey sb = sbNew()
    sb.add("[")
    sb.add(elem)
    sb.add("; ")
    sb.add(itoa(n))
    sb.add("]")
    bet sb.finish()
}

// True for `[ELEM; N]` (an array), false for `[]ELEM` (a slice) or non-bracket types.
finna isArrayTy(t: str) -> bool {
    fr str.len(t) < 2 { bet cap }
    fr str.at(t, 0) != 91 { bet cap }
    bet str.at(t, 1) != 93
}

// Element type of `[ELEM; N]`: the text between `[` and `;`.
finna arrayElem(t: str) -> str {
    lowkey n = str.len(t)
    lowkey i = 1
    vibin i < n {
        fr str.at(t, i) == 59 { bet str.sub(t, 1, i) }
        i = i + 1
    }
    bet ""
}

// Length text of `[ELEM; N]`: the digits after `; ` up to `]`.
finna arrayLenStr(t: str) -> str {
    lowkey n = str.len(t)
    lowkey semi = 0
    lowkey i = 1
    vibin i < n {
        fr str.at(t, i) == 59 { semi = i }
        i = i + 1
    }
    lowkey start = semi + 2
    lowkey j = start
    vibin j < n {
        fr str.at(t, j) == 93 { bet str.sub(t, start, j) }
        j = j + 1
    }
    bet ""
}

// --- slices, spelled `[]ELEM` (a fat {ptr,len} view; indexed like an array) ---
finna isSliceTy(t: str) -> bool {
    fr str.len(t) < 2 { bet cap }
    bet str.at(t, 0) == 91 && str.at(t, 1) == 93
}

finna sliceElem(t: str) -> str {
    bet str.sub(t, 2, str.len(t))
}

finna sliceTyStr(elem: str) -> str {
    bet cat2("[]", elem)
}

// Element hint from an array/slice type hint, else "".
finna arrayElemHint(hint: str) -> str {
    fr isArrayTy(hint) { bet arrayElem(hint) }
    fr isSliceTy(hint) { bet sliceElem(hint) }
    bet ""
}

// --- runtime-backed vec[T]: a handle, spelled `vec[ELEM]` ---
finna isVecTy(t: str) -> bool {
    fr str.len(t) < 5 { bet cap }
    bet str.at(t, 0) == 118 && str.at(t, 1) == 101 && str.at(t, 2) == 99 && str.at(t, 3) == 91
}

finna vecElem(t: str) -> str {
    bet str.sub(t, 4, str.len(t) - 1)
}

finna vecTyStr(elem: str) -> str {
    bet cat3("vec[", elem, "]")
}

// --- stash (hash map) types, spelled `map[K, V]` in MIR (mirror the vec type helpers) ---
finna isMapTy(t: str) -> bool {
    fr str.len(t) < 5 { bet cap }
    bet str.at(t, 0) == 109 && str.at(t, 1) == 97 && str.at(t, 2) == 112 && str.at(t, 3) == 91
}

finna mapTyStr(k: str, v: str) -> str {
    lowkey sb = sbNew()
    sb.add("map[")
    sb.add(k)
    sb.add(", ")
    sb.add(v)
    sb.add("]")
    bet sb.finish()
}

// The key component of a `map[K, V]` type — content up to the top-level comma (depth-aware).
finna mapKey(t: str) -> str {
    lowkey n = str.len(t)
    lowkey depth = 0
    lowkey i = 4
    vibin i < n - 1 {
        lowkey ch = str.at(t, i)
        fr ch == 91 || ch == 40 {
            depth = depth + 1
        } naw fr ch == 93 || ch == 41 {
            depth = depth - 1
        } naw fr ch == 44 && depth == 0 {
            bet trimSpace(str.sub(t, 4, i))
        }
        i = i + 1
    }
    bet ""
}

// The value component of a `map[K, V]` type — content after the top-level comma (depth-aware).
finna mapVal(t: str) -> str {
    lowkey n = str.len(t)
    lowkey depth = 0
    lowkey i = 4
    vibin i < n - 1 {
        lowkey ch = str.at(t, i)
        fr ch == 91 || ch == 40 {
            depth = depth + 1
        } naw fr ch == 93 || ch == 41 {
            depth = depth - 1
        } naw fr ch == 44 && depth == 0 {
            bet trimSpace(str.sub(t, i + 1, n - 1))
        }
        i = i + 1
    }
    bet ""
}
// --- memory-model handle types: `crib ELEM` (arena), `tag ELEM` (slot handle),
// `ref ELEM` (a live borrow). Spelled `<kw> ELEM`, matching text.rs `crib/tag/ref {}`. ---
finna cribTyStr(elem: str) -> str { bet cat2("crib ", elem) }

finna isCribTy(t: str) -> bool { bet str.slaps(firstWord(t), "crib") }

finna cribElem(t: str) -> str { bet afterFirst(t) }

finna tagTyStr(elem: str) -> str { bet cat2("tag ", elem) }

finna isTagTy(t: str) -> bool { bet str.slaps(firstWord(t), "tag") }

finna tagElem(t: str) -> str { bet afterFirst(t) }

finna refTyStr(elem: str) -> str { bet cat2("ref ", elem) }

finna isRefTy(t: str) -> bool { bet str.slaps(firstWord(t), "ref") }

finna refElem(t: str) -> str { bet afterFirst(t) }

// --- tuple types, spelled `(A, B, ..)` (multi-return values) ---
finna isTupleTy(t: str) -> bool {
    fr str.len(t) < 2 { bet cap }
    bet str.at(t, 0) == 40
}

finna trimSpace(s: str) -> str {
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n && str.at(s, i) == 32 { i = i + 1 }
    bet str.sub(s, i, n)
}

// The `idx`-th component type of a tuple `(A, B, ..)` — split at top-level commas.
finna tupleComponentAt(t: str, idx: int) -> str {
    lowkey n = str.len(t)
    lowkey start = 1
    lowkey depth = 0
    lowkey cur = 0
    lowkey i = 1
    vibin i < n - 1 {
        lowkey ch = str.at(t, i)
        fr ch == 40 {
            depth = depth + 1
        } naw fr ch == 41 {
            depth = depth - 1
        } naw fr ch == 44 && depth == 0 {
            fr cur == idx { bet trimSpace(str.sub(t, start, i)) }
            cur = cur + 1
            start = i + 1
        }
        i = i + 1
    }
    fr cur == idx { bet trimSpace(str.sub(t, start, n - 1)) }
    bet ""
}

// Number of components in a tuple type `(A, B, ..)`.
finna tupleArity(t: str) -> int {
    lowkey i = 0
    vibin !isEmpty(tupleComponentAt(t, i)) { i = i + 1 }
    bet i
}

// The zero value operand for a scalar/str return slot (mirror zero_operand).
finna zeroOperand(c: LowerCtx, ty: str) -> str {
    fr isIntTy(ty) { bet cat2("0", ty) }
    fr str.slaps(ty, "bool") { bet "false" }
    fr str.slaps(ty, "str") { bet "\"\"" }
    lcFail(c)
    bet "0i64"
}

// Split a space-separated target list ("q r") into names.
finna splitSpaces(s: str) -> vec[str] {
    lowkey out = vec.new[str]()
    lowkey n = str.len(s)
    lowkey start = 0
    lowkey i = 0
    vibin i < n {
        fr str.at(s, i) == 32 {
            fr i > start { out.stack(str.sub(s, start, i)) }
            start = i + 1
        }
        i = i + 1
    }
    fr n > start { out.stack(str.sub(s, start, n)) }
    bet out
}

// True for a bare SSA register `%N` with no projection (an addressable place base).
finna isReg(s: str) -> bool {
    fr str.len(s) == 0 { bet cap }
    fr str.at(s, 0) != 37 { bet cap }
    lowkey n = str.len(s)
    lowkey i = 1
    vibin i < n {
        fr str.at(s, i) == 46 { bet cap }
        i = i + 1
    }
    bet nocap
}

// True for any place-rooted operand `%..` (a register, possibly with projections).
finna isPlace(s: str) -> bool {
    fr str.len(s) == 0 { bet cap }
    bet str.at(s, 0) == 37
}

// --- function-pointer types, spelled `fn(P, ..) -> R` (a callable value) ---
finna isFnPtrTy(t: str) -> bool {
    fr str.len(t) < 3 { bet cap }
    bet str.at(t, 0) == 102 && str.at(t, 1) == 110 && str.at(t, 2) == 40
}

// Index of the ") -> " that separates a `fn(..) -> R` type's params from its return, or -1.
finna fnPtrArrowAt(t: str) -> int {
    lowkey n = str.len(t)
    lowkey i = 0
    vibin i + 5 <= n {
        fr str.at(t, i) == 41 && str.at(t, i + 1) == 32 && str.at(t, i + 2) == 45 && str.at(t, i + 3) == 62 && str.at(t, i + 4) == 32 {
            bet i
        }
        i = i + 1
    }
    bet 0 - 1
}

// Params portion of `fn(P, ..) -> R` — the text between `fn(` and `) -> ` (a ", "-joined list).
finna fnPtrParams(t: str) -> str {
    lowkey a = fnPtrArrowAt(t)
    fr a < 3 { bet "" }
    bet str.sub(t, 3, a)
}

// Return portion of `fn(P, ..) -> R` — the text after `) -> `.
finna fnPtrRet(t: str) -> str {
    lowkey a = fnPtrArrowAt(t)
    fr a < 0 { bet "" }
    bet str.sub(t, a + 5, str.len(t))
}

// The `fn(P, ..) -> R` type of a registered function (mirror the FnPtr TyKind of a bare fn name).
finna fnPtrTypeOf(c: LowerCtx, fi: int) -> str {
    lowkey csv = c.fnParamCsv[fi]
    lowkey sb = sbNew()
    sb.add("fn(")
    lowkey i = 0
    vibin !isEmpty(csvAt(csv, i)) {
        fr i > 0 { sb.add(", ") }
        sb.add(csvAt(csv, i))
        i = i + 1
    }
    sb.add(") -> ")
    sb.add(c.fnRet[fi])
    bet sb.finish()
}

// The .mir type string for a type node (scalar named types only in C4.2).
// ===========================================================================
// Generics / monomorphization (mirror lower.rs: mono_struct / mono_fn / lower_mono_fn / mangle).
// Generic defs are collected by name; each distinct concrete instantiation is emitted once with a
// name-mangled symbol (`pickFirst$i64`, `Pair$str`). A work-list drains fn instances after the
// concrete funcs, so an instance that calls further generics spawns more instances.
// ===========================================================================

// --- active type-parameter substitution (T -> concrete .mir type) ---
finna clearSubst(c: LowerCtx) {
    vibin (c.substNames.gang() as int) > 0 {
        c.substNames.pop()
        c.substTypes.pop()
    }
}

// The concrete .mir type bound to type-parameter `name`, or "" if `name` is not a bound param.
finna substLookup(c: LowerCtx, name: str) -> str {
    lowkey n = c.substNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.substNames[i], name) { bet c.substTypes[i] }
        i = i + 1
    }
    bet ""
}

// Snapshot the active substitution (so a nested instantiation can save/restore the caller's).
finna substSnapshot(c: LowerCtx) -> (vec[str], vec[str]) {
    lowkey sn = vec.new[str]()
    lowkey st = vec.new[str]()
    lowkey n = c.substNames.gang() as int
    lowkey i = 0
    vibin i < n {
        sn.stack(c.substNames[i])
        st.stack(c.substTypes[i])
        i = i + 1
    }
    bet sn, st
}

finna substRestore(c: LowerCtx, sn: vec[str], st: vec[str]) {
    clearSubst(c)
    lowkey n = sn.gang() as int
    lowkey i = 0
    vibin i < n {
        c.substNames.stack(sn[i])
        c.substTypes.stack(st[i])
        i = i + 1
    }
}

// Split a space-separated string into its words (generic param name lists are `T` / `T U`).
finna splitWs(s: str) -> vec[str] {
    lowkey out = vec.new[str]()
    lowkey n = str.len(s)
    lowkey start = 0
    lowkey i = 0
    vibin i < n {
        fr str.at(s, i) == 32 {
            fr i > start { out.stack(str.sub(s, start, i)) }
            start = i + 1
        }
        i = i + 1
    }
    fr n > start { out.stack(str.sub(s, start, n)) }
    bet out
}

// Join a vec of strings with "," (comma only — the CSV format `csvAt` splits on).
finna joinCsv(v: vec[str]) -> str {
    lowkey sb = sbNew()
    lowkey n = v.gang() as int
    lowkey i = 0
    vibin i < n {
        fr i > 0 { sb.add(",") }
        sb.add(v[i])
        i = i + 1
    }
    bet sb.finish()
}

// The space-separated generic-param names of a decl node (`generics T U` -> "T U"), or "".
finna genericParamsStr(p: P, declIdx: int) -> str {
    lowkey g = findKidWord(p, declIdx, "generics")
    fr g < 0 { bet "" }
    bet afterFirst(lab(p, g))
}

// True if a `func`/`drip`/`moods` decl has a non-empty generic parameter list.
finna isGenericDeclG(p: P, declIdx: int) -> bool {
    bet !isEmpty(genericParamsStr(p, declIdx))
}

// Replace the active substitution with {decl's generic params -> the given concrete arg CSV}.
finna setSubstCsv(c: LowerCtx, p: P, declIdx: int, argsCsv: str) {
    clearSubst(c)
    lowkey names = splitWs(genericParamsStr(p, declIdx))
    lowkey n = names.gang() as int
    lowkey i = 0
    vibin i < n {
        c.substNames.stack(names[i])
        c.substTypes.stack(csvAt(argsCsv, i))
        i = i + 1
    }
}

// --- generic-definition registries (populated by the prescan; keyed by base name) ---
finna isGenericFn(c: LowerCtx, name: str) -> bool {
    lowkey n = c.genFnNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.genFnNames[i], name) { bet nocap }
        i = i + 1
    }
    bet cap
}

finna lookupGenericFn(c: LowerCtx, name: str) -> int {
    lowkey n = c.genFnNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.genFnNames[i], name) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

finna isGenericStruct(c: LowerCtx, name: str) -> bool {
    lowkey n = c.genStructNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.genStructNames[i], name) { bet nocap }
        i = i + 1
    }
    bet cap
}

finna lookupGenericStruct(c: LowerCtx, name: str) -> int {
    lowkey n = c.genStructNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.genStructNames[i], name) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

// --- symbol mangling (mirror lower.rs mangle / mangle_ty) ---
// The mangle suffix component for one concrete .mir type. Scalars and (already-mangled) aggregate
// names map to themselves; slice/array match lower.rs; anything else is conservatively sentineled.
finna mangleTy(c: LowerCtx, mir: str) -> str {
    fr isIntTy(mir) || isFloatTy(mir) { bet mir }
    fr str.slaps(mir, "bool") || str.slaps(mir, "str") { bet mir }
    fr str.slaps(mir, "void") || str.slaps(mir, "rawptr") { bet mir }
    fr isStruct(c, mir) || isSum(c, mir) { bet mir }
    fr isSliceTy(mir) { bet cat2("slice_", mangleTy(c, sliceElem(mir))) }
    fr isArrayTy(mir) { bet cat2(cat2("arr", arrayLenStr(mir)), cat2("_", mangleTy(c, arrayElem(mir)))) }
    lcFail(c)
    bet mir
}

// `base$t0$t1..` — the mangled instance symbol for a generic instantiation.
finna mangle(c: LowerCtx, base: str, argTys: vec[str]) -> str {
    lowkey sb = sbNew()
    sb.add(base)
    lowkey n = argTys.gang() as int
    lowkey i = 0
    vibin i < n {
        sb.add("$")
        sb.add(mangleTy(c, argTys[i]))
        i = i + 1
    }
    bet sb.finish()
}

// Map every child of `parent` as a type node -> a vec of concrete .mir type strings. Used for both
// a `typeargs` wrapper (call / struct-lit sites) and a `named STRUCT <args..>` type position.
finna mapTypeArgs(c: LowerCtx, p: P, parent: int) -> vec[str] {
    lowkey out = vec.new[str]()
    lowkey n = kidCount(p, parent)
    lowkey i = 0
    vibin i < n {
        out.stack(mapTypeNode(c, p, kidAt(p, parent, i)))
        i = i + 1
    }
    bet out
}

// Instantiate a generic `drip` at concrete `argTys`, returning the mangled struct name (rendering
// its `struct NAME { .. }` decl and registering its fields on first use). Mirror mono_struct.
finna monoStruct(c: LowerCtx, p: P, genName: str, argTys: vec[str]) -> str {
    lowkey mangled = mangle(c, genName, argTys)
    fr !lcOk(c) { bet mangled }
    fr isStruct(c, mangled) { bet mangled }
    lowkey gi = lookupGenericStruct(c, genName)
    fr gi < 0 {
        lcFail(c)
        bet mangled
    }
    lowkey dripIdx = c.genStructIdx[gi]
    lowkey names = splitWs(genericParamsStr(p, dripIdx))
    fr (names.gang() as int) != (argTys.gang() as int) {
        lcFail(c)
        bet mangled
    }
    lowkey argsCsv = joinCsv(argTys)
    lowkey sn, st = substSnapshot(c)
    setSubstCsv(c, p, dripIdx, argsCsv)
    lowkey sb = sbNew()
    sb.add("struct ")
    sb.add(mangled)
    sb.add(" {")
    lowkey nk = kidCount(p, dripIdx)
    lowkey pos = 0
    lowkey i = 0
    vibin i < nk && lcOk(c) {
        lowkey k = kidAt(p, dripIdx, i)
        fr str.slaps(firstWord(lab(p, k)), "field") {
            lowkey visName = afterFirst(lab(p, k))
            lowkey vis = firstWord(visName)
            fr str.slaps(vis, "default") { vis = "hush" }
            lowkey fname = afterFirst(visName)
            lowkey fty = mapTypeNode(c, p, kidAt(p, k, 0))
            fr pos == 0 { sb.add(" ") } naw { sb.add(", ") }
            sb.add(vis)
            sb.add(" ")
            sb.add(fname)
            sb.add(": ")
            sb.add(fty)
            addField(c, mangled, fname, fty, pos)
            pos = pos + 1
        }
        i = i + 1
    }
    sb.add(" }")
    substRestore(c, sn, st)
    c.structNames.stack(mangled)
    c.structDecls.stack(sb.finish())
    bet mangled
}

// Reserve (and register the signature of) a generic function instance at concrete `argTys`,
// returning its mangled name and enqueuing its body for later lowering. Mirror mono_fn.
finna monoFn(c: LowerCtx, p: P, genName: str, argTys: vec[str]) -> str {
    lowkey mangled = mangle(c, genName, argTys)
    fr !lcOk(c) { bet mangled }
    fr lookupFn(c, mangled) >= 0 { bet mangled }
    lowkey gi = lookupGenericFn(c, genName)
    fr gi < 0 {
        lcFail(c)
        bet mangled
    }
    lowkey funcIdx = c.genFnIdx[gi]
    // Generic methods (a receiver) are not yet lowered.
    fr findKidWord(p, funcIdx, "receiver") >= 0 {
        lcFail(c)
        bet mangled
    }
    lowkey names = splitWs(genericParamsStr(p, funcIdx))
    fr (names.gang() as int) != (argTys.gang() as int) {
        lcFail(c)
        bet mangled
    }
    lowkey argsCsv = joinCsv(argTys)
    lowkey sn, st = substSnapshot(c)
    setSubstCsv(c, p, funcIdx, argsCsv)
    lowkey pw = findKid(p, funcIdx, "params")
    lowkey csv = collectParamTypes(c, p, pw)
    lowkey ret = collectRetType(c, p, funcIdx)
    substRestore(c, sn, st)
    c.fnNames.stack(mangled)
    c.fnParamCsv.stack(csv)
    c.fnRet.stack(ret)
    c.moQName.stack(genName)
    c.moQMangled.stack(mangled)
    c.moQArgs.stack(argsCsv)
    bet mangled
}

// Lower one queued monomorphized function instance from the work-list (mirror lower_mono_fn).
finna lowerMonoFn(c: LowerCtx, p: P, qi: int) {
    lowkey genName = c.moQName[qi]
    lowkey mangled = c.moQMangled[qi]
    lowkey argsCsv = c.moQArgs[qi]
    lowkey gi = lookupGenericFn(c, genName)
    fr gi < 0 {
        lcFail(c)
    } naw {
        lowkey funcIdx = c.genFnIdx[gi]
        lowkey sn, st = substSnapshot(c)
        setSubstCsv(c, p, funcIdx, argsCsv)
        lowerFuncNamed(c, p, funcIdx, mangled)
        substRestore(c, sn, st)
    }
}

finna mapTypeNode(c: LowerCtx, p: P, tyNode: int) -> str {
    fr str.slaps(firstWord(lab(p, tyNode)), "named") {
        lowkey nm = afterFirst(lab(p, tyNode))
        // A type-parameter name in the active substitution resolves to its concrete argument.
        lowkey sub = substLookup(c, nm)
        fr !isEmpty(sub) { bet sub }
        lowkey m = mapScalar(nm)
        fr !isEmpty(m) { bet m }
        fr str.slaps(nm, "yikes") {
            ensureYikes(c)
            bet "__yikes"
        }
        // A `vec[T]` type node is `named vec` with the element type as its child.
        fr str.slaps(nm, "vec") && kidCount(p, tyNode) > 0 {
            bet vecTyStr(mapTypeNode(c, p, kidAt(p, tyNode, 0)))
        }
        // A `stash[K, V]` type node is `named stash` with the key/value types as its children.
        fr str.slaps(nm, "stash") && kidCount(p, tyNode) == 2 {
            bet mapTyStr(mapTypeNode(c, p, kidAt(p, tyNode, 0)), mapTypeNode(c, p, kidAt(p, tyNode, 1)))
        }
        // `Pair[int]` in a type position: `named STRUCT` with the type args as direct children.
        fr kidCount(p, tyNode) > 0 && isGenericStruct(c, nm) {
            bet monoStruct(c, p, nm, mapTypeArgs(c, p, tyNode))
        }
        fr isStruct(c, nm) { bet nm }
        fr isSum(c, nm) { bet nm }
    }
    // A `[]T` slice type node is `slice` with the element type as its child.
    fr str.slaps(firstWord(lab(p, tyNode)), "slice") {
        bet sliceTyStr(mapTypeNode(c, p, kidAt(p, tyNode, 0)))
    }
    // A `finna(P, ..) -> R` function-pointer type node: `fn(P, ..) -> R` (mirror TyKind::FnPtr).
    fr str.slaps(firstWord(lab(p, tyNode)), "fn-ty") {
        lowkey paramsW = kidAt(p, tyNode, 0)
        lowkey retW = kidAt(p, tyNode, 1)
        lowkey sb = sbNew()
        sb.add("fn(")
        lowkey np = kidCount(p, paramsW)
        lowkey i = 0
        vibin i < np {
            fr i > 0 { sb.add(", ") }
            sb.add(mapTypeNode(c, p, kidAt(p, paramsW, i)))
            i = i + 1
        }
        sb.add(") -> ")
        sb.add(mapTypeNode(c, p, kidAt(p, retW, 0)))
        bet sb.finish()
    }
    // A `tag T` handle type node is `tag` with the element type as its child.
    fr str.slaps(firstWord(lab(p, tyNode)), "tag") {
        bet tagTyStr(mapTypeNode(c, p, kidAt(p, tyNode, 0)))
    }
    // A `crib T` arena type node is `crib` with the element type as its child.
    fr str.slaps(firstWord(lab(p, tyNode)), "crib") {
        bet cribTyStr(mapTypeNode(c, p, kidAt(p, tyNode, 0)))
    }
    lcFail(c)
    bet "i64"
}

finna lcOk(c: LowerCtx) -> bool {
    bet c.ok[0] == 1
}

finna lcFail(c: LowerCtx) {
    c.ok.pop()
    c.ok.stack(0)
}

// Dedup-add an extern decl line, preserving first-use order (matches lower.rs get_extern).
finna getExtern(c: LowerCtx, line: str) {
    lowkey found = cap
    lowkey n = c.externs.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.externs[i], line) { found = nocap }
        i = i + 1
    }
    fr !found { c.externs.stack(line) }
}

// Allocate a fresh SSA local of type `ty`; returns its id (mirrors ctx.new_local).
finna newLocal(c: LowerCtx, ty: str) -> int {
    lowkey id = c.localTypes.gang() as int
    c.localTypes.stack(ty)
    bet id
}

finna emitStmt(c: LowerCtx, line: str) {
    c.blocks[curId(c)].stmts.stack(line)
}

// `%N` — a register name.
finna reg(n: int) -> str {
    bet cat2("%", itoa(n))
}

finna cat2(a: str, b: str) -> str {
    lowkey sb = sbNew()
    sb.add(a)
    sb.add(b)
    bet sb.finish()
}

// --- AST label-tree accessors (lowering reads the tree the parser built) ---
finna kidCount(p: P, idx: int) -> int {
    bet p.nodes[idx].kids.gang() as int
}

finna kidAt(p: P, idx: int, n: int) -> int {
    bet p.nodes[idx].kids[n]
}

finna lab(p: P, idx: int) -> str {
    bet p.nodes[idx].label
}

// The first space-delimited word of a label (its node kind).
finna firstWord(s: str) -> str {
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n && str.at(s, i) != 32 {
        i = i + 1
    }
    bet str.sub(s, 0, i)
}

// Everything after the first word (the payload — may contain spaces, e.g. a quoted string).
finna afterFirst(s: str) -> str {
    lowkey n = str.len(s)
    lowkey i = 0
    vibin i < n && str.at(s, i) != 32 {
        i = i + 1
    }
    fr i >= n {
        bet ""
    }
    bet str.sub(s, i + 1, n)
}

// The index of the first child whose label exactly equals `name` (or -1).
finna findKid(p: P, idx: int, name: str) -> int {
    lowkey n = kidCount(p, idx)
    lowkey i = 0
    vibin i < n {
        lowkey k = kidAt(p, idx, i)
        fr str.slaps(lab(p, k), name) {
            bet k
        }
        i = i + 1
    }
    bet -1
}

// Like findKid but matches on the first label word (for labeled-payload nodes like `receiver c`).
finna findKidWord(p: P, idx: int, word: str) -> int {
    lowkey n = kidCount(p, idx)
    lowkey i = 0
    vibin i < n {
        lowkey k = kidAt(p, idx, i)
        fr str.slaps(firstWord(lab(p, k)), word) {
            bet k
        }
        i = i + 1
    }
    bet 0 - 1
}

// Undo the dump `quote`: strip the surrounding quotes and decode \\ \" \n \t \r back to bytes.
// The AST stores string payloads quoted; lowering needs the raw value to concat/re-escape/split.
finna unquote(q: str) -> str {
    lowkey out = vec.new[u8]()
    lowkey n = str.len(q)
    lowkey i = 1
    vibin i < n - 1 {
        lowkey ch = str.at(q, i)
        fr ch == 92 {
            i = i + 1
            lowkey e = str.at(q, i)
            fr e == 110 {
                out.stack(10 as u8)
            } naw fr e == 116 {
                out.stack(9 as u8)
            } naw fr e == 114 {
                out.stack(13 as u8)
            } naw fr e == 92 {
                out.stack(92 as u8)
            } naw fr e == 34 {
                out.stack(34 as u8)
            } naw {
                out.stack(e as u8)
            }
            i = i + 1
        } naw {
            out.stack(ch as u8)
            i = i + 1
        }
    }
    bet out.str()
}

// Split a `spill.f` format string into text/hole segments (mirror lower.rs split_format). Valid
// corpus formats never contain a lone `{`/`}`, so those are passed through as literal bytes.
finna splitFormat(fmt: str) -> vec[Seg] {
    lowkey segs = vec.new[Seg]()
    lowkey buf = vec.new[u8]()
    lowkey n = str.len(fmt)
    lowkey i = 0
    vibin i < n {
        lowkey ch = str.at(fmt, i)
        lowkey nx = 0
        fr i + 1 < n {
            nx = str.at(fmt, i + 1)
        }
        fr ch == 123 && nx == 123 {
            buf.stack(123 as u8)
            i = i + 2
        } naw fr ch == 123 && nx == 125 {
            segs.stack(Seg{ isHole: cap, text: buf.str() })
            buf = vec.new[u8]()
            segs.stack(Seg{ isHole: nocap, text: "" })
            i = i + 2
        } naw fr ch == 125 && nx == 125 {
            buf.stack(125 as u8)
            i = i + 2
        } naw {
            buf.stack(ch as u8)
            i = i + 1
        }
    }
    segs.stack(Seg{ isHole: cap, text: buf.str() })
    bet segs
}

// emit_print_operand: str_ptr / str_len / call_extern @bet_print of a str operand `opStr`.
finna emitPrintOperand(c: LowerCtx, opStr: str) {
    lowkey ptr = newLocal(c, "rawptr")
    lowkey len = newLocal(c, "u64")
    lowkey res = newLocal(c, "void")
    lowkey s1 = sbNew()
    s1.add(reg(ptr))
    s1.add(" = str_ptr(")
    s1.add(opStr)
    s1.add(")")
    emitStmt(c, s1.finish())
    lowkey s2 = sbNew()
    s2.add(reg(len))
    s2.add(" = str_len(")
    s2.add(opStr)
    s2.add(")")
    emitStmt(c, s2.finish())
    lowkey s3 = sbNew()
    s3.add(reg(res))
    s3.add(" = call_extern @bet_print(")
    s3.add(reg(ptr))
    s3.add(", ")
    s3.add(reg(len))
    s3.add(")")
    emitStmt(c, s3.finish())
}

// emit_print of a literal string (raw bytes) — quoted, then printed as an operand.
finna emitPrint(c: LowerCtx, raw: str) {
    emitPrintOperand(c, quote(raw))
}

// `%dst = <line>` — emit an assignment statement.
finna emitAssign(c: LowerCtx, dst: int, rhs: str) {
    lowkey sb = sbNew()
    sb.add(reg(dst))
    sb.add(" = ")
    sb.add(rhs)
    emitStmt(c, sb.finish())
}

// `<place> = <rhs>` — emit an assignment to an arbitrary place string (a field/index projection).
finna emitPlaceAssign(c: LowerCtx, place: str, rhs: str) {
    lowkey sb = sbNew()
    sb.add(place)
    sb.add(" = ")
    sb.add(rhs)
    emitStmt(c, sb.finish())
}

// `%t = addr_of(<target>)` into a fresh rawptr temp; returns its id.
finna emitAddrOf(c: LowerCtx, target: str) -> int {
    lowkey t = newLocal(c, "rawptr")
    lowkey sb = sbNew()
    sb.add("addr_of(")
    sb.add(target)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet t
}

// `%t = call_extern @NAME(a, b, ..)` into a fresh temp of `retTy`; returns its id. Voids too.
finna emitExternCall(c: LowerCtx, retTy: str, name: str, args: vec[str]) -> int {
    lowkey r = newLocal(c, retTy)
    lowkey sb = sbNew()
    sb.add("call_extern @")
    sb.add(name)
    sb.add("(")
    sb.add(joinComma(args))
    sb.add(")")
    emitAssign(c, r, sb.finish())
    bet r
}

// Widen an int operand to the print word type (mirror coerce_int): no-op if already `to`.
finna coerceInt(c: LowerCtx, opStr: str, from: str, to: str) -> str {
    fr str.slaps(from, to) { bet opStr }
    lowkey t = newLocal(c, to)
    lowkey sb = sbNew()
    sb.add("cast.")
    sb.add(castKind(from, to))
    sb.add("(")
    sb.add(opStr)
    sb.add(" as ")
    sb.add(to)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet reg(t)
}

// Lower an expression to (operand, type) strings (mirror lower_expr). Emits temps as needed.
finna lowerExpr(c: LowerCtx, p: P, idx: int, hint: str) -> (str, str) {
    lowkey h = firstWord(lab(p, idx))
    lowkey payload = afterFirst(lab(p, idx))
    fr str.slaps(h, "int") {
        lowkey ty = intHintOrDefault(hint)
        bet cat2(payload, ty), ty
    }
    fr str.slaps(h, "float") {
        lowkey ty = floatHintOrDefault(hint)
        bet cat2(payload, ty), ty
    }
    fr str.slaps(h, "bool") {
        bet payload, "bool"
    }
    fr str.slaps(h, "str") {
        bet payload, "str"
    }
    fr str.slaps(h, "byte") {
        bet cat2(payload, "u8"), "u8"
    }
    fr str.slaps(h, "name") {
        lowkey no, nt = lowerName(c, p, idx)
        bet no, nt
    }
    fr str.slaps(h, "unary") {
        lowkey uo, ut = lowerUnary(c, p, idx, hint)
        bet uo, ut
    }
    fr str.slaps(h, "binary") {
        lowkey bo, bt = lowerBinary(c, p, idx, hint)
        bet bo, bt
    }
    fr str.slaps(h, "cast") {
        lowkey co, ct = lowerCast(c, p, idx)
        bet co, ct
    }
    fr str.slaps(h, "array-lit") {
        lowkey ao, at = lowerArrayLit(c, p, idx, hint)
        bet ao, at
    }
    fr str.slaps(h, "index") {
        lowkey xo, xt = lowerIndex(c, p, idx)
        bet xo, xt
    }
    fr str.slaps(h, "struct") {
        lowkey so, st = lowerStructLit(c, p, idx)
        bet so, st
    }
    fr str.slaps(h, "field") {
        lowkey fo, ft = fieldAccessStr(c, p, idx)
        bet fo, ft
    }
    fr str.slaps(h, "call") {
        lowkey lo, lt = lowerCall(c, p, idx)
        bet lo, lt
    }
    fr str.slaps(h, "method") {
        lowkey mo, mt = lowerMethodCall(c, p, idx)
        bet mo, mt
    }
    fr str.slaps(h, "cop") {
        lowkey po, pt = lowerCop(c, p, idx)
        bet po, pt
    }
    fr str.slaps(h, "trust") {
        lowkey ro, rt = lowerTrust(c, p, idx)
        bet ro, rt
    }
    fr str.slaps(h, "ghosted") {
        // `ghosted` in a yikes context is the no-error value `{ present: false }`.
        fr isYikesTy(hint) {
            lowkey go, gt = emitMakeYikes(c, "false", "\"\"")
            bet go, gt
        }
        lcFail(c)
        bet "0i64", "i64"
    }
    lcFail(c)
    bet "0i64", "i64"
}

// The stdlib module namespaces (mirror is_module).
finna isModule(name: str) -> bool {
    bet str.slaps(name, "spill") || str.slaps(name, "str") || str.slaps(name, "math") || str.slaps(name, "mem") || str.slaps(name, "bytes") || str.slaps(name, "fmt") || str.slaps(name, "stash") || str.slaps(name, "vec") || str.slaps(name, "yikes") || str.slaps(name, "fs") || str.slaps(name, "sys")
}

// `str_ptr(s)` / `str_len(s)` into fresh temps; return their ids.
finna emitStrPtr(c: LowerCtx, sop: str) -> int {
    lowkey t = newLocal(c, "rawptr")
    lowkey sb = sbNew()
    sb.add("str_ptr(")
    sb.add(sop)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet t
}

finna emitStrLen(c: LowerCtx, sop: str) -> int {
    lowkey t = newLocal(c, "u64")
    lowkey sb = sbNew()
    sb.add("str_len(")
    sb.add(sop)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet t
}

// A non-copying `[]u8` byte view over a str (mirror str_byteslice_local); returns the slice place.
finna strByteslice(c: LowerCtx, s: str) -> str {
    lowkey sp = emitStrPtr(c, s)
    lowkey sl = emitStrLen(c, s)
    lowkey slc = newLocal(c, "[]u8")
    emitAssign(c, slc, call2("make_slice[u8]", reg(sp), reg(sl)))
    bet reg(slc)
}

// Concatenate two str operands into a fresh str via bet_str_concat (mirror concat_str); returns
// the result str operand.
finna concatStr(c: LowerCtx, a: str, b: str) -> str {
    lowkey ap = emitStrPtr(c, a)
    lowkey al = emitStrLen(c, a)
    lowkey bp = emitStrPtr(c, b)
    lowkey bl = emitStrLen(c, b)
    getExtern(c, "extern \"C\" fn bet_str_concat(rawptr, u64, rawptr, u64) -> rawptr")
    lowkey outPtr = newLocal(c, "rawptr")
    lowkey cb = sbNew()
    cb.add("call_extern @bet_str_concat(")
    cb.add(reg(ap))
    cb.add(", ")
    cb.add(reg(al))
    cb.add(", ")
    cb.add(reg(bp))
    cb.add(", ")
    cb.add(reg(bl))
    cb.add(")")
    emitAssign(c, outPtr, cb.finish())
    lowkey outLen = newLocal(c, "u64")
    lowkey lb = sbNew()
    lb.add("add.wrap(")
    lb.add(reg(al))
    lb.add(", ")
    lb.add(reg(bl))
    lb.add(")")
    emitAssign(c, outLen, lb.finish())
    lowkey result = newLocal(c, "str")
    lowkey mb = sbNew()
    mb.add("make_str(")
    mb.add(reg(outPtr))
    mb.add(", ")
    mb.add(reg(outLen))
    mb.add(")")
    emitAssign(c, result, mb.finish())
    bet reg(result)
}

// A stdlib module intrinsic call (mirror lower_intrinsic) — the scalar/str subset. Unhandled
// (module, method) pairs sentinel the program.
finna lowerIntrinsic(c: LowerCtx, p: P, module: str, method: str, methodIdx: int) -> (str, str) {
    lowkey argsW = findKid(p, methodIdx, "args")
    fr str.slaps(module, "yikes") && str.slaps(method, "new") {
        lowkey msg, mty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey yo, yt = emitMakeYikes(c, "true", msg)
        bet yo, yt
    }
    fr str.slaps(module, "math") && str.slaps(method, "lap") {
        lowkey a, aty = lowerExpr(c, p, argValue(p, argsW, 0), "")
        lowkey b, bty = lowerExpr(c, p, argValue(p, argsW, 1), aty)
        lowkey t = newLocal(c, aty)
        lowkey sb = sbNew()
        sb.add("add.wrap(")
        sb.add(a)
        sb.add(", ")
        sb.add(b)
        sb.add(")")
        emitAssign(c, t, sb.finish())
        bet reg(t), aty
    }
    fr str.slaps(module, "str") && str.slaps(method, "glow") {
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey sp = emitStrPtr(c, s)
        lowkey sl = emitStrLen(c, s)
        getExtern(c, "extern \"C\" fn bet_str_upper(rawptr, u64) -> rawptr")
        lowkey out = newLocal(c, "rawptr")
        lowkey cb = sbNew()
        cb.add("call_extern @bet_str_upper(")
        cb.add(reg(sp))
        cb.add(", ")
        cb.add(reg(sl))
        cb.add(")")
        emitAssign(c, out, cb.finish())
        lowkey result = newLocal(c, "str")
        lowkey mb = sbNew()
        mb.add("make_str(")
        mb.add(reg(out))
        mb.add(", ")
        mb.add(reg(sl))
        mb.add(")")
        emitAssign(c, result, mb.finish())
        bet reg(result), "str"
    }
    fr str.slaps(module, "bytes") && str.slaps(method, "readU32le") {
        lowkey buf, bty = lowerExpr(c, p, argValue(p, argsW, 0), "")
        lowkey off, oty = lowerExpr(c, p, argValue(p, argsW, 1), "i64")
        fr !isPlace(buf) {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey acc = newLocal(c, "u32")
        emitAssign(c, acc, "0u32")
        lowkey k = 0
        vibin k < 4 {
            lowkey idxL = newLocal(c, "i64")
            lowkey ib = sbNew()
            ib.add("add.wrap(")
            ib.add(off)
            ib.add(", ")
            ib.add(itoa(k))
            ib.add("i64)")
            emitAssign(c, idxL, ib.finish())
            lowkey bz = newLocal(c, "u32")
            lowkey zb = sbNew()
            zb.add("cast.zext(")
            zb.add(buf)
            zb.add(".index(")
            zb.add(reg(idxL))
            zb.add(") as u32)")
            emitAssign(c, bz, zb.finish())
            lowkey sh = newLocal(c, "u32")
            lowkey shb = sbNew()
            shb.add("shl.na(")
            shb.add(reg(bz))
            shb.add(", ")
            shb.add(itoa(8 * k))
            shb.add("u32)")
            emitAssign(c, sh, shb.finish())
            lowkey orr = newLocal(c, "u32")
            lowkey ob = sbNew()
            ob.add("bitor.na(")
            ob.add(reg(acc))
            ob.add(", ")
            ob.add(reg(sh))
            ob.add(")")
            emitAssign(c, orr, ob.finish())
            emitAssign(c, acc, reg(orr))
            k = k + 1
        }
        bet reg(acc), "u32"
    }
    fr str.slaps(module, "sys") && str.slaps(method, "argc") {
        getExtern(c, "extern \"C\" fn bet_arg_count() -> u64")
        lowkey n = newLocal(c, "u64")
        emitAssign(c, n, "call_extern @bet_arg_count()")
        lowkey out = coerceInt(c, reg(n), "u64", "i64")
        bet out, "i64"
    }
    fr str.slaps(module, "sys") && str.slaps(method, "arg") {
        lowkey idx, ity = lowerExpr(c, p, argValue(p, argsW, 0), "i64")
        lowkey idxu = coerceInt(c, idx, ity, "u64")
        lowkey outLen = newLocal(c, "u64")
        emitAssign(c, outLen, "0u64")
        lowkey outPtr = newLocal(c, "rawptr")
        lowkey ab = sbNew()
        ab.add("addr_of(")
        ab.add(reg(outLen))
        ab.add(")")
        emitAssign(c, outPtr, ab.finish())
        getExtern(c, "extern \"C\" fn bet_arg_get(u64, rawptr) -> rawptr")
        lowkey data = newLocal(c, "rawptr")
        lowkey cb = sbNew()
        cb.add("call_extern @bet_arg_get(")
        cb.add(idxu)
        cb.add(", ")
        cb.add(reg(outPtr))
        cb.add(")")
        emitAssign(c, data, cb.finish())
        lowkey result = newLocal(c, "str")
        lowkey mb = sbNew()
        mb.add("make_str(")
        mb.add(reg(data))
        mb.add(", ")
        mb.add(reg(outLen))
        mb.add(")")
        emitAssign(c, result, mb.finish())
        bet reg(result), "str"
    }
    fr str.slaps(module, "str") && str.slaps(method, "len") {
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey lenu = newLocal(c, "u64")
        emitAssign(c, lenu, call1("str_len", s))
        lowkey out = coerceInt(c, reg(lenu), "u64", "i64")
        bet out, "i64"
    }
    fr str.slaps(module, "str") && str.slaps(method, "at") {
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey slc = strByteslice(c, s)
        lowkey idx, ity = lowerExpr(c, p, argValue(p, argsW, 1), "i64")
        lowkey idxc = coerceInt(c, idx, ity, "i64")
        lowkey out = newLocal(c, "i64")
        lowkey sb = sbNew()
        sb.add("cast.zext(")
        sb.add(slc)
        sb.add(".index(")
        sb.add(idxc)
        sb.add(") as i64)")
        emitAssign(c, out, sb.finish())
        bet reg(out), "i64"
    }
    fr str.slaps(module, "str") && str.slaps(method, "sub") {
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey start, stty = lowerExpr(c, p, argValue(p, argsW, 1), "i64")
        lowkey startc = coerceInt(c, start, stty, "i64")
        lowkey endd, ety = lowerExpr(c, p, argValue(p, argsW, 2), "i64")
        lowkey endc = coerceInt(c, endd, ety, "i64")
        lowkey slc = strByteslice(c, s)
        lowkey isb = sbNew()
        isb.add(slc)
        isb.add(".index(")
        isb.add(startc)
        isb.add(")")
        lowkey dptr = emitAddrOf(c, isb.finish())
        lowkey newlen = newLocal(c, "i64")
        emitAssign(c, newlen, call2("sub.wrap", endc, startc))
        lowkey result = newLocal(c, "str")
        emitAssign(c, result, call2("make_str", reg(dptr), reg(newlen)))
        bet reg(result), "str"
    }
    fr str.slaps(module, "str") && str.slaps(method, "bytes") {
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey slc = strByteslice(c, s)
        bet slc, "[]u8"
    }
    fr str.slaps(module, "str") && str.slaps(method, "fromBytesTrust") {
        lowkey sl, slty = lowerExpr(c, p, argValue(p, argsW, 0), "")
        fr !isPlace(sl) {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey sp = newLocal(c, "rawptr")
        emitAssign(c, sp, call1("slice_ptr", sl))
        lowkey slen = newLocal(c, "u64")
        emitAssign(c, slen, call1("slice_len", sl))
        lowkey result = newLocal(c, "str")
        emitAssign(c, result, call2("make_str", reg(sp), reg(slen)))
        bet reg(result), "str"
    }
    fr str.slaps(module, "str") && str.slaps(method, "fromBytes") {
        lowkey sl, slty = lowerExpr(c, p, argValue(p, argsW, 0), "")
        fr !isPlace(sl) {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey sp = newLocal(c, "rawptr")
        emitAssign(c, sp, call1("slice_ptr", sl))
        lowkey slen = newLocal(c, "u64")
        emitAssign(c, slen, call1("slice_len", sl))
        getExtern(c, "extern \"C\" fn bet_str_valid(rawptr, u64) -> u64")
        lowkey valid = newLocal(c, "u64")
        emitAssign(c, valid, call2("call_extern @bet_str_valid", reg(sp), reg(slen)))
        lowkey newlen = newLocal(c, "u64")
        emitAssign(c, newlen, call2("mul.wrap", reg(slen), reg(valid)))
        lowkey result = newLocal(c, "str")
        emitAssign(c, result, call2("make_str", reg(sp), reg(newlen)))
        bet reg(result), "str"
    }
    fr str.slaps(module, "str") && str.slaps(method, "slaps") {
        lowkey a, aty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey b, bty = lowerExpr(c, p, argValue(p, argsW, 1), "str")
        lowkey ap = emitStrPtr(c, a)
        lowkey al = emitStrLen(c, a)
        lowkey bp = emitStrPtr(c, b)
        lowkey bl = emitStrLen(c, b)
        getExtern(c, "extern \"C\" fn bet_str_eq(rawptr, u64, rawptr, u64) -> bool")
        lowkey out = newLocal(c, "bool")
        lowkey cb = sbNew()
        cb.add("call_extern @bet_str_eq(")
        cb.add(reg(ap))
        cb.add(", ")
        cb.add(reg(al))
        cb.add(", ")
        cb.add(reg(bp))
        cb.add(", ")
        cb.add(reg(bl))
        cb.add(")")
        emitAssign(c, out, cb.finish())
        bet reg(out), "bool"
    }
    fr str.slaps(module, "mem") && str.slaps(method, "scratch") {
        // `mem.scratch()` — the thread's built-in per-frame bump arena (a `crib void`).
        getExtern(c, "extern \"C\" fn bet_scratch() -> crib void")
        lowkey tmp = newLocal(c, "crib void")
        emitAssign(c, tmp, "call_extern @bet_scratch()")
        bet reg(tmp), "crib void"
    }
    lcFail(c)
    bet "0i64", "i64"
}

// Serialize a map key to (ptr, len) operands (mirror serialize_key): a str key uses str_ptr/str_len;
// any other key is spilled to a slot and passed by addr_of + size_of.
finna serializeKey(c: LowerCtx, p: P, keyIdx: int, kty: str) -> (str, str) {
    lowkey keyOp, keyT = lowerExpr(c, p, keyIdx, kty)
    fr str.slaps(kty, "str") {
        lowkey kp = emitStrPtr(c, keyOp)
        lowkey kl = emitStrLen(c, keyOp)
        bet reg(kp), reg(kl)
    }
    lowkey slot = newLocal(c, kty)
    emitAssign(c, slot, keyOp)
    lowkey kp = emitAddrOf(c, reg(slot))
    lowkey kl = newLocal(c, "u64")
    lowkey sb = sbNew()
    sb.add("size_of[")
    sb.add(kty)
    sb.add("]")
    emitAssign(c, kl, sb.finish())
    bet reg(kp), reg(kl)
}

// `stash.new[K, V]()` — an empty hash map (mirror lower_stash_new): size_of[V] + bet_map_new(size).
// The `in: <crib>` allocator-context form is not lowered in this subset (sentinels).
finna lowerStashNew(c: LowerCtx, p: P, methodIdx: int) -> (str, str) {
    lowkey targsW = findKid(p, methodIdx, "typeargs")
    fr targsW < 0 || kidCount(p, targsW) != 2 {
        lcFail(c)
        bet "0i64", "i64"
    }
    // The only supported arg is the `in: <crib>` allocator-context override (SP0.1), which scopes
    // bet_map_new between bet_ctx_push(crib) / bet_ctx_pop().
    lowkey argsW = findKid(p, methodIdx, "args")
    lowkey cribOp = ""
    lowkey hasIn = cap
    fr argsW >= 0 && kidCount(p, argsW) > 0 {
        lowkey a0 = kidAt(p, argsW, 0)
        fr kidCount(p, argsW) == 1 && str.slaps(afterFirst(lab(p, a0)), "in") {
            lowkey co, cty = lowerExpr(c, p, kidAt(p, a0, 0), "")
            cribOp = co
            hasIn = nocap
        } naw {
            lcFail(c)
            bet "0i64", "i64"
        }
    }
    lowkey k = mapTypeNode(c, p, kidAt(p, targsW, 0))
    lowkey v = mapTypeNode(c, p, kidAt(p, targsW, 1))
    lowkey mapTy = mapTyStr(k, v)
    fr hasIn {
        getExtern(c, "extern \"C\" fn bet_ctx_push(crib void) -> void")
        lowkey pushArgs = vec.new[str]()
        pushArgs.stack(cribOp)
        lowkey pr = emitExternCall(c, "void", "bet_ctx_push", pushArgs)
    }
    lowkey vsize = newLocal(c, "u64")
    lowkey sb = sbNew()
    sb.add("size_of[")
    sb.add(v)
    sb.add("]")
    emitAssign(c, vsize, sb.finish())
    lowkey ext = sbNew()
    ext.add("extern \"C\" fn bet_map_new(u64) -> ")
    ext.add(mapTy)
    getExtern(c, ext.finish())
    lowkey args = vec.new[str]()
    args.stack(reg(vsize))
    lowkey tmp = emitExternCall(c, mapTy, "bet_map_new", args)
    fr hasIn {
        getExtern(c, "extern \"C\" fn bet_ctx_pop() -> void")
        lowkey popArgs = vec.new[str]()
        lowkey pr2 = emitExternCall(c, "void", "bet_ctx_pop", popArgs)
    }
    bet reg(tmp), mapTy
}

// Dispatch a method on a `stash[K, V]` (map) value: put, peep, gang (mirror lower_stash_method).
// `peep` yields a `(V, bool)` tuple destructured by the caller's `lowkey v, ok = ...`.
finna lowerStashMethod(c: LowerCtx, p: P, methodIdx: int, mapOp: str, k: str, v: str, method: str) -> (str, str) {
    lowkey mapTy = mapTyStr(k, v)
    lowkey argsW = findKid(p, methodIdx, "args")
    fr str.slaps(method, "put") {
        lowkey keyPtr, keyLen = serializeKey(c, p, argValue(p, argsW, 0), k)
        lowkey val, vty = lowerExpr(c, p, argValue(p, argsW, 1), v)
        lowkey vl = newLocal(c, v)
        emitAssign(c, vl, val)
        lowkey valPtr = emitAddrOf(c, reg(vl))
        getExtern(c, vecExternDecl("bet_map_put", cat2(mapTy, ", rawptr, u64, rawptr"), "void"))
        lowkey args = vec.new[str]()
        args.stack(mapOp)
        args.stack(keyPtr)
        args.stack(keyLen)
        args.stack(reg(valPtr))
        lowkey r = emitExternCall(c, "void", "bet_map_put", args)
        bet reg(r), "void"
    }
    fr str.slaps(method, "peep") {
        lowkey keyPtr, keyLen = serializeKey(c, p, argValue(p, argsW, 0), k)
        lowkey out = newLocal(c, v)
        lowkey valPtr = emitAddrOf(c, reg(out))
        getExtern(c, vecExternDecl("bet_map_get", cat2(mapTy, ", rawptr, u64, rawptr"), "bool"))
        lowkey args = vec.new[str]()
        args.stack(mapOp)
        args.stack(keyPtr)
        args.stack(keyLen)
        args.stack(reg(valPtr))
        lowkey ok = emitExternCall(c, "bool", "bet_map_get", args)
        lowkey tupTy = cat3("(", v, ", bool)")
        lowkey tup = newLocal(c, tupTy)
        lowkey tsb = sbNew()
        tsb.add("tuple(")
        tsb.add(reg(out))
        tsb.add(", ")
        tsb.add(reg(ok))
        tsb.add(")")
        emitAssign(c, tup, tsb.finish())
        bet reg(tup), tupTy
    }
    fr str.slaps(method, "gang") {
        getExtern(c, vecExternDecl("bet_map_len", mapTy, "u64"))
        lowkey args = vec.new[str]()
        args.stack(mapOp)
        lowkey r = emitExternCall(c, "u64", "bet_map_len", args)
        bet reg(r), "u64"
    }
    lcFail(c)
    bet "0i64", "i64"
}

// `vec.new[T]()` — an empty growable vec (mirror lower_vec_new): size_of[T] + bet_vec_new(size).
finna lowerVecNew(c: LowerCtx, p: P, methodIdx: int) -> (str, str) {
    lowkey targsW = findKid(p, methodIdx, "typeargs")
    fr targsW < 0 || kidCount(p, targsW) != 1 {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey elem = mapTypeNode(c, p, kidAt(p, targsW, 0))
    lowkey vecTy = vecTyStr(elem)
    lowkey esize = newLocal(c, "u64")
    lowkey sb = sbNew()
    sb.add("size_of[")
    sb.add(elem)
    sb.add("]")
    emitAssign(c, esize, sb.finish())
    lowkey ext = sbNew()
    ext.add("extern \"C\" fn bet_vec_new(u64) -> ")
    ext.add(vecTy)
    getExtern(c, ext.finish())
    lowkey args = vec.new[str]()
    args.stack(reg(esize))
    lowkey tmp = emitExternCall(c, vecTy, "bet_vec_new", args)
    bet reg(tmp), vecTy
}

// The `extern "C" fn NAME(<paramList>) -> RET` decl string.
finna vecExternDecl(name: str, paramList: str, ret: str) -> str {
    lowkey sb = sbNew()
    sb.add("extern \"C\" fn ")
    sb.add(name)
    sb.add("(")
    sb.add(paramList)
    sb.add(") -> ")
    sb.add(ret)
    bet sb.finish()
}

// Dispatch a method on a `vec[T]` value: stack (push), pop, gang (length) (mirror lower_vec_method).
finna lowerVecMethod(c: LowerCtx, p: P, methodIdx: int, vecOp: str, elem: str, method: str) -> (str, str) {
    lowkey vecTy = vecTyStr(elem)
    lowkey argsW = findKid(p, methodIdx, "args")
    fr str.slaps(method, "stack") {
        lowkey val, vty = lowerExpr(c, p, argValue(p, argsW, 0), elem)
        lowkey el = newLocal(c, elem)
        emitAssign(c, el, val)
        lowkey ptr = emitAddrOf(c, reg(el))
        getExtern(c, vecExternDecl("bet_vec_push", cat3(vecTy, ", ", "rawptr"), "void"))
        lowkey args = vec.new[str]()
        args.stack(vecOp)
        args.stack(reg(ptr))
        lowkey r = emitExternCall(c, "void", "bet_vec_push", args)
        bet reg(r), "void"
    }
    fr str.slaps(method, "gang") {
        getExtern(c, vecExternDecl("bet_vec_len", vecTy, "u64"))
        lowkey args = vec.new[str]()
        args.stack(vecOp)
        lowkey r = emitExternCall(c, "u64", "bet_vec_len", args)
        bet reg(r), "u64"
    }
    fr str.slaps(method, "pop") {
        lowkey out = newLocal(c, elem)
        lowkey ptr = emitAddrOf(c, reg(out))
        getExtern(c, vecExternDecl("bet_vec_pop", cat3(vecTy, ", ", "rawptr"), "bool"))
        lowkey args = vec.new[str]()
        args.stack(vecOp)
        args.stack(reg(ptr))
        lowkey ok = emitExternCall(c, "bool", "bet_vec_pop", args)
        bet reg(out), elem
    }
    // `v.append(s)` → bet_vec_extend(vec, str_ptr, str_len): bulk-append a str's raw bytes.
    // The string-builder primitive; restricted to `vec[u8]` (mirror lower_vec_method).
    fr str.slaps(method, "append") {
        fr !str.slaps(elem, "u8") {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey s, sty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
        lowkey sp = emitStrPtr(c, s)
        lowkey sl = emitStrLen(c, s)
        getExtern(c, vecExternDecl("bet_vec_extend", cat3(vecTy, ", ", "rawptr, u64"), "void"))
        lowkey args = vec.new[str]()
        args.stack(vecOp)
        args.stack(reg(sp))
        args.stack(reg(sl))
        lowkey r = emitExternCall(c, "void", "bet_vec_extend", args)
        bet reg(r), "void"
    }
    // `v.str()` → an owned `str` copied out of a `vec[u8]`'s buffer: bet_vec_data + bet_vec_len,
    // then bet_str_concat (with an empty second run) so the result outlives later mutation
    // (mirror lower_vec_method's `str` arm). Restricted to `vec[u8]`.
    fr str.slaps(method, "str") {
        fr !str.slaps(elem, "u8") {
            lcFail(c)
            bet "0i64", "i64"
        }
        getExtern(c, vecExternDecl("bet_vec_data", vecTy, "rawptr"))
        lowkey dataArgs = vec.new[str]()
        dataArgs.stack(vecOp)
        lowkey data = emitExternCall(c, "rawptr", "bet_vec_data", dataArgs)
        getExtern(c, vecExternDecl("bet_vec_len", vecTy, "u64"))
        lowkey lenArgs = vec.new[str]()
        lenArgs.stack(vecOp)
        lowkey len = emitExternCall(c, "u64", "bet_vec_len", lenArgs)
        getExtern(c, "extern \"C\" fn bet_str_concat(rawptr, u64, rawptr, u64) -> rawptr")
        lowkey outPtr = newLocal(c, "rawptr")
        lowkey cb = sbNew()
        cb.add("call_extern @bet_str_concat(")
        cb.add(reg(data))
        cb.add(", ")
        cb.add(reg(len))
        cb.add(", ")
        cb.add(reg(data))
        cb.add(", 0u64)")
        emitAssign(c, outPtr, cb.finish())
        lowkey result = newLocal(c, "str")
        emitAssign(c, result, call2("make_str", reg(outPtr), reg(len)))
        bet reg(result), "str"
    }
    lcFail(c)
    bet "0i64", "i64"
}

// `v[i]` for a `vec[T]` — a runtime read into a fresh slot via bet_vec_get (mirror lower_vec_index).
finna lowerVecIndex(c: LowerCtx, p: P, indexIdx: int, vecOp: str, elem: str) -> (str, str) {
    lowkey vecTy = vecTyStr(elem)
    lowkey iop, ity = lowerExpr(c, p, kidAt(p, indexIdx, 1), "u64")
    lowkey iu = coerceInt(c, iop, ity, "u64")
    lowkey out = newLocal(c, elem)
    lowkey ptr = emitAddrOf(c, reg(out))
    getExtern(c, vecExternDecl("bet_vec_get", cat3(vecTy, ", ", "u64, rawptr"), "bool"))
    lowkey args = vec.new[str]()
    args.stack(vecOp)
    args.stack(iu)
    args.stack(reg(ptr))
    lowkey ok = emitExternCall(c, "bool", "bet_vec_get", args)
    bet reg(out), elem
}

// `squad x in v { .. }` for a `vec[T]` — a counter loop bounded by bet_vec_len (mirror
// lower_vec_squad). The counter is u64; each iteration binds `x = bet_vec_get(v, ctr)`.
finna lowerVecSquad(c: LowerCtx, p: P, squadIdx: int, vecOp: str, elem: str, var: str) {
    lowkey vecTy = vecTyStr(elem)
    getExtern(c, vecExternDecl("bet_vec_len", vecTy, "u64"))
    lowkey lenArgs = vec.new[str]()
    lenArgs.stack(vecOp)
    lowkey len = emitExternCall(c, "u64", "bet_vec_len", lenArgs)
    lowkey ctr = newLocal(c, "u64")
    emitAssign(c, ctr, "0u64")
    lowkey pre = curId(c)
    lowkey header = reserveBlock(c)
    setGoto(c, pre, header)
    selectBlock(c, header)
    lowkey cond = newLocal(c, "bool")
    lowkey csb = sbNew()
    csb.add("lt.na(")
    csb.add(reg(ctr))
    csb.add(", ")
    csb.add(reg(len))
    csb.add(")")
    emitAssign(c, cond, csb.finish())
    lowkey headerEnd = curId(c)
    lowkey bodyBb = newBlock(c)
    lowkey exit = reserveBlock(c)
    setBranch(c, headerEnd, reg(cond), bodyBb, exit)
    selectBlock(c, bodyBb)
    lowkey elemLocal = newLocal(c, elem)
    lowkey ptr = emitAddrOf(c, reg(elemLocal))
    getExtern(c, vecExternDecl("bet_vec_get", cat3(vecTy, ", ", "u64, rawptr"), "bool"))
    lowkey getArgs = vec.new[str]()
    getArgs.stack(vecOp)
    getArgs.stack(reg(ctr))
    getArgs.stack(reg(ptr))
    lowkey got = emitExternCall(c, "bool", "bet_vec_get", getArgs)
    bindLocal(c, var, elemLocal)
    lowkey incr = reserveBlock(c)
    pushLoop(c, incr, exit)
    lowerBlock(c, p, kidAt(p, squadIdx, 1))
    popLoop(c)
    termGoto(c, incr)
    selectBlock(c, incr)
    lowkey isb = sbNew()
    isb.add("add.wrap(")
    isb.add(reg(ctr))
    isb.add(", 1u64)")
    emitAssign(c, ctr, isb.finish())
    termGoto(c, header)
    selectBlock(c, exit)
}

// `y.tea(ctx)` — wrap an error, prefixing `"<ctx>: "` to its message (mirror lower_yikes_method).
finna lowerTea(c: LowerCtx, p: P, methodIdx: int, yop: str) -> (str, str) {
    lowkey argsW = findKid(p, methodIdx, "args")
    lowkey ctx, cty = lowerExpr(c, p, argValue(p, argsW, 0), "str")
    lowkey msg = cat2(yop, ".field(1)")
    lowkey prefixed = concatStr(c, ctx, "\": \"")
    lowkey full = concatStr(c, prefixed, msg)
    lowkey yo, yt = emitMakeYikes(c, "true", full)
    bet yo, yt
}

// `recv.method(args)` where `recv` is a value — a user receiver method (mirror lower_method's user
// branch): the receiver becomes the leading argument. Module-name receivers route to intrinsics.
finna lowerMethodCall(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey methodName = afterFirst(lab(p, idx))
    lowkey recvW = findKid(p, idx, "receiver")
    lowkey recvE = kidAt(p, recvW, 0)
    // A bare-name receiver that is neither a value (local/const) nor a function is a module.
    fr str.slaps(firstWord(lab(p, recvE)), "name") && kidCount(p, recvE) == 0 {
        lowkey rn = afterFirst(lab(p, recvE))
        fr lookupLocal(c, rn) < 0 && lookupConst(c, rn) < 0 && lookupGlobalConst(c, rn) < 0 && lookupFn(c, rn) < 0 {
            fr isModule(rn) {
                // `vec.new[T]()` needs its type arg, so it bypasses the plain intrinsic dispatch.
                fr str.slaps(rn, "vec") && str.slaps(methodName, "new") {
                    lowkey vo, vt = lowerVecNew(c, p, idx)
                    bet vo, vt
                }
                // `stash.new[K, V]()` needs its type args too, so it bypasses plain intrinsic dispatch.
                fr str.slaps(rn, "stash") && str.slaps(methodName, "new") {
                    lowkey so, st = lowerStashNew(c, p, idx)
                    bet so, st
                }
                lowkey io, it = lowerIntrinsic(c, p, rn, methodName, idx)
                bet io, it
            }
            lcFail(c)
            bet "0i64", "i64"
        }
    }
    lowkey fi = lookupFn(c, methodName)
    fr fi < 0 {
        // Not a user method — try a value method on the receiver's type (yikes.tea / vec.*).
        lowkey yop, yty = lowerExpr(c, p, recvE, "")
        fr isYikesTy(yty) && str.slaps(methodName, "tea") && isPlace(yop) {
            lowkey to, tt = lowerTea(c, p, idx, yop)
            bet to, tt
        }
        fr isVecTy(yty) {
            lowkey vo, vt = lowerVecMethod(c, p, idx, yop, vecElem(yty), methodName)
            bet vo, vt
        }
        fr isMapTy(yty) {
            lowkey mo, mt = lowerStashMethod(c, p, idx, yop, mapKey(yty), mapVal(yty), methodName)
            bet mo, mt
        }
        // A `finna(..)`-typed struct field named like the method — an indirect call through it
        // (mirror lower_fn_field_call): `%r = call_indirect %recv.deref.field(i)(args)`. The base
        // must be an addressable place; a `ref Struct` receiver auto-derefs.
        fr isPlace(yop) {
            lowkey sname = yty
            lowkey base = yop
            fr isRefTy(yty) {
                sname = refElem(yty)
                base = cat2(yop, ".deref")
            }
            fr isStruct(c, sname) {
                lowkey ffi = structFieldIndex(c, sname, methodName)
                fr ffi >= 0 {
                    lowkey fpty = structFieldType(c, sname, methodName)
                    fr isFnPtrTy(fpty) {
                        lowkey fptr = cat3(base, ".field(", cat2(itoa(ffi), ")"))
                        lowkey fpCsv = fnPtrParams(fpty)
                        lowkey fpRet = fnPtrRet(fpty)
                        lowkey fargsW = findKid(p, idx, "args")
                        lowkey fargs = vec.new[str]()
                        lowkey fnr = kidCount(p, fargsW)
                        lowkey fk = 0
                        vibin fk < fnr {
                            lowkey aop, aty = lowerExpr(c, p, argValue(p, fargsW, fk), csvAt(fpCsv, fk))
                            fargs.stack(aop)
                            fk = fk + 1
                        }
                        lowkey fres = newLocal(c, fpRet)
                        lowkey fsb = sbNew()
                        fsb.add("call_indirect ")
                        fsb.add(fptr)
                        fsb.add("(")
                        fsb.add(joinComma(fargs))
                        fsb.add(")")
                        emitAssign(c, fres, fsb.finish())
                        bet reg(fres), fpRet
                    }
                }
            }
        }
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey paramCsv = c.fnParamCsv[fi]
    lowkey retTy = c.fnRet[fi]
    lowkey rop, rty = lowerExpr(c, p, recvE, csvAt(paramCsv, 0))
    lowkey argStrs = vec.new[str]()
    argStrs.stack(rop)
    lowkey argsW = findKid(p, idx, "args")
    lowkey na = kidCount(p, argsW)
    lowkey ai = 0
    vibin ai < na {
        lowkey aop, aty = lowerExpr(c, p, argValue(p, argsW, ai), csvAt(paramCsv, ai + 1))
        argStrs.stack(aop)
        ai = ai + 1
    }
    lowkey res = newLocal(c, retTy)
    lowkey sb = sbNew()
    sb.add("call @")
    sb.add(methodName)
    sb.add("(")
    sb.add(joinComma(argStrs))
    sb.add(")")
    emitAssign(c, res, sb.finish())
    bet reg(res), retTy
}

// `Name{ f: v, .. }` — a struct literal materialized into a temp (mirror lower_struct_lit). Field
// operands are built in DECLARATION order (matched by name), each lowered with its field type.
finna lowerStructLit(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey name = afterFirst(lab(p, idx))
    // `Pair[int]{ .. }` — a generic struct literal carries a `typeargs` child; monomorphize it to
    // the mangled struct (and re-point `name` at that instance) before matching fields.
    lowkey taW = findKid(p, idx, "typeargs")
    fr taW >= 0 {
        fr !isGenericStruct(c, name) {
            lcFail(c)
            bet "0i64", "i64"
        }
        name = monoStruct(c, p, name, mapTypeArgs(c, p, taW))
        fr !lcOk(c) {
            bet "0i64", "i64"
        }
    }
    fr !isStruct(c, name) {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey fieldsW = findKid(p, idx, "fields")
    lowkey ops = vec.new[str]()
    lowkey nf = c.fieldNames.gang() as int
    lowkey i = 0
    vibin i < nf && lcOk(c) {
        fr str.slaps(c.fieldStruct[i], name) {
            lowkey declName = c.fieldNames[i]
            lowkey declTy = c.fieldTypes[i]
            lowkey valIdx = litFieldValue(p, fieldsW, declName)
            fr valIdx < 0 {
                lcFail(c)
            } naw {
                lowkey op, oty = lowerExpr(c, p, valIdx, declTy)
                ops.stack(op)
            }
        }
        i = i + 1
    }
    lowkey tmp = newLocal(c, name)
    lowkey sb = sbNew()
    sb.add("make ")
    sb.add(name)
    sb.add("(")
    sb.add(joinComma(ops))
    sb.add(")")
    emitAssign(c, tmp, sb.finish())
    bet reg(tmp), name
}

// The value node of the literal field named `fname` inside a `fields` node, or -1.
finna litFieldValue(p: P, fieldsW: int, fname: str) -> int {
    lowkey n = kidCount(p, fieldsW)
    lowkey i = 0
    vibin i < n {
        lowkey fnode = kidAt(p, fieldsW, i)
        fr str.slaps(afterFirst(lab(p, fnode)), fname) {
            bet kidAt(p, fnode, 0)
        }
        i = i + 1
    }
    bet 0 - 1
}

// `Name{ f: v, .. }` cop-init — the struct-literal payload of a `cop`, spelled `Name{0: op, ..}`
// with fields in DECLARATION order (mirror lower_cop struct arm + text.rs cop_init StructLit).
finna copStructInit(c: LowerCtx, p: P, initNode: int, name: str) -> str {
    lowkey fieldsW = findKid(p, initNode, "fields")
    lowkey parts = vec.new[str]()
    lowkey nf = c.fieldNames.gang() as int
    lowkey i = 0
    vibin i < nf && lcOk(c) {
        fr str.slaps(c.fieldStruct[i], name) {
            lowkey declName = c.fieldNames[i]
            lowkey declTy = c.fieldTypes[i]
            lowkey valIdx = litFieldValue(p, fieldsW, declName)
            fr valIdx < 0 {
                lcFail(c)
            } naw {
                lowkey op, oty = lowerExpr(c, p, valIdx, declTy)
                parts.stack(cat3(itoa(c.fieldIdx[i]), ": ", op))
            }
        }
        i = i + 1
    }
    bet cat3(name, "{", cat2(joinComma(parts), "}"))
}

// `Sum::Variant(op, ..)` cop-init — the sum-variant payload of a `cop` (mirror lower_cop variant
// arm + text.rs cop_init SumVariant). Args lower with their declared payload types.
finna copVariantInit(c: LowerCtx, p: P, initNode: int, vi: int) -> str {
    lowkey vname = afterFirst(lab(p, initNode))
    lowkey payloadCsv = c.variantPayload[vi]
    lowkey argsW = findKid(p, initNode, "args")
    lowkey ops = vec.new[str]()
    lowkey vn = kidCount(p, argsW)
    lowkey k = 0
    vibin k < vn {
        lowkey aop, aty = lowerExpr(c, p, argValue(p, argsW, k), csvAt(payloadCsv, k))
        ops.stack(aop)
        k = k + 1
    }
    lowkey head = cat3(c.variantSum[vi], "::", vname)
    fr vn == 0 { bet head }
    bet cat2(head, cat3("(", joinComma(ops), ")"))
}

// `cop INIT in CRIB` — allocate into an arena (mirror lower_cop). Lowers the crib operand first,
// then the init payload; a typed crib hands back `tag elem`, a bump (`crib void`) hands back a
// live `ref Struct`. `%t = cop(%crib, INIT)`.
finna lowerCop(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey initNode = kidAt(p, idx, 0)
    lowkey cribW = kidAt(p, idx, 1)
    lowkey cribOp, cribTy = lowerExpr(c, p, kidAt(p, cribW, 0), "")
    fr !isCribTy(cribTy) {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey elem = cribElem(cribTy)
    lowkey isBump = str.slaps(elem, "void")
    lowkey initH = firstWord(lab(p, initNode))
    lowkey initStr = ""
    lowkey resTy = ""
    fr str.slaps(initH, "struct") {
        lowkey sname = afterFirst(lab(p, initNode))
        fr !isStruct(c, sname) {
            lcFail(c)
            bet "0i64", "i64"
        }
        initStr = copStructInit(c, p, initNode, sname)
        fr isBump { resTy = refTyStr(sname) } naw { resTy = tagTyStr(elem) }
    } naw fr str.slaps(initH, "variant") {
        lowkey vi = lookupVariant(c, afterFirst(lab(p, initNode)))
        fr isBump || !isSum(c, elem) || vi < 0 {
            lcFail(c)
            bet "0i64", "i64"
        }
        initStr = copVariantInit(c, p, initNode, vi)
        resTy = tagTyStr(elem)
    } naw {
        lcFail(c)
        bet "0i64", "i64"
    }
    fr !lcOk(c) {
        bet "0i64", "i64"
    }
    lowkey tmp = newLocal(c, resTy)
    emitAssign(c, tmp, cat3("cop(", cribOp, cat3(", ", initStr, ")")))
    bet reg(tmp), resTy
}

// `tag.trust() in CRIB` — the unchecked escape hatch (mirror lower_trust). Lowers the tag operand
// first, then the crib; yields a live `ref elem`. `%t = trust(%crib, %tag)`.
finna lowerTrust(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey tagOp, tagTy = lowerExpr(c, p, kidAt(p, idx, 0), "")
    lowkey cribOp, cribTy = lowerExpr(c, p, kidAt(p, idx, 1), "")
    fr !isCribTy(cribTy) {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey resTy = refTyStr(cribElem(cribTy))
    lowkey tmp = newLocal(c, resTy)
    emitAssign(c, tmp, cat3("trust(", cribOp, cat3(", ", tagOp, ")")))
    bet reg(tmp), resTy
}

// `base.field` — a place projection used as an operand (mirror lower_field). The base must be an
// addressable struct place (a bare register); returns (`%b.field(i)`, field type).
finna fieldAccessStr(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey fname = afterFirst(lab(p, idx))
    lowkey bop, bty = lowerExpr(c, p, kidAt(p, idx, 0), "")
    // Auto-deref a `ref Struct` base (as produced by `trust`/`holla`/bump `cop`): `%b.deref.field`.
    lowkey sname = bty
    lowkey base = bop
    fr isRefTy(bty) {
        sname = refElem(bty)
        base = cat2(bop, ".deref")
    }
    fr !isStruct(c, sname) || !isReg(bop) {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey fidx = structFieldIndex(c, sname, fname)
    fr fidx < 0 {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey sb = sbNew()
    sb.add(base)
    sb.add(".field(")
    sb.add(itoa(fidx))
    sb.add(")")
    bet sb.finish(), structFieldType(c, sname, fname)
}

// `[a, b, c]` — a fixed array literal materialized into a temp (mirror lower_array_lit).
// Slice-typed contexts (`[]T` hint) are sentineled upstream, so only the array form is emitted.
finna lowerArrayLit(c: LowerCtx, p: P, idx: int, hint: str) -> (str, str) {
    lowkey nk = kidCount(p, idx)
    fr nk == 0 {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey elemHint = arrayElemHint(hint)
    lowkey ops = vec.new[str]()
    lowkey elemTy = elemHint
    lowkey i = 0
    vibin i < nk {
        lowkey eo, et = lowerExpr(c, p, kidAt(p, idx, i), elemTy)
        fr isEmpty(elemTy) { elemTy = et }
        ops.stack(eo)
        i = i + 1
    }
    lowkey aty = arrayTyStr(elemTy, nk)
    lowkey tmp = newLocal(c, aty)
    lowkey sb = sbNew()
    sb.add("array[")
    sb.add(elemTy)
    sb.add("](")
    sb.add(joinComma(ops))
    sb.add(")")
    emitAssign(c, tmp, sb.finish())
    // In a slice context (`[]T`), materialize a slice over the freshly built array's storage.
    fr isSliceTy(hint) {
        lowkey dptr = emitAddrOf(c, reg(tmp))
        lowkey sl = newLocal(c, sliceTyStr(elemTy))
        lowkey msb = sbNew()
        msb.add("make_slice[")
        msb.add(elemTy)
        msb.add("](")
        msb.add(reg(dptr))
        msb.add(", ")
        msb.add(itoa(nk))
        msb.add("u64)")
        emitAssign(c, sl, msb.finish())
        bet reg(sl), sliceTyStr(elemTy)
    }
    bet reg(tmp), aty
}

// `base[i]` — a place projection used as an operand (mirror lower_index). Arrays/slices only;
// the base must be an addressable place (a bare register) and vec[T] indexing is deferred.
finna lowerIndex(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey bop, bty = lowerExpr(c, p, kidAt(p, idx, 0), "")
    fr isVecTy(bty) {
        lowkey vo, vt = lowerVecIndex(c, p, idx, bop, vecElem(bty))
        bet vo, vt
    }
    fr !(isArrayTy(bty) || isSliceTy(bty)) || !isReg(bop) {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey elem = arrayElem(bty)
    fr isSliceTy(bty) { elem = sliceElem(bty) }
    lowkey iop, ity = lowerExpr(c, p, kidAt(p, idx, 1), "i64")
    lowkey sb = sbNew()
    sb.add(bop)
    sb.add(".index(")
    sb.add(iop)
    sb.add(")")
    bet sb.finish(), elem
}

// A direct call to a named user function (mirror lower_call + lower_args + emit_call_result).
finna lowerCall(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey calleeW = findKid(p, idx, "callee")
    lowkey calleeE = kidAt(p, calleeW, 0)
    // Only a bare function name is a direct call (a generic call adds a `typeargs` child, below).
    fr !str.slaps(firstWord(lab(p, calleeE)), "name") {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey nm = afterFirst(lab(p, calleeE))
    // A callee that names a local of function-pointer type is an indirect call through that value
    // (mirror lower_call's Callee::Indirect path): `%r = call_indirect %f(args)`.
    lowkey lid = lookupLocal(c, nm)
    fr lid >= 0 {
        lowkey fty = c.localTypes[lid]
        fr !isFnPtrTy(fty) {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey ipCsv = fnPtrParams(fty)
        lowkey iret = fnPtrRet(fty)
        lowkey iargsW = findKid(p, idx, "args")
        lowkey iargs = vec.new[str]()
        lowkey inr = kidCount(p, iargsW)
        lowkey ik = 0
        vibin ik < inr {
            lowkey aop, aty = lowerExpr(c, p, argValue(p, iargsW, ik), csvAt(ipCsv, ik))
            iargs.stack(aop)
            ik = ik + 1
        }
        lowkey ires = newLocal(c, iret)
        lowkey isb = sbNew()
        isb.add("call_indirect ")
        isb.add(reg(lid))
        isb.add("(")
        isb.add(joinComma(iargs))
        isb.add(")")
        emitAssign(c, ires, isb.finish())
        bet reg(ires), iret
    }
    // A generic call `f[int](..)` — the callee `name f` carries a `typeargs` child. Monomorphize
    // the instance and re-point `nm` at its mangled symbol, then fall through to the normal path.
    fr kidCount(p, calleeE) > 0 {
        lowkey taW = findKid(p, calleeE, "typeargs")
        fr taW < 0 || !isGenericFn(c, nm) {
            lcFail(c)
            bet "0i64", "i64"
        }
        lowkey gargs = mapTypeArgs(c, p, taW)
        fr !lcOk(c) {
            bet "0i64", "i64"
        }
        nm = monoFn(c, p, nm, gargs)
        fr !lcOk(c) {
            bet "0i64", "i64"
        }
    }
    // A callee that names a `moods` variant (and not a fn) is a value constructor with payload.
    lowkey vi = lookupVariant(c, nm)
    fr vi >= 0 && lookupFn(c, nm) < 0 {
        lowkey payloadCsv = c.variantPayload[vi]
        lowkey vargsW = findKid(p, idx, "args")
        lowkey vops = vec.new[str]()
        lowkey vn = kidCount(p, vargsW)
        lowkey vk = 0
        vibin vk < vn {
            lowkey aop, aty = lowerExpr(c, p, argValue(p, vargsW, vk), csvAt(payloadCsv, vk))
            vops.stack(aop)
            vk = vk + 1
        }
        lowkey mo, mt = emitMakeVariant(c, c.variantSum[vi], nm, vops)
        bet mo, mt
    }
    // An `extern "C"` FFI import lowers to `call_extern @NAME` and emits its decl on first use.
    lowkey ei = lookupExtern(c, nm)
    fr ei >= 0 {
        getExtern(c, c.externFnDecl[ei])
        lowkey ePcsv = c.externFnParamCsv[ei]
        lowkey eRet = c.externFnRet[ei]
        lowkey eargsW = findKid(p, idx, "args")
        lowkey eargs = vec.new[str]()
        lowkey en = kidCount(p, eargsW)
        lowkey ek = 0
        vibin ek < en {
            lowkey aop, aty = lowerExpr(c, p, argValue(p, eargsW, ek), csvAt(ePcsv, ek))
            eargs.stack(aop)
            ek = ek + 1
        }
        lowkey eres = newLocal(c, eRet)
        lowkey esb = sbNew()
        esb.add("call_extern @")
        esb.add(nm)
        esb.add("(")
        esb.add(joinComma(eargs))
        esb.add(")")
        emitAssign(c, eres, esb.finish())
        bet reg(eres), eRet
    }
    lowkey fi = lookupFn(c, nm)
    fr fi < 0 {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey paramCsv = c.fnParamCsv[fi]
    lowkey retTy = c.fnRet[fi]
    lowkey argsW = findKid(p, idx, "args")
    lowkey argStrs = vec.new[str]()
    lowkey na = kidCount(p, argsW)
    lowkey ai = 0
    vibin ai < na {
        lowkey aop, aty = lowerExpr(c, p, argValue(p, argsW, ai), csvAt(paramCsv, ai))
        argStrs.stack(aop)
        ai = ai + 1
    }
    lowkey res = newLocal(c, retTy)
    lowkey sb = sbNew()
    sb.add("call @")
    sb.add(nm)
    sb.add("(")
    sb.add(joinComma(argStrs))
    sb.add(")")
    emitAssign(c, res, sb.finish())
    bet reg(res), retTy
}

// Lower a bare name: a local (Copy) or an inlined const value (mirror lower_name).
finna lowerName(c: LowerCtx, p: P, idx: int) -> (str, str) {
    // A name with generics (a `typeargs` child) is not lowered in this subset.
    fr kidCount(p, idx) > 0 {
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey nm = afterFirst(lab(p, idx))
    lowkey lid = lookupLocal(c, nm)
    fr lid >= 0 {
        bet reg(lid), c.localTypes[lid]
    }
    lowkey ci = lookupConst(c, nm)
    fr ci >= 0 {
        bet c.constVals[ci], c.constTys[ci]
    }
    lowkey gi = lookupGlobalConst(c, nm)
    fr gi >= 0 {
        bet c.gConstVals[gi], c.gConstTys[gi]
    }
    // A module-level crib: load its handle from the backing global (mirror lower_name crib arm).
    lowkey cgi = lookupCribGlobal(c, nm)
    fr cgi >= 0 {
        lowkey cty = cribTyStr(c.cribGlobalElems[cgi])
        lowkey tmp = newLocal(c, cty)
        emitAssign(c, tmp, cat3("crib_global(@", nm, ")"))
        bet reg(tmp), cty
    }
    // A bare name that is a nullary `moods` variant is a value constructor.
    lowkey vi = lookupVariant(c, nm)
    fr vi >= 0 && isEmpty(c.variantPayload[vi]) {
        lowkey mo, mt = emitMakeVariant(c, c.variantSum[vi], nm, vec.new[str]())
        bet mo, mt
    }
    // A bare function name used as a value is a function pointer: `@NAME` of type `fn(..) -> R`
    // (mirror lower_name's Const::FnRef case). The operand is inlined; callers materialize it.
    lowkey fi = lookupFn(c, nm)
    fr fi >= 0 {
        bet cat2("@", nm), fnPtrTypeOf(c, fi)
    }
    lcFail(c)
    bet "0i64", "i64"
}

finna lowerUnary(c: LowerCtx, p: P, idx: int, hint: str) -> (str, str) {
    lowkey opTag = afterFirst(lab(p, idx))
    lowkey io, ity = lowerExpr(c, p, kidAt(p, idx, 0), hint)
    lowkey resTy = ity
    fr str.slaps(opTag, "not") { resTy = "bool" }
    lowkey t = newLocal(c, resTy)
    lowkey sb = sbNew()
    sb.add(opTag)
    sb.add("(")
    sb.add(io)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet reg(t), resTy
}

finna lowerBinary(c: LowerCtx, p: P, idx: int, hint: str) -> (str, str) {
    lowkey opTag = afterFirst(lab(p, idx))
    // Short-circuit `and`/`or` lower to control flow.
    fr str.slaps(opTag, "and") || str.slaps(opTag, "or") {
        lowkey so, st = lowerShortCircuit(c, p, idx, opTag)
        bet so, st
    }
    // `x == ghosted` / `x != ghosted`: for a yikes operand this reads its `present` flag.
    lowkey lIsGhost = str.slaps(firstWord(lab(p, kidAt(p, idx, 0))), "ghosted")
    lowkey rIsGhost = str.slaps(firstWord(lab(p, kidAt(p, idx, 1))), "ghosted")
    fr (str.slaps(opTag, "eq") || str.slaps(opTag, "ne")) && (lIsGhost || rIsGhost) {
        lowkey otherE = kidAt(p, idx, 1)
        fr rIsGhost { otherE = kidAt(p, idx, 0) }
        lowkey oop, oty = lowerExpr(c, p, otherE, "")
        fr isYikesTy(oty) && isPlace(oop) {
            lowkey present = cat2(oop, ".field(0)")
            fr str.slaps(opTag, "ne") {
                bet present, "bool"
            }
            lowkey t = newLocal(c, "bool")
            emitAssign(c, t, cat3("not(", present, ")"))
            bet reg(t), "bool"
        }
        lcFail(c)
        bet "0i64", "i64"
    }
    lowkey isCmp = isComparisonTag(opTag)
    lowkey lhint = ""
    fr !isCmp { lhint = hint }
    lowkey lo, lty = lowerExpr(c, p, kidAt(p, idx, 0), lhint)
    lowkey ro, rty = lowerExpr(c, p, kidAt(p, idx, 1), lty)
    lowkey mode = arithMode(lty, opTag)
    lowkey resTy = lty
    fr isCmp { resTy = "bool" }
    lowkey t = newLocal(c, resTy)
    lowkey sb = sbNew()
    sb.add(opTag)
    sb.add(".")
    sb.add(mode)
    sb.add("(")
    sb.add(lo)
    sb.add(", ")
    sb.add(ro)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet reg(t), resTy
}

finna lowerCast(c: LowerCtx, p: P, idx: int) -> (str, str) {
    lowkey io, ity = lowerExpr(c, p, kidAt(p, idx, 0), "")
    lowkey dst = mapTypeNode(c, p, kidAt(p, idx, 1))
    lowkey kind = castKind(ity, dst)
    lowkey t = newLocal(c, dst)
    lowkey sb = sbNew()
    sb.add("cast.")
    sb.add(kind)
    sb.add("(")
    sb.add(io)
    sb.add(" as ")
    sb.add(dst)
    sb.add(")")
    emitAssign(c, t, sb.finish())
    bet reg(t), dst
}

// A restricted constant evaluator for `facts` (mirror const_literal): literals + unary neg.
finna constLiteral(c: LowerCtx, p: P, idx: int, hint: str) -> (str, str) {
    lowkey h = firstWord(lab(p, idx))
    lowkey payload = afterFirst(lab(p, idx))
    fr str.slaps(h, "int") {
        lowkey ty = intHintOrDefault(hint)
        bet cat2(payload, ty), ty
    }
    fr str.slaps(h, "float") {
        lowkey ty = floatHintOrDefault(hint)
        bet cat2(payload, ty), ty
    }
    fr str.slaps(h, "bool") {
        bet payload, "bool"
    }
    fr str.slaps(h, "str") {
        bet payload, "str"
    }
    fr str.slaps(h, "byte") {
        bet cat2(payload, "u8"), "u8"
    }
    fr str.slaps(h, "unary") && str.slaps(payload, "neg") {
        lowkey inner = kidAt(p, idx, 0)
        lowkey ih = firstWord(lab(p, inner))
        fr str.slaps(ih, "int") {
            lowkey ty = intHintOrDefault(hint)
            bet cat3("-", afterFirst(lab(p, inner)), ty), ty
        }
        fr str.slaps(ih, "float") {
            lowkey ty = floatHintOrDefault(hint)
            bet cat3("-", afterFirst(lab(p, inner)), ty), ty
        }
    }
    lcFail(c)
    bet "0i64", "i64"
}

finna cat3(a: str, b: str, cc: str) -> str {
    bet cat2(cat2(a, b), cc)
}

// `name(a)` / `name(a, b)` — rvalue/terminator text builders.
finna call1(name: str, a: str) -> str {
    lowkey sb = sbNew()
    sb.add(name)
    sb.add("(")
    sb.add(a)
    sb.add(")")
    bet sb.finish()
}

finna call2(name: str, a: str, b: str) -> str {
    lowkey sb = sbNew()
    sb.add(name)
    sb.add("(")
    sb.add(a)
    sb.add(", ")
    sb.add(b)
    sb.add(")")
    bet sb.finish()
}

// Type-directed value print (mirror lower_print_value) for the scalar subset.
finna lowerPrintValue(c: LowerCtx, opStr: str, ty: str) {
    fr isSignedIntTy(ty) {
        lowkey v = coerceInt(c, opStr, ty, "i64")
        emitPrintNum(c, "extern \"C\" fn bet_print_i64(i64) -> void", "bet_print_i64", v)
    } naw fr isUnsignedIntTy(ty) {
        lowkey v = coerceInt(c, opStr, ty, "u64")
        emitPrintNum(c, "extern \"C\" fn bet_print_u64(u64) -> void", "bet_print_u64", v)
    } naw fr str.slaps(ty, "f64") {
        emitPrintNum(c, "extern \"C\" fn bet_print_f64(f64) -> void", "bet_print_f64", opStr)
    } naw fr str.slaps(ty, "f32") {
        lowkey t = newLocal(c, "f64")
        lowkey sb = sbNew()
        sb.add("cast.fresize(")
        sb.add(opStr)
        sb.add(" as f64)")
        emitAssign(c, t, sb.finish())
        emitPrintNum(c, "extern \"C\" fn bet_print_f64(f64) -> void", "bet_print_f64", reg(t))
    } naw fr str.slaps(ty, "str") {
        emitPrintOperand(c, opStr)
    } naw fr str.slaps(ty, "bool") {
        lowerPrintBool(c, opStr)
    } naw fr isYikesTy(ty) {
        // A yikes prints as its message (field 1).
        emitPrintOperand(c, cat2(opStr, ".field(1)"))
    } naw {
        lcFail(c)
    }
}

// emit_print_num: call_extern @name(valStr) after ensuring its extern decl (mirror emit_print_num).
finna emitPrintNum(c: LowerCtx, externLine: str, name: str, valStr: str) {
    getExtern(c, externLine)
    lowkey res = newLocal(c, "void")
    lowkey sb = sbNew()
    sb.add(reg(res))
    sb.add(" = call_extern @")
    sb.add(name)
    sb.add("(")
    sb.add(valStr)
    sb.add(")")
    emitStmt(c, sb.finish())
}

// Lower a single printed argument expression (mirror lower_print_expr).
finna lowerPrintExpr(c: LowerCtx, p: P, valIdx: int) {
    fr str.slaps(firstWord(lab(p, valIdx)), "ghosted") {
        emitPrint(c, "ghosted")
    } naw {
        lowkey op, ty = lowerExpr(c, p, valIdx, "")
        lowerPrintValue(c, op, ty)
    }
}

// The value expression of the nth argument under an `args` wrapper.
finna argValue(p: P, argsIdx: int, n: int) -> int {
    bet kidAt(p, kidAt(p, argsIdx, n), 0)
}

// Lower a `spill.it` / `spill.f` call (mirror lower_spill).
finna lowerSpill(c: LowerCtx, p: P, methodIdx: int) {
    lowkey method = afterFirst(lab(p, methodIdx))
    lowkey argsIdx = findKid(p, methodIdx, "args")
    fr argsIdx < 0 {
        lcFail(c)
    } naw fr str.slaps(method, "it") {
        lowkey v = argValue(p, argsIdx, 0)
        fr str.slaps(firstWord(lab(p, v)), "str") {
            emitPrint(c, cat2(unquote(afterFirst(lab(p, v))), "\n"))
        } naw {
            lowerPrintExpr(c, p, v)
            emitPrint(c, "\n")
        }
    } naw fr str.slaps(method, "f") {
        lowkey fmtNode = argValue(p, argsIdx, 0)
        fr !str.slaps(firstWord(lab(p, fmtNode)), "str") {
            lcFail(c)
        } naw {
            lowkey segs = splitFormat(unquote(afterFirst(lab(p, fmtNode))))
            lowkey hole = 1
            lowkey nS = segs.gang() as int
            lowkey i = 0
            vibin i < nS {
                lowkey seg = segs[i]
                fr seg.isHole {
                    lowerPrintExpr(c, p, argValue(p, argsIdx, hole))
                    hole = hole + 1
                } naw fr str.len(seg.text) > 0 {
                    emitPrint(c, seg.text)
                }
                i = i + 1
            }
        }
    } naw {
        lcFail(c)
    }
}

// Lower an expr-stmt (SUPPORTED: a spill.it/spill.f call).
finna lowerExprStmt(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey e = kidAt(p, stmtIdx, 0)
    lowkey isSpill = cap
    fr str.slaps(firstWord(lab(p, e)), "method") {
        lowkey recv = findKid(p, e, "receiver")
        fr recv >= 0 && kidCount(p, recv) > 0 {
            fr str.slaps(lab(p, kidAt(p, recv, 0)), "name spill") {
                isSpill = nocap
            }
        }
    }
    fr isSpill {
        lowerSpill(c, p, e)
    } naw fr str.slaps(firstWord(lab(p, e)), "call") {
        lowkey dop, dty = lowerCall(c, p, e)
    } naw fr str.slaps(firstWord(lab(p, e)), "method") {
        // A non-spill method statement (e.g. `xs.stack(10)`): lower and discard its result.
        lowkey mop, mty = lowerMethodCall(c, p, e)
    } naw {
        lcFail(c)
    }
}

// `lowkey a = expr` — single target (mirror lower_var).
finna lowerVar(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey targets = afterFirst(afterFirst(lab(p, stmtIdx)))
    fr hasSpace(targets) {
        lowerVarMulti(c, p, stmtIdx, targets)
    } naw {
        lowkey tw = findKid(p, stmtIdx, "type")
        lowkey declTy = ""
        fr tw >= 0 {
            declTy = mapTypeNode(c, p, kidAt(p, tw, 0))
        }
        lowkey vw = findKid(p, stmtIdx, "values")
        lowkey op, vty = lowerExpr(c, p, kidAt(p, vw, 0), declTy)
        lowkey ty = vty
        fr !isEmpty(declTy) { ty = declTy }
        lowkey l = newLocal(c, ty)
        emitAssign(c, l, op)
        bindLocal(c, targets, l)
    }
}

// `lowkey a, b = tupleExpr` — destructure a tuple-returning rvalue into one local per name
// (mirror the multi-binding path: bind each name to `tmp.field(i)`).
finna lowerVarMulti(c: LowerCtx, p: P, stmtIdx: int, targets: str) {
    lowkey vw = findKid(p, stmtIdx, "values")
    lowkey op, vty = lowerExpr(c, p, kidAt(p, vw, 0), "")
    fr !isTupleTy(vty) || !isReg(op) {
        lcFail(c)
    } naw {
        lowkey names = splitSpaces(targets)
        lowkey nn = names.gang() as int
        lowkey i = 0
        vibin i < nn {
            lowkey compTy = tupleComponentAt(vty, i)
            lowkey l = newLocal(c, compTy)
            lowkey sb = sbNew()
            sb.add(op)
            sb.add(".field(")
            sb.add(itoa(i))
            sb.add(")")
            emitAssign(c, l, sb.finish())
            bindLocal(c, names[i], l)
            i = i + 1
        }
    }
}

// `facts NAME [: T] = literal` — compile-time-evaluated, inlined at use (mirror eval_const).
finna lowerConst(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey nm = afterFirst(afterFirst(lab(p, stmtIdx)))
    fr hasSpace(nm) {
        lcFail(c)
    } naw {
        lowkey tw = findKid(p, stmtIdx, "type")
        lowkey hintTy = ""
        fr tw >= 0 {
            hintTy = mapTypeNode(c, p, kidAt(p, tw, 0))
        }
        lowkey vw = findKid(p, stmtIdx, "value")
        lowkey op, ty = constLiteral(c, p, kidAt(p, vw, 0), hintTy)
        addConst(c, nm, op, ty)
    }
}

// `target op= expr` / `target = expr` for a single local target (mirror lower_assign).
finna lowerAssign(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey opTag = afterFirst(lab(p, stmtIdx))
    lowkey tw = kidAt(p, stmtIdx, 0)
    lowkey vw = kidAt(p, stmtIdx, 1)
    fr kidCount(p, tw) != 1 || kidCount(p, vw) != 1 {
        lcFail(c)
    } naw fr str.slaps(firstWord(lab(p, kidAt(p, tw, 0))), "field") {
        // `base.field = expr` — assign through a field place (compound field-assign deferred).
        fr !str.slaps(opTag, "eq") {
            lcFail(c)
        } naw {
            lowkey place, fty = fieldAccessStr(c, p, kidAt(p, tw, 0))
            fr lcOk(c) {
                lowkey val, vty = lowerExpr(c, p, kidAt(p, vw, 0), fty)
                emitPlaceAssign(c, place, val)
            }
        }
    } naw {
        lowkey te = kidAt(p, tw, 0)
        lowkey lid = 0 - 1
        fr str.slaps(firstWord(lab(p, te)), "name") && kidCount(p, te) == 0 {
            lid = lookupLocal(c, afterFirst(lab(p, te)))
        }
        fr lid < 0 {
            lcFail(c)
        } naw fr str.slaps(opTag, "eq") {
            lowkey val, vty = lowerExpr(c, p, kidAt(p, vw, 0), c.localTypes[lid])
            emitAssign(c, lid, val)
        } naw {
            lowkey irop = compoundBinop(opTag)
            lowkey pty = c.localTypes[lid]
            lowkey rhs, rty = lowerExpr(c, p, kidAt(p, vw, 0), pty)
            lowkey mode = arithMode(pty, irop)
            lowkey sb = sbNew()
            sb.add(irop)
            sb.add(".")
            sb.add(mode)
            sb.add("(")
            sb.add(reg(lid))
            sb.add(", ")
            sb.add(rhs)
            sb.add(")")
            emitAssign(c, lid, sb.finish())
        }
    }
}

// `bet` — zero values (void) or a single value (mirror lower_bet); multi-value is deferred.
finna lowerBet(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey nv = kidCount(p, stmtIdx)
    fr nv == 0 {
        termRet(c)
    } naw fr nv == 1 {
        lowkey op, ty = lowerExpr(c, p, kidAt(p, stmtIdx, 0), c.curRet[0])
        termRetVal(c, op)
    } naw {
        // Multi-value return: each value hinted by its tuple component type.
        lowkey ret = c.curRet[0]
        lowkey ops = vec.new[str]()
        lowkey i = 0
        vibin i < nv {
            lowkey op, ty = lowerExpr(c, p, kidAt(p, stmtIdx, i), tupleComponentAt(ret, i))
            ops.stack(op)
            i = i + 1
        }
        termRetMulti(c, ops)
    }
}

// `bounce y` — early-return-on-error (mirror lower_bounce): if `y.present`, return zeros for the
// leading slots plus `y`; else fall through.
finna lowerBounce(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey op, ty = lowerExpr(c, p, kidAt(p, stmtIdx, 0), "")
    lowkey ret = c.curRet[0]
    fr !isYikesTy(ty) || !isPlace(op) || !isTupleTy(ret) {
        lcFail(c)
    } naw {
        lowkey present = cat2(op, ".field(0)")
        lowkey ncomp = tupleArity(ret)
        lowkey retOps = vec.new[str]()
        lowkey i = 0
        vibin i < ncomp - 1 {
            retOps.stack(zeroOperand(c, tupleComponentAt(ret, i)))
            i = i + 1
        }
        retOps.stack(op)
        lowkey condEnd = curId(c)
        lowkey merge = reserveBlock(c)
        lowkey thenBb = newBlock(c)
        termRetMulti(c, retOps)
        setBranch(c, condEnd, present, thenBb, merge)
        selectBlock(c, merge)
    }
}

// Print a bool by branching: true edge prints `nocap`, false edge `cap` (mirror lower_print_bool).
finna lowerPrintBool(c: LowerCtx, cond: str) {
    lowkey condEnd = curId(c)
    lowkey merge = reserveBlock(c)
    lowkey thenBb = newBlock(c)
    emitPrint(c, "nocap")
    termGoto(c, merge)
    lowkey elseBb = newBlock(c)
    emitPrint(c, "cap")
    termGoto(c, merge)
    setBranch(c, condEnd, cond, thenBb, elseBb)
    selectBlock(c, merge)
}

// Short-circuit `&&`/`||` lower to control flow (mirror lower_short_circuit).
finna lowerShortCircuit(c: LowerCtx, p: P, idx: int, opTag: str) -> (str, str) {
    lowkey res = newLocal(c, "bool")
    lowkey lo, lty = lowerExpr(c, p, kidAt(p, idx, 0), "bool")
    lowkey lhsEnd = curId(c)
    lowkey rhsBb = newBlock(c)
    lowkey ro, rty = lowerExpr(c, p, kidAt(p, idx, 1), "bool")
    lowkey rhsEnd = curId(c)
    emitAssign(c, res, ro)
    lowkey shortBb = newBlock(c)
    lowkey shortVal = "false"
    fr str.slaps(opTag, "or") { shortVal = "true" }
    emitAssign(c, res, shortVal)
    lowkey merge = newBlock(c)
    setGoto(c, rhsEnd, merge)
    setGoto(c, shortBb, merge)
    fr str.slaps(opTag, "and") {
        setBranch(c, lhsEnd, lo, rhsBb, shortBb)
    } naw {
        setBranch(c, lhsEnd, lo, shortBb, rhsBb)
    }
    selectBlock(c, merge)
    bet reg(res), "bool"
}

// `fr cond { .. } naw fr .. naw { .. }` (mirror lower_fr + emit_if_chain).
finna lowerFr(c: LowerCtx, p: P, frIdx: int) {
    lowkey conds = vec.new[int]()
    lowkey bodies = vec.new[int]()
    conds.stack(kidAt(p, frIdx, 0))
    bodies.stack(kidAt(p, frIdx, 1))
    lowkey elseBody = 0 - 1
    lowkey nk = kidCount(p, frIdx)
    lowkey i = 2
    vibin i < nk {
        lowkey k = kidAt(p, frIdx, i)
        fr str.slaps(lab(p, k), "elif") {
            conds.stack(kidAt(p, k, 0))
            bodies.stack(kidAt(p, k, 1))
        } naw fr str.slaps(lab(p, k), "else") {
            elseBody = kidAt(p, k, 0)
        }
        i = i + 1
    }
    lowkey merge = reserveBlock(c)
    emitIfChain(c, p, conds, bodies, elseBody, 0, merge)
    selectBlock(c, merge)
}

finna emitIfChain(c: LowerCtx, p: P, conds: vec[int], bodies: vec[int], elseBody: int, armIdx: int, merge: int) {
    lowkey cndOp, cty = lowerExpr(c, p, conds[armIdx], "bool")
    lowkey condEnd = curId(c)
    lowkey thenBb = newBlock(c)
    lowerBlock(c, p, bodies[armIdx])
    termGoto(c, merge)
    lowkey elseBb = newBlock(c)
    lowkey narms = conds.gang() as int
    fr armIdx + 1 < narms {
        emitIfChain(c, p, conds, bodies, elseBody, armIdx + 1, merge)
    } naw fr elseBody >= 0 {
        lowerBlock(c, p, elseBody)
        termGoto(c, merge)
    } naw {
        termGoto(c, merge)
    }
    setBranch(c, condEnd, cndOp, thenBb, elseBb)
}

// `vibin cond { .. }` (mirror lower_vibin). dip/skip in the body are not yet lowered.
finna lowerVibin(c: LowerCtx, p: P, vibinIdx: int) {
    lowkey pre = curId(c)
    lowkey header = reserveBlock(c)
    setGoto(c, pre, header)
    selectBlock(c, header)
    lowkey cndOp, cty = lowerExpr(c, p, kidAt(p, vibinIdx, 0), "bool")
    lowkey headerEnd = curId(c)
    lowkey bodyBb = newBlock(c)
    lowkey exit = reserveBlock(c)
    setBranch(c, headerEnd, cndOp, bodyBb, exit)
    selectBlock(c, bodyBb)
    pushLoop(c, header, exit)
    lowerBlock(c, p, kidAt(p, vibinIdx, 1))
    popLoop(c)
    termGoto(c, header)
    selectBlock(c, exit)
}

// `vibe scrut { Variant(binds) { .. } .. naw { .. } }` (mirror lower_vibe): discriminant + switch;
// each arm downcasts + binds its payload; the merge block is a reserved landing pad.
finna lowerVibe(c: LowerCtx, p: P, vibeIdx: int) {
    lowkey sop, sty = lowerExpr(c, p, kidAt(p, vibeIdx, 0), "")
    // Auto-deref a `ref Sum` scrutinee (as produced by `holla`/`trust` over a sum crib).
    lowkey sumName = sty
    lowkey scrut = sop
    fr isRefTy(sty) {
        sumName = refElem(sty)
        scrut = cat2(sop, ".deref")
    }
    fr !isSum(c, sumName) || !isPlace(sop) {
        lcFail(c)
    } naw {
        lowkey disc = newLocal(c, "u32")
        lowkey db = sbNew()
        db.add("discriminant(")
        db.add(scrut)
        db.add(")")
        emitAssign(c, disc, db.finish())
        lowkey switchBlock = curId(c)
        lowkey merge = reserveBlock(c)
        lowkey caseVals = vec.new[int]()
        lowkey caseBbs = vec.new[int]()
        lowkey defaultBody = 0 - 1
        lowkey nk = kidCount(p, vibeIdx)
        lowkey i = 1
        vibin i < nk && lcOk(c) {
            lowkey arm = kidAt(p, vibeIdx, i)
            fr str.slaps(firstWord(lab(p, arm)), "default") {
                defaultBody = kidAt(p, arm, 0)
            } naw {
                // "arm Variant b0 b1 .." — first word is the variant, the rest are bindings.
                lowkey spec = splitSpaces(afterFirst(lab(p, arm)))
                lowkey vname = spec[0]
                lowkey vi = lookupVariant(c, vname)
                fr vi < 0 {
                    lcFail(c)
                } naw {
                    lowkey armBb = newBlock(c)
                    lowkey payloadCsv = c.variantPayload[vi]
                    lowkey nb = (spec.gang() as int) - 1
                    lowkey j = 0
                    vibin j < nb {
                        lowkey fty = csvAt(payloadCsv, j)
                        lowkey l = newLocal(c, fty)
                        lowkey fb = sbNew()
                        fb.add(scrut)
                        fb.add(".downcast(")
                        fb.add(itoa(c.variantIdx[vi]))
                        fb.add(").field(")
                        fb.add(itoa(j))
                        fb.add(")")
                        emitAssign(c, l, fb.finish())
                        bindLocal(c, spec[j + 1], l)
                        j = j + 1
                    }
                    lowerBlock(c, p, findKid(p, arm, "block"))
                    termGoto(c, merge)
                    caseVals.stack(c.variantIdx[vi])
                    caseBbs.stack(armBb)
                }
            }
            i = i + 1
        }
        lowkey defaultBb = newBlock(c)
        fr defaultBody >= 0 {
            lowerBlock(c, p, defaultBody)
            termGoto(c, merge)
        } naw {
            termUnreachable(c)
        }
        setSwitch(c, switchBlock, reg(disc), caseVals, caseBbs, defaultBb)
        selectBlock(c, merge)
    }
}

// `squad x in xs { .. }` over a fixed array — a counter loop (mirror lower_squad). The
// increment block is the `skip` target and the exit block is the `dip` target. vec[T]
// iterables are deferred (sentinel).
finna lowerSquad(c: LowerCtx, p: P, squadIdx: int) {
    lowkey var = afterFirst(lab(p, squadIdx))
    lowkey iop, ity = lowerExpr(c, p, kidAt(p, squadIdx, 0), "")
    fr isVecTy(ity) {
        lowerVecSquad(c, p, squadIdx, iop, vecElem(ity), var)
    } naw fr !isArrayTy(ity) || !isReg(iop) {
        lcFail(c)
    } naw {
        lowkey elem = arrayElem(ity)
        lowkey nStr = arrayLenStr(ity)
        lowkey ctr = newLocal(c, "i64")
        emitAssign(c, ctr, "0i64")
        lowkey pre = curId(c)
        lowkey header = reserveBlock(c)
        setGoto(c, pre, header)
        selectBlock(c, header)
        lowkey cond = newLocal(c, "bool")
        lowkey csb = sbNew()
        csb.add("lt.na(")
        csb.add(reg(ctr))
        csb.add(", ")
        csb.add(nStr)
        csb.add("i64)")
        emitAssign(c, cond, csb.finish())
        lowkey headerEnd = curId(c)
        lowkey bodyBb = newBlock(c)
        lowkey exit = reserveBlock(c)
        setBranch(c, headerEnd, reg(cond), bodyBb, exit)
        selectBlock(c, bodyBb)
        lowkey elemLocal = newLocal(c, elem)
        lowkey esb = sbNew()
        esb.add(iop)
        esb.add(".index(")
        esb.add(reg(ctr))
        esb.add(")")
        emitAssign(c, elemLocal, esb.finish())
        bindLocal(c, var, elemLocal)
        lowkey incr = reserveBlock(c)
        pushLoop(c, incr, exit)
        lowerBlock(c, p, kidAt(p, squadIdx, 1))
        popLoop(c)
        termGoto(c, incr)
        selectBlock(c, incr)
        lowkey isb = sbNew()
        isb.add("add.wrap(")
        isb.add(reg(ctr))
        isb.add(", 1i64)")
        emitAssign(c, ctr, isb.finish())
        termGoto(c, header)
        selectBlock(c, exit)
    }
}

// `crib NAME [: T[N]]` — a function-local arena (mirror lower_crib_decl). A typed slab keeps its
// element/capacity; a bare `crib NAME` is an untyped bump crib (`crib void`). `%l = crib_new[E; N]`.
finna lowerCribDecl(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey elem, capa = cribDeclElemAndCap(c, p, stmtIdx)
    lowkey l = newLocal(c, cribTyStr(elem))
    lowkey sb = sbNew()
    sb.add("crib_new[")
    sb.add(elem)
    sb.add("; ")
    sb.add(capa)
    sb.add("]")
    emitAssign(c, l, sb.finish())
    bindLocal(c, afterFirst(afterFirst(lab(p, stmtIdx))), l)
}

// `holla BIND = TAG in CRIB { live } ghosted { }` — checked tag resolution (mirror lower_holla).
// The merge block is reserved first (so it prints before the arms); the check-block terminator is
// a `holla_check(tag, crib, resolvedRef) -> live else ghosted`.
finna lowerHolla(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey binding = afterFirst(lab(p, stmtIdx))
    lowkey tagW = findKid(p, stmtIdx, "tag")
    lowkey cribW = findKid(p, stmtIdx, "crib")
    lowkey liveW = findKid(p, stmtIdx, "live")
    lowkey ghostedW = findKid(p, stmtIdx, "ghosted")
    lowkey tagOp, tagTy = lowerExpr(c, p, kidAt(p, tagW, 0), "")
    lowkey cribOp, cribTy = lowerExpr(c, p, kidAt(p, cribW, 0), "")
    fr !isCribTy(cribTy) {
        lcFail(c)
    } naw {
        lowkey resolved = newLocal(c, refTyStr(cribElem(cribTy)))
        lowkey checkBlock = curId(c)
        lowkey merge = reserveBlock(c)
        lowkey liveBb = newBlock(c)
        bindLocal(c, binding, resolved)
        lowerBlock(c, p, findKid(p, liveW, "block"))
        termGoto(c, merge)
        lowkey ghostedBb = newBlock(c)
        lowerBlock(c, p, findKid(p, ghostedW, "block"))
        termGoto(c, merge)
        setHolla(c, checkBlock, tagOp, cribOp, reg(resolved), liveBb, ghostedBb)
        selectBlock(c, merge)
    }
}

// `holla_check(tag, crib, resolved) -> bbLive else bbGhosted` on a reserved check block.
finna setHolla(c: LowerCtx, from: int, tagOp: str, cribOp: str, resolved: str, liveBb: int, ghostedBb: int) {
    lowkey sb = sbNew()
    sb.add("holla_check(")
    sb.add(tagOp)
    sb.add(", ")
    sb.add(cribOp)
    sb.add(", ")
    sb.add(resolved)
    sb.add(") -> bb")
    sb.add(itoa(liveBb))
    sb.add(" else bb")
    sb.add(itoa(ghostedBb))
    setTerm(c, from, sb.finish())
}

// `evict CRIB` — free an arena in O(1) (mirror lower_stmt Evict): a plain `evict %crib` statement.
finna lowerEvict(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey cribOp, cribTy = lowerExpr(c, p, kidAt(p, stmtIdx, 0), "")
    fr !isCribTy(cribTy) {
        lcFail(c)
    } naw {
        emitStmt(c, cat2("evict ", cribOp))
    }
}

// `slide worker()` — spawn a concurrent task via `bet_slide` (mirror lower_slide). Only a bare
// call of a known, no-arg named function lowers today: materialize its code pointer `@NAME`, bitcast
// to `rawptr`, and pass it as both the entry and the (unused) task argument. The `u64` TaskHandle is
// discarded. Anything else (indirect/generic/receiver call, or arguments) sentinels.
finna lowerSlide(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey callIdx = kidAt(p, stmtIdx, 0)
    fr !str.slaps(firstWord(lab(p, callIdx)), "call") {
        lcFail(c)
    } naw {
        lowkey calleeW = findKid(p, callIdx, "callee")
        lowkey calleeE = kidAt(p, calleeW, 0)
        lowkey argsW = findKid(p, callIdx, "args")
        lowkey nm = afterFirst(lab(p, calleeE))
        lowkey fi = lookupFn(c, nm)
        fr !str.slaps(firstWord(lab(p, calleeE)), "name") || (argsW >= 0 && kidCount(p, argsW) > 0) || fi < 0 {
            lcFail(c)
        } naw {
            // The worker's code pointer, materialized then bitcast to a raw pointer for the ABI.
            lowkey fnref = newLocal(c, fnPtrTypeOf(c, fi))
            emitAssign(c, fnref, cat2("@", nm))
            lowkey entry = newLocal(c, "rawptr")
            emitAssign(c, entry, cat3("cast.bitcast(", reg(fnref), " as rawptr)"))
            // bet_slide(entry, arg) -> TaskHandle (u64); reuse the entry pointer as the unused arg.
            getExtern(c, "extern \"C\" fn bet_slide(rawptr, rawptr) -> u64")
            lowkey sargs = vec.new[str]()
            sargs.stack(reg(entry))
            sargs.stack(reg(entry))
            lowkey handle = emitExternCall(c, "u64", "bet_slide", sargs)
        }
    }
}

// Lower one statement (mirror lower_stmt) — the scalar subset.
finna lowerStmt(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey h = firstWord(lab(p, stmtIdx))
    fr str.slaps(h, "expr-stmt") {
        lowerExprStmt(c, p, stmtIdx)
    } naw fr str.slaps(h, "var") {
        lowerVar(c, p, stmtIdx)
    } naw fr str.slaps(h, "const") {
        lowerConst(c, p, stmtIdx)
    } naw fr str.slaps(h, "assign") {
        lowerAssign(c, p, stmtIdx)
    } naw fr str.slaps(h, "bet") {
        lowerBet(c, p, stmtIdx)
    } naw fr str.slaps(h, "bounce") {
        lowerBounce(c, p, stmtIdx)
    } naw fr str.slaps(h, "fr") {
        lowerFr(c, p, stmtIdx)
    } naw fr str.slaps(h, "vibin") {
        lowerVibin(c, p, stmtIdx)
    } naw fr str.slaps(h, "vibe") {
        lowerVibe(c, p, stmtIdx)
    } naw fr str.slaps(h, "squad") {
        lowerSquad(c, p, stmtIdx)
    } naw fr str.slaps(h, "crib") {
        lowerCribDecl(c, p, stmtIdx)
    } naw fr str.slaps(h, "holla") {
        lowerHolla(c, p, stmtIdx)
    } naw fr str.slaps(h, "evict") {
        lowerEvict(c, p, stmtIdx)
    } naw fr str.slaps(h, "slide") {
        lowerSlide(c, p, stmtIdx)
    } naw fr str.slaps(h, "dip") {
        fr inLoop(c) { termGoto(c, loopExitTop(c)) } naw { lcFail(c) }
    } naw fr str.slaps(h, "skip") {
        fr inLoop(c) { termGoto(c, loopIncrTop(c)) } naw { lcFail(c) }
    } naw {
        lcFail(c)
    }
}

finna lowerBlock(c: LowerCtx, p: P, blockIdx: int) {
    lowkey n = kidCount(p, blockIdx)
    lowkey i = 0
    vibin i < n && lcOk(c) && !lcDone(c) {
        lowerStmt(c, p, kidAt(p, blockIdx, i))
        i = i + 1
    }
}

// The comma-joined .mir param types of a `params` node.
finna collectParamTypes(c: LowerCtx, p: P, pw: int) -> str {
    lowkey sb = sbNew()
    lowkey n = kidCount(p, pw)
    lowkey i = 0
    vibin i < n {
        fr i > 0 { sb.add(",") }
        sb.add(mapTypeNode(c, p, kidAt(p, kidAt(p, pw, i), 0)))
        i = i + 1
    }
    bet sb.finish()
}

// The .mir return-type string of a function ("void" / a single type; multi-return deferred).
finna collectRetType(c: LowerCtx, p: P, funcIdx: int) -> str {
    fr findKid(p, funcIdx, "ret none") >= 0 { bet "void" }
    lowkey rs = findKid(p, funcIdx, "ret single")
    fr rs >= 0 { bet mapTypeNode(c, p, kidAt(p, rs, 0)) }
    lowkey rm = findKid(p, funcIdx, "ret multi")
    fr rm >= 0 {
        lowkey sb = sbNew()
        sb.add("(")
        lowkey nk = kidCount(p, rm)
        lowkey i = 0
        vibin i < nk {
            fr i > 0 { sb.add(", ") }
            sb.add(mapTypeNode(c, p, kidAt(p, rm, i)))
            i = i + 1
        }
        sb.add(")")
        bet sb.finish()
    }
    lcFail(c)
    bet "void"
}

// Pre-register a function's signature so calls resolve regardless of declaration order (mirror the
// collect pass). Generic / receiver / non-scalar signatures defer the whole program.
finna registerFn(c: LowerCtx, p: P, funcIdx: int) {
    lowkey name = afterFirst(afterFirst(lab(p, funcIdx)))
    fr isGenericDecl(p, funcIdx) {
        // A generic `finna f[T](..)` — store for on-demand monomorphization; no concrete sig here.
        c.genFnNames.stack(name)
        c.genFnIdx.stack(funcIdx)
    } naw {
        // A receiver method's receiver is a leading parameter (mirror has_receiver).
        lowkey pw = findKid(p, funcIdx, "params")
        lowkey csv = collectParamTypes(c, p, pw)
        lowkey recvW = findKidWord(p, funcIdx, "receiver")
        fr recvW >= 0 {
            lowkey rty = mapTypeNode(c, p, kidAt(p, recvW, 0))
            fr isEmpty(csv) { csv = rty } naw { csv = cat3(rty, ",", csv) }
        }
        c.fnNames.stack(name)
        c.fnParamCsv.stack(csv)
        c.fnRet.stack(collectRetType(c, p, funcIdx))
    }
}

finna collectFns(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n {
        lowkey it = kidAt(p, root, i)
        fr str.slaps(firstWord(lab(p, it)), "func") {
            registerFn(c, p, it)
        }
        i = i + 1
    }
}

// Register an `extern "C" finna NAME(..)` FFI import: its signature (for call-arg hints) and the
// `extern "C" fn NAME(t, ..) -> R` decl line (added to the module on first use, in use order).
finna registerExtern(c: LowerCtx, p: P, externIdx: int) {
    lowkey name = afterFirst(afterFirst(lab(p, externIdx)))
    lowkey pw = findKid(p, externIdx, "params")
    lowkey ret = collectRetType(c, p, externIdx)
    lowkey decl = sbNew()
    decl.add("extern \"C\" fn ")
    decl.add(name)
    decl.add("(")
    lowkey np = kidCount(p, pw)
    lowkey j = 0
    vibin j < np {
        fr j > 0 { decl.add(", ") }
        decl.add(mapTypeNode(c, p, kidAt(p, kidAt(p, pw, j), 0)))
        j = j + 1
    }
    decl.add(") -> ")
    decl.add(ret)
    c.externFnNames.stack(name)
    c.externFnParamCsv.stack(collectParamTypes(c, p, pw))
    c.externFnRet.stack(ret)
    c.externFnDecl.stack(decl.finish())
}

finna collectExterns(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n {
        lowkey it = kidAt(p, root, i)
        fr str.slaps(firstWord(lab(p, it)), "extern") {
            registerExtern(c, p, it)
        }
        i = i + 1
    }
}

finna lookupExtern(c: LowerCtx, name: str) -> int {
    lowkey n = c.externFnNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.externFnNames[i], name) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

// Index of the module-level crib arena named `name`, or -1.
finna lookupCribGlobal(c: LowerCtx, name: str) -> int {
    lowkey n = c.cribGlobalNames.gang() as int
    lowkey i = 0
    vibin i < n {
        fr str.slaps(c.cribGlobalNames[i], name) { bet i }
        i = i + 1
    }
    bet 0 - 1
}

// The (element type, capacity text) of a `crib` decl node (mirror crib_elem_and_cap): a `T[N]`
// typed slab, a bare `T` typed crib (cap 0), or an untyped bump crib (`void`, cap 0).
finna cribDeclElemAndCap(c: LowerCtx, p: P, cribIdx: int) -> (str, str) {
    fr kidCount(p, cribIdx) == 0 {
        bet "void", "0"
    }
    lowkey tnode = kidAt(p, cribIdx, 0)
    fr str.slaps(firstWord(lab(p, tnode)), "array") {
        bet mapTypeNode(c, p, kidAt(p, tnode, 0)), afterFirst(lab(p, tnode))
    }
    bet mapTypeNode(c, p, tnode), "0"
}

// Prescan: register a module-level `crib NAME: T[N]` arena so any function can reference it and
// so its `crib @NAME: T[N]` decl prints in the module header (mirror lower_items pass 1).
finna registerCribGlobal(c: LowerCtx, p: P, cribIdx: int) {
    lowkey elem, capa = cribDeclElemAndCap(c, p, cribIdx)
    c.cribGlobalNames.stack(afterFirst(afterFirst(lab(p, cribIdx))))
    c.cribGlobalElems.stack(elem)
    c.cribGlobalCaps.stack(capa)
}

finna collectCribGlobals(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n && lcOk(c) {
        lowkey it = kidAt(p, root, i)
        fr str.slaps(firstWord(lab(p, it)), "crib") {
            registerCribGlobal(c, p, it)
        }
        i = i + 1
    }
}

// Evaluate a top-level `const` item into the global scope (mirror lowerConst, global storage).
finna lowerGlobalConst(c: LowerCtx, p: P, stmtIdx: int) {
    lowkey nm = afterFirst(afterFirst(lab(p, stmtIdx)))
    fr hasSpace(nm) {
        lcFail(c)
    } naw {
        lowkey tw = findKid(p, stmtIdx, "type")
        lowkey hintTy = ""
        fr tw >= 0 {
            hintTy = mapTypeNode(c, p, kidAt(p, tw, 0))
        }
        lowkey vw = findKid(p, stmtIdx, "value")
        lowkey op, ty = constLiteral(c, p, kidAt(p, vw, 0), hintTy)
        addGlobalConst(c, nm, op, ty)
    }
}

// True if a `drip`/`moods` item is generic. (A generic decl's node is labeled `generics T ..`, so
// it must be found by first-word match — the empty non-generic node is labeled exactly `generics`.)
finna isGenericDecl(p: P, declIdx: int) -> bool {
    bet isGenericDeclG(p, declIdx)
}

// Prescan pass 1: register a struct's name so any field/variant type can resolve it. A generic
// `drip S[T] { .. }` is stored for on-demand monomorphization instead (no concrete decl here).
finna registerStructName(c: LowerCtx, p: P, dripIdx: int) {
    fr isGenericDecl(p, dripIdx) {
        c.genStructNames.stack(afterFirst(afterFirst(lab(p, dripIdx))))
        c.genStructIdx.stack(dripIdx)
    } naw {
        c.structNames.stack(afterFirst(afterFirst(lab(p, dripIdx))))
    }
}

// Prescan pass 2: render a struct's `struct NAME { .. }` decl and record its fields (text.rs
// struct_def). Runs after all names are known, so struct/sum field types resolve either way.
finna buildStructDef(c: LowerCtx, p: P, dripIdx: int) {
    fr !isGenericDecl(p, dripIdx) {
        lowkey name = afterFirst(afterFirst(lab(p, dripIdx)))
        lowkey sb = sbNew()
        sb.add("struct ")
        sb.add(name)
        sb.add(" {")
        lowkey nk = kidCount(p, dripIdx)
        lowkey pos = 0
        lowkey i = 0
        vibin i < nk {
            lowkey k = kidAt(p, dripIdx, i)
            fr str.slaps(firstWord(lab(p, k)), "field") {
                lowkey visName = afterFirst(lab(p, k))
                lowkey vis = firstWord(visName)
                // An unspecified field visibility defaults to private (`hush`).
                fr str.slaps(vis, "default") { vis = "hush" }
                lowkey fname = afterFirst(visName)
                lowkey fty = mapTypeNode(c, p, kidAt(p, k, 0))
                fr pos == 0 { sb.add(" ") } naw { sb.add(", ") }
                sb.add(vis)
                sb.add(" ")
                sb.add(fname)
                sb.add(": ")
                sb.add(fty)
                addField(c, name, fname, fty, pos)
                pos = pos + 1
            }
            i = i + 1
        }
        sb.add(" }")
        c.structDecls.stack(sb.finish())
    }
}

// Prescan pass 1: register a sum's name.
finna registerSumName(c: LowerCtx, p: P, moodsIdx: int) {
    fr isGenericDecl(p, moodsIdx) {
        lcFail(c)
    } naw {
        c.sumNames.stack(afterFirst(afterFirst(lab(p, moodsIdx))))
    }
}

// Prescan pass 2: render a sum's `sum NAME { V(t,..), .. }` decl and record its variants (text.rs
// sum_def). Payload types are kept as a "," CSV (construction hints) plus a ", " list (the decl).
finna buildSumDef(c: LowerCtx, p: P, moodsIdx: int) {
    fr !isGenericDecl(p, moodsIdx) {
        lowkey name = afterFirst(afterFirst(lab(p, moodsIdx)))
        lowkey sb = sbNew()
        sb.add("sum ")
        sb.add(name)
        sb.add(" {")
        lowkey nk = kidCount(p, moodsIdx)
        lowkey vpos = 0
        lowkey i = 0
        vibin i < nk {
            lowkey k = kidAt(p, moodsIdx, i)
            fr str.slaps(firstWord(lab(p, k)), "variant") {
                lowkey vname = afterFirst(lab(p, k))
                lowkey csv = sbNew()
                lowkey decl = sbNew()
                lowkey np = kidCount(p, k)
                lowkey j = 0
                vibin j < np {
                    fr j > 0 {
                        csv.add(",")
                        decl.add(", ")
                    }
                    lowkey pty = mapTypeNode(c, p, kidAt(p, k, j))
                    csv.add(pty)
                    decl.add(pty)
                    j = j + 1
                }
                fr vpos == 0 { sb.add(" ") } naw { sb.add(", ") }
                sb.add(vname)
                fr np > 0 {
                    sb.add("(")
                    sb.add(decl.finish())
                    sb.add(")")
                }
                addVariant(c, name, vname, vpos, csv.finish())
                vpos = vpos + 1
            }
            i = i + 1
        }
        sb.add(" }")
        c.sumDecls.stack(sb.finish())
    }
}

// Prescan pass 1: register all struct + sum type names (so field/variant/param types resolve
// regardless of declaration order — mirror the frontend prescan that ids all types first).
finna collectTypeNames(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n && lcOk(c) {
        lowkey it = kidAt(p, root, i)
        lowkey w = firstWord(lab(p, it))
        fr str.slaps(w, "drip") {
            registerStructName(c, p, it)
        } naw fr str.slaps(w, "moods") {
            registerSumName(c, p, it)
        }
        i = i + 1
    }
}

// Prescan pass 2: build the struct + sum decls/fields/variants now that all names are known.
finna collectTypeDefs(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n && lcOk(c) {
        lowkey it = kidAt(p, root, i)
        lowkey w = firstWord(lab(p, it))
        fr str.slaps(w, "drip") {
            buildStructDef(c, p, it)
        } naw fr str.slaps(w, "moods") {
            buildSumDef(c, p, it)
        }
        i = i + 1
    }
}

// Pre-pass: evaluate every top-level const so functions resolve them regardless of order.
finna collectConsts(c: LowerCtx, p: P, root: int) {
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n && lcOk(c) {
        lowkey it = kidAt(p, root, i)
        fr str.slaps(firstWord(lab(p, it)), "const") {
            lowerGlobalConst(c, p, it)
        }
        i = i + 1
    }
}

// Lower one function to .mir text (mirror lower_func + lower_fn_core).
finna lowerFunc(c: LowerCtx, p: P, funcIdx: int) {
    lowerFuncNamed(c, p, funcIdx, afterFirst(afterFirst(lab(p, funcIdx))))
}

// As `lowerFunc`, but with the emitted symbol given explicitly (a monomorphized instance uses its
// mangled name and looks up its reserved signature under that name; the active subst supplies the
// concrete param/ret types via `mapTypeNode`).
finna lowerFuncNamed(c: LowerCtx, p: P, funcIdx: int, emitName: str) {
    lowkey fi = lookupFn(c, emitName)
    lowkey pw = findKid(p, funcIdx, "params")
    lowkey recvW = findKidWord(p, funcIdx, "receiver")
    lowkey explicit = kidCount(p, pw)
    lowkey pcount = explicit
    fr recvW >= 0 { pcount = explicit + 1 }
    lowkey ret = c.fnRet[fi]
    resetFn(c, pcount, ret)
    lowkey slot = 0
    // A receiver method binds its receiver as the leading parameter %0.
    fr recvW >= 0 {
        c.localTypes.stack(mapTypeNode(c, p, kidAt(p, recvW, 0)))
        bindLocal(c, afterFirst(lab(p, recvW)), 0)
        slot = 1
    }
    lowkey i = 0
    vibin i < explicit {
        lowkey paramNode = kidAt(p, pw, i)
        c.localTypes.stack(mapTypeNode(c, p, kidAt(p, paramNode, 0)))
        bindLocal(c, afterFirst(lab(p, paramNode)), slot)
        slot = slot + 1
        i = i + 1
    }
    lowerBlock(c, p, findKid(p, funcIdx, "block"))
    fr str.slaps(ret, "void") {
        termRet(c)
    } naw {
        termUnreachable(c)
    }
    lowkey sig = sbNew()
    sig.add("fn ")
    sig.add(emitName)
    sig.add("(")
    lowkey ps = vec.new[str]()
    lowkey j = 0
    vibin j < pcount {
        ps.stack(cat3(reg(j), ": ", c.localTypes[j]))
        j = j + 1
    }
    sig.add(joinComma(ps))
    sig.add(") -> ")
    sig.add(ret)
    finishFn(c, sig.finish())
}

// Finish the current function: build its text (signature + temp `let`s + blocks) and stash it.
// Param locals (index < paramCount) live in the signature, so they get no `let` line.
finna finishFn(c: LowerCtx, sigLine: str) {
    lowkey sb = sbNew()
    sb.add(sigLine)
    sb.add(" {\n")
    lowkey pcount = c.paramCount[0]
    lowkey nl = c.localTypes.gang() as int
    lowkey j = pcount
    vibin j < nl {
        sb.add("  let ")
        sb.add(reg(j))
        sb.add(": ")
        sb.add(c.localTypes[j])
        sb.add("\n")
        j = j + 1
    }
    lowkey nb = c.blocks.gang() as int
    lowkey bi = 0
    vibin bi < nb {
        sb.add("  bb")
        sb.add(itoa(bi))
        sb.add(":\n")
        lowkey blk = c.blocks[bi]
        lowkey ns = blk.stmts.gang() as int
        lowkey k = 0
        vibin k < ns {
            sb.add("    ")
            sb.add(blk.stmts[k])
            sb.add("\n")
            k = k + 1
        }
        sb.add("    ")
        sb.add(blk.term[0])
        sb.add("\n")
        bi = bi + 1
    }
    sb.add("}\n")
    c.fns.stack(sb.finish())
}

// Assemble the module: struct decls, sum decls, extern decls, crib-global decls, then each
// function prefixed with a blank line (mirror text.rs order: structs, sums, externs, cribs, funcs).
finna assembleModule(c: LowerCtx) -> str {
    lowkey sb = sbNew()
    lowkey nst = c.structDecls.gang() as int
    lowkey s = 0
    vibin s < nst {
        sb.add(c.structDecls[s])
        sb.add("\n")
        s = s + 1
    }
    lowkey nsm = c.sumDecls.gang() as int
    lowkey sm = 0
    vibin sm < nsm {
        sb.add(c.sumDecls[sm])
        sb.add("\n")
        sm = sm + 1
    }
    lowkey ne = c.externs.gang() as int
    lowkey i = 0
    vibin i < ne {
        sb.add(c.externs[i])
        sb.add("\n")
        i = i + 1
    }
    lowkey ncg = c.cribGlobalNames.gang() as int
    lowkey cg = 0
    vibin cg < ncg {
        sb.add("crib @")
        sb.add(c.cribGlobalNames[cg])
        sb.add(": ")
        sb.add(c.cribGlobalElems[cg])
        sb.add("[")
        sb.add(c.cribGlobalCaps[cg])
        sb.add("]\n")
        cg = cg + 1
    }
    lowkey nf = c.fns.gang() as int
    lowkey j = 0
    vibin j < nf {
        sb.add("\n")
        sb.add(c.fns[j])
        j = j + 1
    }
    bet sb.finish()
}

// Walk the program and emit its .mir, or the `%%UNSUPPORTED%%` sentinel if it uses a construct
// C4 doesn't lower yet.
finna emitMir(p: P, root: int) -> str {
    lowkey c = lcNew()
    collectTypeNames(c, p, root)
    collectTypeDefs(c, p, root)
    collectCribGlobals(c, p, root)
    collectConsts(c, p, root)
    collectExterns(c, p, root)
    collectFns(c, p, root)
    lowkey n = kidCount(p, root)
    lowkey i = 0
    vibin i < n && lcOk(c) {
        lowkey it = kidAt(p, root, i)
        lowkey h = firstWord(lab(p, it))
        fr str.slaps(h, "pull") {
            // pull is a no-op import — ignored.
        } naw fr str.slaps(h, "extern") {
            // extern FFI imports were registered in the collectExterns pre-pass.
        } naw fr str.slaps(h, "const") {
            // top-level consts were evaluated in the collectConsts pre-pass.
        } naw fr str.slaps(h, "drip") {
            // structs were registered in the type prescan.
        } naw fr str.slaps(h, "moods") {
            // sums were registered in the type prescan.
        } naw fr str.slaps(h, "crib") {
            // module-level crib arenas were registered in the crib prescan.
        } naw fr str.slaps(h, "func") {
            // Concrete functions are lowered in place; generic ones are instantiated on demand
            // (their bodies are drained from the work-list after all concrete funcs, below).
            fr !isGenericDecl(p, it) { lowerFunc(c, p, it) }
        } naw {
            lcFail(c)
        }
        i = i + 1
    }
    // Drain the monomorphization work-list. Instances may enqueue further instances (a generic
    // function calling another generic instance); the index walk picks those up too.
    lowkey qi = 0
    vibin qi < (c.moQName.gang() as int) && lcOk(c) {
        lowerMonoFn(c, p, qi)
        qi = qi + 1
    }
    fr !lcOk(c) {
        bet UNSUPPORTED
    }
    bet assembleModule(c)
}

// ===========================================================================
// C0 tracer — the fixed `hello` .mir emission (retires at C4/C5 when real lowering lands).
// ===========================================================================

// Emit the `.mir` for the `hello` program (`spill.it("hi")`), matching the Rust frontend's
// canonical printer (crates/midir/src/text.rs) line for line.
finna emitHelloMir() -> str {
    lowkey sb = sbNew()
    sb.add("extern \"C\" fn bet_print(rawptr, u64) -> void\n")
    sb.add("\n")
    sb.add("fn main() -> void {\n")
    sb.add("  let %0: rawptr\n")
    sb.add("  let %1: u64\n")
    sb.add("  let %2: void\n")
    sb.add("  bb0:\n")
    sb.add("    %0 = str_ptr(\"hi\\n\")\n")
    sb.add("    %1 = str_len(\"hi\\n\")\n")
    sb.add("    %2 = call_extern @bet_print(%0, %1)\n")
    sb.add("    return\n")
    sb.add("}")
    bet sb.finish()
}

finna main() {
    // `betfe --emit tokens <file>` prints the token dump; `--emit ast <file>` prints the AST dump.
    // With no args the C0 tracer emits the fixed hello .mir for the backend hand-off. Conditions
    // stay on one line so ASI doesn't split the multi-clause `&&` (a line ending in `)` gets a
    // statement-terminating semicolon).
    fr sys.argc() >= 4 && str.slaps(sys.arg(1), "--emit") && str.slaps(sys.arg(2), "tokens") {
        lowkey src = fs.peepText(sys.arg(3))
        spill.f("{}", emitTokens(lex(src)))
    } naw fr sys.argc() >= 4 && str.slaps(sys.arg(1), "--emit") && str.slaps(sys.arg(2), "ast") {
        lowkey src = fs.peepText(sys.arg(3))
        spill.f("{}", emitAst(lex(src)))
    } naw fr sys.argc() >= 4 && str.slaps(sys.arg(1), "--emit") && str.slaps(sys.arg(2), "mir") {
        lowkey src = fs.peepText(sys.arg(3))
        spill.f("{}", emitMirFromSrc(src))
    } naw {
        spill.it(emitHelloMir())
    }
}
