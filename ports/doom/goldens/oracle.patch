diff --git a/doomgeneric/doomgeneric_dump.c b/doomgeneric/doomgeneric_dump.c
new file mode 100644
index 0000000..88b403a
--- /dev/null
+++ b/doomgeneric/doomgeneric_dump.c
@@ -0,0 +1,185 @@
+//
+// doomgeneric_dump.c — headless "dump" platform for the bet DOOM port's oracle
+// (added by ports/doom/goldens/oracle.patch; built by `cargo xtask doom-oracle`).
+//
+// No window, no input, uncapped time. With the environment variable DOOM_SYNC_OUT set
+// to a file path, it appends a deterministic sync stream:
+//
+//   * after each G_Ticker while in a level (hook in d_net.c RunTic), one fingerprint line —
+//     all values %08x fixed-width hex:
+//       T=<gametic> R=<prndindex> X=<mo.x> Y=<mo.y> Z=<mo.z> A=<mo.angle>
+//       MX=<mo.momx> MY=<mo.momy> H=<players[0].health> S=<sector index of players[0].mo>
+//       LT=<leveltime> C=<crc32 of the full 8-bit I_VideoBuffer>
+//     X/Y/Z/A/MX/MY come from players[0].mo (zeros when no mobj exists). Rendering happens
+//     AFTER the tics in doomgeneric_Tick, so C is the crc of the last PRESENTED frame —
+//     it lags the sim fields by one frame. The bet port must fingerprint at the same spot.
+//
+//   * right after P_SetupLevel (hook in g_game.c G_DoLoadLevel), a SETUP block:
+//       SETUP sectors=<numsectors> lines=<numlines> things=<mobj count>
+//       SETUP T i=<n> type=<mobjtype> x=<fixed> y=<fixed> a=<angle>
+//     one T line per mobj thinker, in spawn order (the thinker list appends on spawn).
+//
+// Diff two streams with `cargo xtask doom-verify --ours <file> --theirs <file>`.
+//
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <time.h>
+
+#include "doomgeneric.h"
+
+#include "doomdef.h"
+#include "doomstat.h"
+#include "d_loop.h"
+#include "d_player.h"
+#include "i_video.h"
+#include "m_fixed.h"
+#include "p_local.h"
+#include "p_mobj.h"
+#include "r_state.h"
+
+extern int prndindex; /* m_random.c keeps it private to the header's users */
+
+//
+// DG platform callbacks: headless.
+//
+
+void DG_Init()
+{
+}
+
+void DG_DrawFrame()
+{
+}
+
+void DG_SleepMs(uint32_t ms)
+{
+    (void)ms; /* uncapped: never sleep */
+}
+
+uint32_t DG_GetTicksMs()
+{
+    struct timespec ts;
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    return (uint32_t)((uint64_t)ts.tv_sec * 1000u + (uint64_t)ts.tv_nsec / 1000000u);
+}
+
+int DG_GetKey(int* pressed, unsigned char* doomKey)
+{
+    (void)pressed;
+    (void)doomKey;
+    return 0;
+}
+
+void DG_SetWindowTitle(const char* title)
+{
+    (void)title;
+}
+
+//
+// The sync-stream dump (active only when DOOM_SYNC_OUT is set).
+//
+
+/* CRC-32: IEEE 802.3 reflected, polynomial 0xEDB88320, init 0xFFFFFFFF, final XOR
+ * 0xFFFFFFFF. Must match crates/xtask/src/doom.rs::crc32, gen_tables.c, and the bet twin
+ * bit-for-bit. */
+static uint32_t crc32_buf(const unsigned char* p, size_t n)
+{
+    uint32_t crc = 0xFFFFFFFFu;
+    size_t i;
+    int k;
+    for (i = 0; i < n; i++) {
+        crc ^= p[i];
+        for (k = 0; k < 8; k++)
+            crc = (crc >> 1) ^ (0xEDB88320u & (0u - (crc & 1u)));
+    }
+    return crc ^ 0xFFFFFFFFu;
+}
+
+static FILE* sync_out(void)
+{
+    static FILE* f = NULL;
+    static int checked = 0;
+    if (!checked) {
+        const char* path = getenv("DOOM_SYNC_OUT");
+        checked = 1;
+        if (path && path[0])
+            f = fopen(path, "a");
+    }
+    return f;
+}
+
+/* Hooked after G_Ticker() in d_net.c's RunTic. */
+void DG_SyncTick(void)
+{
+    FILE* f = sync_out();
+    mobj_t* mo;
+    unsigned x = 0, y = 0, z = 0, a = 0, mx = 0, my = 0, s = 0, c = 0;
+
+    if (!f || gamestate != GS_LEVEL)
+        return;
+
+    mo = players[0].mo;
+    if (mo) {
+        x = (unsigned)mo->x;
+        y = (unsigned)mo->y;
+        z = (unsigned)mo->z;
+        a = (unsigned)mo->angle;
+        mx = (unsigned)mo->momx;
+        my = (unsigned)mo->momy;
+        if (mo->subsector && mo->subsector->sector)
+            s = (unsigned)(mo->subsector->sector - sectors);
+    }
+    if (I_VideoBuffer)
+        c = crc32_buf((const unsigned char*)I_VideoBuffer,
+                      (size_t)SCREENWIDTH * (size_t)SCREENHEIGHT);
+
+    fprintf(f,
+            "T=%08x R=%08x X=%08x Y=%08x Z=%08x A=%08x MX=%08x MY=%08x H=%08x S=%08x "
+            "LT=%08x C=%08x\n",
+            (unsigned)gametic, (unsigned)prndindex, x, y, z, a, mx, my,
+            (unsigned)players[0].health, s, (unsigned)leveltime, c);
+    fflush(f);
+}
+
+/* Hooked after P_SetupLevel(..) in g_game.c's G_DoLoadLevel. */
+void DG_SyncSetup(void)
+{
+    FILE* f = sync_out();
+    thinker_t* th;
+    unsigned n = 0, i = 0;
+
+    if (!f)
+        return;
+
+    for (th = thinkercap.next; th != &thinkercap; th = th->next)
+        if (th->function.acp1 == (actionf_p1)P_MobjThinker)
+            n++;
+
+    fprintf(f, "SETUP sectors=%08x lines=%08x things=%08x\n", (unsigned)numsectors,
+            (unsigned)numlines, n);
+
+    for (th = thinkercap.next; th != &thinkercap; th = th->next) {
+        mobj_t* mo;
+        if (th->function.acp1 != (actionf_p1)P_MobjThinker)
+            continue;
+        mo = (mobj_t*)th;
+        fprintf(f, "SETUP T i=%08x type=%08x x=%08x y=%08x a=%08x\n", i,
+                (unsigned)mo->type, (unsigned)mo->x, (unsigned)mo->y,
+                (unsigned)mo->angle);
+        i++;
+    }
+    fflush(f);
+}
+
+int main(int argc, char** argv)
+{
+    doomgeneric_Create(argc, argv);
+
+    for (;;) {
+        doomgeneric_Tick();
+    }
+
+    return 0;
+}
