    flex netgame: bool
    flex deathmatch: i32
    flex demoplayback: bool
    flex demorecording: bool
    flex singledemo: bool
    flex netdemo: bool
    flex demobuffer: []u8
    flex demoOfs: int
    flex demoLen: int
    flex demoend: int
    flex consoleplayer: i32
    flex displayplayer: i32
    flex viewactive: bool
    flex nodrawers: bool
    flex noblit: bool
    flex automapactive: bool
    flex menuactive: bool
    flex statusbaractive: bool
    flex wipegamestate: i32
    flex nomonsters: bool
    flex respawnparm: bool
    flex fastparm: bool
    flex devparm: bool
    flex precache: bool
    flex singletics: bool
    flex gamemode: i32
    flex gamemission: i32
    flex language: i32
    flex modifiedgame: bool
    flex autostart: bool
    flex totalkills: i32
    flex totalitems: i32
    flex totalsecret: i32
    flex levelstarttic: i32
    flex mouseSensitivity: i32
    flex players: player.Player[4]
    flex playeringame: bool[4]
    flex playerstarts: think.MapThing[4]
    flex deathmatchstarts: think.MapThing[10]
    flex deathmatchP: i32
    flex wminfo: player.WbStart
    flex maxammo: i32[4]
    flex clipammo: i32[4]
    // ---- P2.8 shell-core additive (g/g_game, d/d_main, d/d_net). All cop-zero-inited; the input
    // arrays + syncBuf handle are populated by D_DoomMain. No sibling drip touched. -------------
    flex timingdemo: bool          // G_TimeDemo: report + self-terminate at demo end
    flex starttime: i32            // I_GetTime at level start (timing report)
    flex secretexit: bool          // G_SecretExitLevel / G_DoCompleted
    flex advancedemo: bool         // attract loop: advance to the next demo sequence step
    flex demosequence: i32         // attract loop cursor (-1..6)
    flex pagetic: i32              // attract page countdown
    flex pagename: str             // TITLEPIC / CREDIT / HELP2 lump for D_PageDrawer
    flex defdemoname: str          // deferred demo lump name (G_DeferedPlayDemo)
    flex demoName: str             // demo-record output path
    flex savegameslot: i32         // pending save slot
    flex savedescription: str      // pending save description
    // input state (G_Responder writes; G_BuildTiccmd reads) ----------------------------------
    flex gamekeydown: bool[256]
    flex turnheld: i32
    flex mousex: i32
    flex mousey: i32
    flex mousebuttons: bool[4]
    flex mousebtnmask: i32         // held mouse-button bitmask, persisted across tics (gg sends edges)
    // -sync fingerprint writer (-timedemo -sync <out>) ---------------------------------------
    flex syncOn: bool
    flex syncPath: str
    flex syncBuf: vec[int]         // accumulated ASCII bytes; fs.drop'd at demo end (null until D_DoomMain)
    flex lastFrameCrc: i32         // crc32 of the LAST presented scr0 (C lags the sim one frame)
    // -dumpframe <tic> -dumpout <path>: write the 8-bit scr0 at gametic==dumpTic (render parity) --
    flex dumpTic: i32              // gametic at which to fs.drop scr0 (0 with empty dumpPath = off)
    flex dumpPath: str             // output path for the raw 64000-byte 8-bit frame ("" = disabled)
    flex demoDone: bool            // set by G_CheckDemoStatus in timedemo; breaks D_DoomLoop
    flex maxframes: i32            // headless self-terminate cap (0 = unlimited)
    flex frameCount: i32           // frames elapsed since D_DoomLoop start
}

