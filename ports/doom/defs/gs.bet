flex drip Hooks {
    flex tryMove: finna(tag GameState, tag think.Thinker, i32, i32) -> bool
    flex slideMove: finna(tag GameState, tag think.Thinker) -> void
    flex checkPosition: finna(tag GameState, tag think.Thinker, i32, i32) -> bool
    flex aimLineAttack: finna(tag GameState, tag think.Thinker, u32, i32) -> i32
    flex crossSpecialLine: finna(tag GameState, i32, i32, tag think.Thinker) -> void
    flex shootSpecialLine: finna(tag GameState, tag think.Thinker, i32) -> void
    flex useSpecialLine: finna(tag GameState, tag think.Thinker, i32, i32) -> bool
    flex mobjThink: finna(tag GameState, tag think.Thinker) -> void
    flex doorThink: finna(tag GameState, tag think.Thinker) -> void
    flex ceilingThink: finna(tag GameState, tag think.Thinker) -> void
    flex floorThink: finna(tag GameState, tag think.Thinker) -> void
    flex platThink: finna(tag GameState, tag think.Thinker) -> void
    flex flickerThink: finna(tag GameState, tag think.Thinker) -> void
    flex flashThink: finna(tag GameState, tag think.Thinker) -> void
    flex strobeThink: finna(tag GameState, tag think.Thinker) -> void
    flex glowThink: finna(tag GameState, tag think.Thinker) -> void
    // P2.4 amendment: P_DropWeapon forward-dispatch. p_inter.killMobj lowers the dead player's
    // weapon, but p_inter cannot pull p/p_pspr (p_pspr -> p_inter for P_DamageMobj, so the reverse
    // edge would cycle). Modelled as a pre-wired fn-value exactly like mobjThink; p_action wires it
    // to p_pspr.dropWeapon at startup. Arg is the player index. cop zero-inits it.
    flex dropWeapon: finna(tag GameState, int) -> void
}

