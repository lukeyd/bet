// ---- AmState (am_map). --------------------------------------------------------------------
// P2.9b: am_map.c keeps ~40 file-level statics (mutable globals don't lower native), so they are
// modelled as additive scalar fields here (only this drip changed). Field map:
//   mx/my/mw/mh = m_x/m_y/m_w/m_h (map coords); mScale = scale_mtof; ftom = scale_ftom;
//   mtof is UNUSED (kept for back-compat). The zoom multipliers, save/restore slots, bounds,
//   window rect, clocks, and mark ring are the remaining am_map statics.
// Marks: id used a mutable 10-entry ring (markpoints[] with in-place x/y writes + clear-to-(-1)).
// A `vec` can't be element-mutated in native codegen, so the ring is a pair of fixed i32[10]
// arrays (markX/markY, native-safe element assign); the pre-existing `marks` vec is left unused.
flex drip AmState {
    flex active: bool
    flex mx: i32
    flex my: i32
    flex mw: i32
    flex mh: i32
    flex mScale: i32              // scale_mtof
    flex ftom: i32               // scale_ftom
    flex mtof: i32               // (unused; kept for back-compat)
    flex followplayer: bool
    flex grid: bool
    flex leaveletter: i32
    flex marks: vec[MapMark]     // (unused in P2.9b; ring is markX/markY below)
    // ---- P2.9b additive statics ------------------------------------------------------------
    flex mx2: i32                // m_x2 (m_x + m_w)
    flex my2: i32                // m_y2 (m_y + m_h)
    flex minX: i32               // level vertex bounds
    flex minY: i32
    flex maxX: i32
    flex maxY: i32
    flex maxW: i32               // max_x-min_x
    flex maxH: i32               // max_y-min_y
    flex minScale: i32           // min_scale_mtof (zoom-out stop)
    flex maxScale: i32           // max_scale_mtof (zoom-in stop)
    flex oldMx: i32              // AM_saveScaleAndLoc slots
    flex oldMy: i32
    flex oldMw: i32
    flex oldMh: i32
    flex oldLocX: i32            // f_oldloc (follow-player last pos; MAXINT = invalid)
    flex oldLocY: i32
    flex panIncX: i32            // m_paninc (map-coord pan velocity per tic)
    flex panIncY: i32
    flex mtofZoom: i32           // mtof_zoommul (per-tic zoom, FRACUNIT = none)
    flex ftomZoom: i32           // ftom_zoommul
    flex fx: i32                 // f_x window rect on screen
    flex fy: i32
    flex fw: i32                 // f_w (SCREENWIDTH)
    flex fh: i32                 // f_h (SCREENHEIGHT-32)
    flex amclock: i32
    flex lightlev: i32
    flex cheating: i32           // 0/1/2 (iddt states)
    flex bigstate: i32           // AM_GOBIGKEY toggle
    flex markpointnum: i32       // next mark ring slot
    flex leveljuststarted: i32
    flex stopped: bool
    flex lastlevel: i32          // AM_Start's static level/episode cache
    flex lastepisode: i32
    flex plrnum: i32             // player represented by the arrow
    flex amCheatPos: i32         // cheat_amap match position (m_cheat state)
    flex markX: i32[10]          // AM_NUMMARKPOINTS mark ring x (-1 = empty)
    flex markY: i32[10]          // mark ring y
}

// ---- WiState (wi_stuff intermission). -----------------------------------------------------
// P2.9c amendment (additive, wi_stuff.c): the base fields (state/acceleratestage/cnt/bcnt/
// cntTime/cntPar/cntTotal/spstate + cntKills/cntItems/cntSecret[MAXPLAYERS]) are id's
// stateenum_t state / acceleratestage / cnt / bcnt / cnt_time / cnt_par / sp_state / cnt_*[].
// The lower block adds the remaining wi_stuff.c file-statics (me/cnt_pause/dm_state/ng_state/
// dofrags/snl_pointeron/cnt_frags/dm_frags/dm_totals), the per-anim mutable animation state
// (mutable globals don't lower native; anim geometry is module data, see wi_stuff.bet), and the
// loaded intermission graphics as byte offsets into g.wad.buf (set once by WI_loadData; the
// []i32 handle tables are mem.slab-allocated there, null until then).
flex drip WiState {
    flex state: i32
    flex acceleratestage: i32
    flex cnt: i32
    flex bcnt: i32
    flex cntTime: i32
    flex cntPar: i32
    flex cntTotal: i32
    flex spstate: i32
    flex cntKills: i32[4]
    flex cntItems: i32[4]
    flex cntSecret: i32[4]
    // ---- P2.9c additive statics ------------------------------------------------------------
    flex me: i32                   // wbs->pnum (this player index)
    flex cntPause: i32             // cnt_pause
    flex dmState: i32              // dm_state
    flex ngState: i32              // ng_state
    flex dofrags: i32              // dofrags (0/1)
    flex snlPointeron: bool        // snl_pointeron (the "You Are Here" flash)
    flex cntFrags: i32[4]          // cnt_frags[MAXPLAYERS]
    flex dmFrags: i32[16]          // dm_frags[MAXPLAYERS][MAXPLAYERS] as [i*4 + j]
    flex dmTotals: i32[4]          // dm_totals[MAXPLAYERS]
    flex loaded: bool              // WI_loadData has run (graphics offsets valid)
    // animated-background per-anim mutable state (MAXANIMS=10 across episodes 0-2). anim geometry
    // (type/period/nanims/loc/data1) is module data in wi_stuff.bet; only the mutable ctr/nexttic/
    // state/lastdrawn + the loaded frame patch offsets live here.
    flex animNexttic: i32[10]
    flex animCtr: i32[10]
    flex animState: i32[10]
    flex animLastdrawn: i32[10]
    flex animP: i32[30]            // loaded frame patch offsets (10 anims * up to 3 frames)
    // loaded graphics (byte offsets into g.wad.buf; set by WI_loadData)
    flex bgOfs: i32                // WIMAP<epsd> background (drawn into scr1, slammed to scr0)
    flex splatOfs: i32             // WISPLAT
    flex percentOfs: i32           // WIPCNT
    flex colonOfs: i32             // WICOLON
    flex wiminusOfs: i32           // WIMINUS
    flex finishedOfs: i32          // WIF "finished"
    flex enteringOfs: i32          // WIENTER "entering"
    flex spSecretOfs: i32          // WISCRT2 "secret"
    flex killsOfs: i32             // WIOSTK
    flex secretOfs: i32            // WIOSTS
    flex itemsOfs: i32             // WIOSTI
    flex fragsOfs: i32             // WIFRGS
    flex timeOfs: i32              // WITIME
    flex parOfs: i32               // WIPAR
    flex sucksOfs: i32             // WISUCKS
    flex killersOfs: i32           // WIKILRS
    flex victimsOfs: i32           // WIVCTMS
    flex totalOfs: i32             // WIMSTT
    flex starOfs: i32              // STFST01 (your face)
    flex bstarOfs: i32             // STFDEAD0 (dead face)
    flex yahOfs: i32[2]            // WIURH0 / WIURH1 "You Are Here"
    flex numOfs: []i32             // WINUM0..9 (10)
    flex pOfs: []i32               // STPB0..3 (MAXPLAYERS)
    flex bpOfs: []i32              // WIBP1..4 (MAXPLAYERS)
    flex lnamesOfs: []i32          // WILV<epsd><m> level-name patches (NUMMAPS, or NUMCMAPS commercial)
}

// ---- FinaleState (f_finale). --------------------------------------------------------------
// P2.9c amendment (additive, f_finale.c): stage/count/text = id's finalestage/finalecount/
// finaletext; `flat` is finaleflat (the FLOOR flat name, re-cached each F_TextWrite). The cast*
// block is the DOOM-II/registered character-cast state machine (F_StartCast..F_CastDrawer,
// gated by gamemode==commercial / gameepisode==30); bunnyLaststage is F_BunnyScroll's static
// laststage (gameepisode==3). textIndex is unused (kept from the frozen shape).
flex drip FinaleState {
    flex stage: i32
    flex count: i32
    flex text: str
    flex textIndex: i32
    // ---- P2.9c additive ---------------------------------------------------------------------
    flex flat: str                 // finaleflat lump name
    flex castNum: i32              // castnum
    flex castTics: i32             // casttics
    flex castStateIdx: i32         // caststate (state index into g.info.states)
    flex castDeath: bool           // castdeath
    flex castFrames: i32           // castframes
    flex castOnMelee: i32          // castonmelee
    flex castAttacking: bool       // castattacking
    flex bunnyLaststage: i32       // F_BunnyScroll static laststage
}

flex drip WipeState {
    flex active: bool
    flex y: []i32
    flex scrStart: []u8
    flex scrEnd: []u8
}

