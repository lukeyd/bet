// fill an empty vec with all NUMMOBJTYPES entries, in mobjtype_t order
flex finna initMobjinfoAll(m: vec[MobjInfo]) {
    initMobjinfo0(m)
    initMobjinfo1(m)
    initMobjinfo2(m)
}

// sprnames[i] — 4 chars per sprite, one concatenated string
flex finna spriteName(i: int) -> str {
    facts NAMES: str = ""
    bet str.sub(NAMES, i * 4, i * 4 + 4)
}
