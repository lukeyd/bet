// fill an empty vec with all NUMSTATES states, in statenum_t order
flex finna initStatesAll(v: vec[State]) {
    initStates0(v)
    initStates1(v)
    initStates2(v)
    initStates3(v)
    initStates4(v)
    initStates5(v)
    initStates6(v)
    initStates7(v)
    initStates8(v)
    initStates9(v)
}

