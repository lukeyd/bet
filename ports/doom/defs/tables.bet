flex finna initTantoangle4(t: []u32) -> []u32 {
    t[2048] = 536870912
    bet t
}

// fill a mem.slab[u32](2049) — call as `t = initTantoangleAll(t)`
flex finna initTantoangleAll(t: []u32) -> []u32 {
    t = initTantoangle0(t)
    t = initTantoangle1(t)
    t = initTantoangle2(t)
    t = initTantoangle3(t)
    t = initTantoangle4(t)
    bet t
}

