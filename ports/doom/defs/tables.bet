// SlopeDiv from tables.c: u32 in, u32 out, clamped to SLOPERANGE.
flex finna slopeDiv(num: u32, den: u32) -> u32 {
    fr den < 512 {
        bet 2048
    }
    lowkey ans: u32 = (num << 3) / (den >> 8)
    fr ans <= 2048 {
        bet ans
    }
    bet 2048
}

