// v/v_video.bet — the v_video.c seam: the 5x256 gamma LUT, the five 8-bit screen buffers,
// and the column-post patch blitter V_DrawPatch (THE core 2D primitive: menus, status bar,
// finale, HUD, the title screen all draw through it).
//
// Screens are `[]u8` palette-index buffers (SCREENWIDTH*SCREENHEIGHT); id's `byte* screens[5]`
// becomes the five fields g.vid.scr0..scr4, selected by an int `screen` arg. The blitter reads
// the patch from g.wad.buf at a byte offset (the w_wad no-cache model) and writes indices into
// the chosen screen — so a screen's crc32 is palette/gamma-INDEPENDENT (the gamma LUT only
// colors the u32 present buffer in i_video.setPalette/finishUpdate).
//
// ALLOCATION OWNERSHIP: v_video.vInit owns the five screen slabs (V_Init). i_video.initGraphics
// owns g.vid.fb + g.vid.pal and calls vInit. (gsInit also pre-allocates all of them so any
// order is safe; vInit/initGraphics re-assert the sizing that v_video/i_video own.)
//
// PORTED:  V_Init, gammatable literal, V_DrawPatch, V_CopyRect, V_DrawBlock (+ drawRawScreen
//          for raw full-screen paletted lumps). V_MarkRect is a documented no-op (gg presents
//          the whole framebuffer each finishUpdate, so id's dirtybox dirty-rect tracking is
//          vestigial).
// SKIPPED: V_DrawPatchFlipped / V_DrawPatchDirect / V_DrawScaledPatch / V_GetBlock — add when a
//          caller needs them (drawPatchDirect == drawPatch on non-PC targets; flipped mirrors
//          the column index; both are trivial deltas of drawPatch).
pull "mem"
pull "../defs/gs" as gs
pull "../util/bstream" as bstream

flex facts SCREENWIDTH: int = 320
flex facts SCREENHEIGHT: int = 200
flex facts SCREENAREA: int = 64000

// vInit — V_Init: allocate the five 8-bit screen buffers.
flex finna vInit(gt: tag gs.GameState) {
    holla g = gt in gs.gsc {
        g.vid.scr0 = mem.slab[u8](64000)
        g.vid.scr1 = mem.slab[u8](64000)
        g.vid.scr2 = mem.slab[u8](64000)
        g.vid.scr3 = mem.slab[u8](64000)
        g.vid.scr4 = mem.slab[u8](64000)
    } ghosted {
        yeet("gs")
    }
}

// gammatable — the 5x256 byte gamma correction LUT, verbatim from v_video.c (id's comment:
// "Now where did these came from?"). Flat, row-major: index [gammaIndex*256 + component],
// gammaIndex 0..4 (usegamma). Returned as a fresh 1280-byte slab.
