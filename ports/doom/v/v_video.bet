// drawPatch — V_DrawPatch. Parse patch_t at byte offset `patchLumpOfs` in g.wad.buf and blit
// its masked columns into screen `screen` at (x, y). patch_t layout (all little-endian):
//   +0 width u16 · +2 height u16 · +4 leftoffset i16 · +6 topoffset i16 · +8 columnofs[width] u32
// each column = a run of posts; a post is { topdelta u8, length u8, pad u8, length*pixel u8,
// pad u8 } and the column ends at topdelta 0xff. x/y are offset by -leftoffset/-topoffset; each
// pixel is clipped to the screen (id's non-RANGECHECK build silently ignores OOB patches).
flex finna drawPatch(gt: tag gs.GameState, x: int, y: int, screen: int, patchLumpOfs: int) {
    holla g = gt in gs.gsc {
        lowkey width = bstream.rdU16(g.wad.buf, patchLumpOfs)
        lowkey leftofs = bstream.rdI16(g.wad.buf, patchLumpOfs + 4)
        lowkey topofs = bstream.rdI16(g.wad.buf, patchLumpOfs + 6)
        lowkey ox = x - leftofs
        lowkey oy = y - topofs
        // Select the destination screen once. Native: the slice shares its backing, so writes
        // land in the field directly. Interp: `scr` is a clone, written back below.
        lowkey scr = g.vid.scr0
        fr screen == 1 {
            scr = g.vid.scr1
        } naw fr screen == 2 {
            scr = g.vid.scr2
        } naw fr screen == 3 {
            scr = g.vid.scr3
        } naw fr screen == 4 {
            scr = g.vid.scr4
        }
        lowkey col = 0
        vibin col < width {
            lowkey cp = patchLumpOfs + bstream.rdU32(g.wad.buf, patchLumpOfs + 8 + col * 4)
            lowkey destX = ox + col
            vibin nocap {
                lowkey topdelta = bstream.rdU8(g.wad.buf, cp)
                fr topdelta == 255 {
                    dip
                }
                lowkey length = bstream.rdU8(g.wad.buf, cp + 1)
                lowkey n = 0
                vibin n < length {
                    lowkey destY = oy + topdelta + n
                    fr destX >= 0 && destX < SCREENWIDTH && destY >= 0 && destY < SCREENHEIGHT {
                        scr[destY * SCREENWIDTH + destX] = bstream.rdU8(g.wad.buf, cp + 3 + n) as u8
                    }
                    n = n + 1
                }
                cp = cp + length + 4
            }
            col = col + 1
        }
        // Write the screen back to its field (a no-op reassign under native; the modified clone
        // under interp).
        fr screen == 0 {
            g.vid.scr0 = scr
        } naw fr screen == 1 {
            g.vid.scr1 = scr
        } naw fr screen == 2 {
            g.vid.scr2 = scr
        } naw fr screen == 3 {
            g.vid.scr3 = scr
        } naw fr screen == 4 {
            g.vid.scr4 = scr
        }
    } ghosted {
        yeet("gs")
    }
}

// drawRawScreen — copy a raw SCREENWIDTH*SCREENHEIGHT paletted lump (e.g. a flat-format full
// screen like the shareware help/credits screens) straight from g.wad.buf into a screen.
flex finna drawRawScreen(gt: tag gs.GameState, screen: int, rawLumpOfs: int) {
    holla g = gt in gs.gsc {
        lowkey scr = g.vid.scr0
        fr screen == 1 {
            scr = g.vid.scr1
        } naw fr screen == 2 {
            scr = g.vid.scr2
        } naw fr screen == 3 {
            scr = g.vid.scr3
        } naw fr screen == 4 {
            scr = g.vid.scr4
        }
        lowkey i = 0
        vibin i < SCREENAREA {
            scr[i] = g.wad.buf[rawLumpOfs + i]
            i = i + 1
        }
        fr screen == 0 {
            g.vid.scr0 = scr
        } naw fr screen == 1 {
            g.vid.scr1 = scr
        } naw fr screen == 2 {
            g.vid.scr2 = scr
        } naw fr screen == 3 {
            g.vid.scr3 = scr
        } naw fr screen == 4 {
            g.vid.scr4 = scr
        }
    } ghosted {
        yeet("gs")
    }
}

// markRect — V_MarkRect. No-op: gg presents the whole framebuffer every finishUpdate, so id's
// dirtybox dirty-rectangle bookkeeping (a blit optimization for partial X updates) is unneeded.
flex finna markRect(gt: tag gs.GameState, x: int, y: int, width: int, height: int) {
}
