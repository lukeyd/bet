// P_Random: the play-sim RNG (deterministic; drives all game logic and demos).
flex finna pRandom(gt: tag gs.GameState) -> int {
    lowkey r = 0
    holla g = gt in gs.gsc {
        g.tick.prndindex = (g.tick.prndindex + 1) & 255
        r = g.tick.rndtable[g.tick.prndindex] as int
    } ghosted {
        yeet("gs")
    }
    bet r
}

// M_Random: the menu/UI RNG (its own index; never affects demo sync).
flex finna mRandom(gt: tag gs.GameState) -> int {
    lowkey r = 0
    holla g = gt in gs.gsc {
        g.tick.rndindex = (g.tick.rndindex + 1) & 255
        r = g.tick.rndtable[g.tick.rndindex] as int
    } ghosted {
        yeet("gs")
    }
    bet r
}

// M_ClearRandom: reset both indices (level start).
flex finna clearRandom(gt: tag gs.GameState) {
    holla g = gt in gs.gsc {
        g.tick.prndindex = 0
        g.tick.rndindex = 0
    } ghosted {
        yeet("gs")
    }
}
