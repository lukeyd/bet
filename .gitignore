# Rust / Cargo build artifacts
/target
**/*.rs.bk
*.pdb

# Compiled `ports/` demo binaries (built at the repo root via `bet build ... -o <name>`)
/pong
/oregon

# Local pinned-LLVM install used by `cargo xtask setup-llvm`
/.llvm

# doomgeneric clone used by `cargo xtask doom-oracle` (lives at the MAIN checkout root,
# outside any worktree; shared scratch, never committed)
/doom-oracle/

# Release artifacts (`cargo xtask dist`)
/dist

# Claude Code agent worktrees (transient isolated checkouts; never committed)
/.claude/worktrees/

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# NOTE: Cargo.lock is intentionally COMMITTED (the workspace ships the `bet` binary;
#       CI builds with --locked). timelog/ is intentionally COMMITTED (durable effort log).
