# Rust / Cargo build artifacts
/target
**/*.rs.bk
*.pdb

# Compiled binaries built at the repo root via `bet build ... -o <name>`:
# `ports/` demos, plus the self-hosted frontend built from `selfhost/betfe.bet`.
/pong
/oregon
/betfe

# Local pinned-LLVM install used by `cargo xtask setup-llvm`
/.llvm

# doomgeneric clone used by `cargo xtask doom-oracle` (lives at the MAIN checkout root,
# outside any worktree; shared scratch, never committed)
/doom-oracle/

# Upstream id Software DOOM C source — reference we translate the `bet` port FROM.
# Cloned locally (see ports/doom/README.md) but NEVER checked in: it is GPL, and it
# is kept OUTSIDE ports/doom so the reference stays separate from the bet port.
/doom-reference/

# WAD game data (shareware or commercial) is copyrighted id/ZeniMax data — never committed.
*.wad

# DOOM port: id-derived verification artifacts. Kept LOCALLY for the in-progress port's parity
# checks but never committed — the gen_*.c generators #include linuxdoom-1.10 source, *.oracle.sync
# is doomgeneric (id engine) output, and these goldens are produced by id's own code paths / WAD
# data. Regenerate with `cargo xtask-doom doom-golden-gen` and `cargo xtask-doom doom-oracle`.
/ports/doom/goldens/gen/
/ports/doom/goldens/oracle.patch
/ports/doom/goldens/*.oracle.sync
/ports/doom/goldens/fixed.golden
/ports/doom/goldens/random.golden
/ports/doom/goldens/angle.golden
/ports/doom/goldens/tables.golden
/ports/doom/goldens/mus_e1m1.golden

# Release artifacts (`cargo xtask dist`)
/dist

# Claude Code agent worktrees (transient isolated checkouts; never committed)
/.claude/worktrees/

# npm distribution: staged artifacts (`node npm/stage.mjs`) — demos are copied from
# ports/ and the dist/ platform packages hold built binaries; neither is committed.
/npm/betlang/demos/
/npm/dist/
/npm/**/*.tgz

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# NOTE: Cargo.lock is intentionally COMMITTED (the workspace ships the `bet` binary;
#       CI builds with --locked). timelog/ is intentionally COMMITTED (durable effort log).

# Docker build env cargo cache (docker/compose.yaml CARGO_HOME)
/.docker-cache/
