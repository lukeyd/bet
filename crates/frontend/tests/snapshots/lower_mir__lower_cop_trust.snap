---
source: crates/frontend/tests/lower_mir.rs
expression: "lower_to_mir(\"drip Enemy { flex hp: int }\\n\\\n                        finna peek(arena: crib Enemy) -> int {\\n\\\n                          lowkey e = cop Enemy{ hp: 77 } in arena\\n\\\n                          lowkey r = e.trust() in arena\\n bet r.hp\\n}\")"
---
struct Enemy { flex hp: i64 }
extern "C" fn bet_print(rawptr, u64) -> void

fn peek(%0: crib Enemy) -> i64 {
  let %1: tag Enemy
  let %2: tag Enemy
  let %3: ref Enemy
  let %4: ref Enemy
  bb0:
    %1 = cop(%0, Enemy{0: 77i64})
    %2 = %1
    %3 = trust(%0, %2)
    %4 = %3
    return %4.deref.field(0)
}
