struct Point { flex x: i64, flex y: i64 }
extern "C" fn bet_print(rawptr, u64) -> void

fn move_x(%0: Point, %1: i64) -> i64 {
  let %2: Point
  let %3: i64
  let %4: i64
  bb0:
    %2 = %0
    %3 = add.trap(%2.field(0), %1)
    %2.field(0) = %3
    %4 = add.trap(%2.field(0), %2.field(1))
    return %4
}
