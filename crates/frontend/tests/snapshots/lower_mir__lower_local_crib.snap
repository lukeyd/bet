struct Enemy { flex hp: i64 }
extern "C" fn bet_print(rawptr, u64) -> void

fn go() -> i64 {
  let %0: crib Enemy
  let %1: tag Enemy
  let %2: tag Enemy
  let %3: ref Enemy
  let %4: i64
  bb0:
    %0 = crib_new[Enemy; 8]
    %1 = cop(%0, Enemy{0: 5i64})
    %2 = %1
    holla_check(%2, %0, %3) -> bb2 else bb3
  bb1:
    unreachable
  bb2:
    return %3.deref.field(0)
  bb3:
    %4 = neg(1i64)
    return %4
}
